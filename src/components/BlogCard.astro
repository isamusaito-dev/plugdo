---
import type { Blog } from '../lib/microcms';

interface Props {
  item: Blog;
}
const { item } = Astro.props;

const date = new Date(item.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${item.slug}/`} class="card group flex flex-col overflow-hidden">
  <div class="aspect-[16/9] overflow-hidden bg-mist">
    {
      item.eyecatch ? (
        <img
          src={`${item.eyecatch.url}?w=640&fit=crop`}
          alt={item.title}
          width="640"
          height="360"
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-navy/30">
          <span class="font-display text-2xl">plugdo</span>
        </div>
      )
    }
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center gap-2 text-xs">
      {
        item.category && (
          <span class="rounded-full bg-pink/10 px-2.5 py-1 font-bold text-pink">
            {item.category.name}
          </span>
        )
      }
      <time datetime={item.publishedAt} class="text-gray">{date}</time>
    </div>
    <h3 class="mt-3 text-base font-bold leading-snug text-navy group-hover:text-pink">
      {item.title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm text-gray">{item.description}</p>
  </div>
</a>
