---
import { plans, compareRows } from '../lib/plans';

interface Props {
  /** summary: トップ向け概要カード / full: 詳細カード+比較表 */
  variant?: 'summary' | 'full';
}
const { variant = 'full' } = Astro.props;

const categories = [...new Set(compareRows.map((r) => r.category))];

function cellVal(v: string | boolean): { label: string; positive: boolean } {
  if (v === true)  return { label: '✓', positive: true };
  if (v === false) return { label: '—', positive: false };
  return { label: v as string, positive: true };
}
---

<!-- ======= プランカード ======= -->
<div class="grid gap-6 md:grid-cols-3">
  {
    plans.map((plan) => (
      <div
        id={`plan-${plan.id}`}
        class:list={[
          'card relative flex flex-col overflow-hidden',
          plan.highlight ? 'border-pink shadow-[0_4px_32px_rgba(228,49,114,0.15)]' : '',
        ]}
      >
        {/* 主力バッジ（非主力はプレースホルダーで高さを統一） */}
        {plan.highlight ? (
          <div class="bg-pink py-1.5 text-center text-xs font-bold tracking-widest text-paper">
            ★ 主力プラン
          </div>
        ) : (
          <div class="py-1.5 text-xs" aria-hidden="true">&nbsp;</div>
        )}

        {/* こんな会社に */}
        <div class="border-b border-mist bg-sky/40 px-6 py-3">
          <p class="text-[10px] font-bold text-pink">こんな会社に →</p>
          <p class="mt-0.5 text-[13px] font-medium leading-snug text-navy">{plan.target}</p>
        </div>

        {/* ヘッダー */}
        <div class:list={['px-6 pb-4 pt-5', plan.highlight ? 'bg-navy/[0.02]' : '']}>
          <div class="flex items-start justify-between gap-2">
            <div>
              <span class="font-display text-2xl font-bold text-navy">{plan.name}</span>
              <p class="mt-0.5 text-xs text-gray">{plan.tagline}</p>
            </div>
            {plan.aio ? (
              <span class="mt-0.5 flex-shrink-0 rounded-full bg-navy px-2.5 py-1 text-[10px] font-bold text-paper">
                AIO対応
              </span>
            ) : (
              <span class="mt-0.5 flex-shrink-0 rounded-full bg-mist px-2.5 py-1 text-[10px] font-bold text-gray">
                AIO なし
              </span>
            )}
          </div>

          {/* 価格 */}
          <div class="mt-4 flex items-end gap-1">
            <span class="font-display text-[2rem] leading-none text-navy">{plan.price}</span>
            <span class="mb-1 text-xs text-gray">{plan.priceNote}</span>
          </div>
        </div>

        {/* 月にやること */}
        <div class="flex flex-1 flex-col border-t border-mist px-6 py-5">
          <p class="mb-3 text-[10px] font-bold uppercase tracking-widest text-gray/60">月にやること</p>
          <ul class="space-y-2.5">
            {plan.monthlyItems.map((item) => (
              <li class="flex items-start gap-2 text-sm text-ink">
                <span class="mt-0.5 font-bold text-navy" aria-hidden="true">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* CTA */}
        <div class="px-6 pb-6 pt-4">
          <a
            href="/contact"
            class:list={[
              'w-full text-sm',
              plan.highlight ? 'btn-pink' : 'btn-navy',
            ]}
          >
            このプランを相談する
          </a>
        </div>
      </div>
    ))
  }
</div>

<!-- 全プラン共通 -->
{
  variant === 'full' && (
    <div class="mt-10">
      <p class="mb-4 flex items-center justify-center gap-3 text-[10px] font-bold uppercase tracking-[0.15em] text-gray/50">
        <span class="block h-px w-10 bg-mist" aria-hidden="true" />
        全プラン共通
        <span class="block h-px w-10 bg-mist" aria-hidden="true" />
      </p>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <div class="flex items-start gap-3 rounded-xl border border-mist bg-paper p-4">
          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-navy/[0.07] text-navy">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 9a2 2 0 0 1-2 2H4.5L2 13.5V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z"/>
              <line x1="5.5" y1="7" x2="10.5" y2="7"/>
              <line x1="5.5" y1="9.5" x2="8.5" y2="9.5"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-navy">Slack 相談・質問</p>
            <p class="mt-0.5 text-[11px] leading-snug text-gray">無制限</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-mist bg-paper p-4">
          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-navy/[0.07] text-navy">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="8" r="6"/>
              <path d="M6 5.5h2.5a1.5 1.5 0 0 1 0 3H6v3.5"/>
              <line x1="6" y1="9" x2="9.5" y2="9"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-navy">初期費用</p>
            <p class="mt-0.5 text-[11px] leading-snug text-gray">なし</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-mist bg-paper p-4">
          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-navy/[0.07] text-navy">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="12" height="11" rx="1.5"/>
              <line x1="2" y1="7" x2="14" y2="7"/>
              <line x1="5.5" y1="1" x2="5.5" y2="5"/>
              <line x1="10.5" y1="1" x2="10.5" y2="5"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-navy">最低契約期間</p>
            <p class="mt-0.5 text-[11px] leading-snug text-gray">3ヶ月から</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-mist bg-paper p-4">
          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-navy/[0.07] text-navy">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 2a3 3 0 0 1 0 4.24L4.12 13.12 1.5 14l.88-2.62L9.26 4.5A3 3 0 0 1 11 2z"/>
              <line x1="9" y1="4.24" x2="11.76" y2="7"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-navy">実装対応</p>
            <p class="mt-0.5 text-[11px] leading-snug text-gray">各プランの枠内で</p>
          </div>
        </div>
      </div>
    </div>
  )
}

<!-- ======= 比較テーブル（full のみ） ======= -->
{
  variant === 'full' && (
    <div class="mt-16 overflow-x-auto">
      <h3 class="mb-6 text-center text-lg font-bold text-navy">機能一覧で比較する</h3>
      <table class="w-full min-w-[640px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-navy/10">
            <th class="w-[40%] pb-3 pr-4 text-left font-bold text-gray">機能</th>
            {plans.map((p) => (
              <th
                class:list={[
                  'pb-3 text-center font-display text-base',
                  p.highlight ? 'text-pink' : 'text-navy',
                ]}
              >
                {p.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {categories.map((cat) => {
            const rows = compareRows.filter((r) => r.category === cat);
            return (
              <>
                <tr>
                  <td
                    colspan="4"
                    class="bg-mist/60 px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-gray"
                  >
                    {cat}
                  </td>
                </tr>
                {rows.map((row, ri) => (
                  <tr class:list={['border-b border-mist/60', ri % 2 !== 0 ? 'bg-paper' : '']}>
                    <td class="py-3 pr-4 text-ink">{row.label}</td>
                    {(['keep', 'grow', 'partner'] as const).map((key) => {
                      const cv = cellVal(row[key]);
                      return (
                        <td class="py-3 text-center">
                          <span
                            class:list={[
                              'inline-block text-sm font-medium',
                              cv.positive ? 'text-navy' : 'text-gray/40',
                              cv.label === '✓' ? 'text-base font-bold text-pink' : '',
                            ]}
                          >
                            {cv.label}
                          </span>
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </>
            );
          })}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-navy/10">
            <td class="pt-5 pr-4 font-bold text-navy">月額（税別）</td>
            {plans.map((p) => (
              <td class="pt-5 text-center">
                <span class="font-display text-lg text-navy">{p.price}</span>
                <span class="ml-0.5 text-xs text-gray">〜</span>
              </td>
            ))}
          </tr>
          <tr>
            <td class="pb-2 pr-4" />
            {plans.map((p) => (
              <td class="pb-4 pt-3 text-center">
                <a
                  href="/contact"
                  class:list={[
                    'text-xs',
                    p.highlight ? 'btn-pink !px-5 !py-2' : 'btn-navy !px-5 !py-2',
                  ]}
                >
                  相談する
                </a>
              </td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
  )
}
