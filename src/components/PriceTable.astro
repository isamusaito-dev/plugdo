---
import { plans, compareRows } from '../lib/plans';

interface Props {
  /** summary: トップ向け概要カード / full: 詳細カード+比較表 */
  variant?: 'summary' | 'full';
}
const { variant = 'full' } = Astro.props;

const categories = [...new Set(compareRows.map((r) => r.category))];

function cellVal(v: string | boolean): { label: string; positive: boolean } {
  if (v === true)  return { label: '✓', positive: true };
  if (v === false) return { label: '—', positive: false };
  return { label: v as string, positive: true };
}
---

<!-- ======= プランカード ======= -->
<div class="grid gap-6 md:grid-cols-3">
  {
    plans.map((plan) => (
      <div
        class:list={[
          'card relative flex flex-col overflow-hidden',
          plan.highlight ? 'border-pink shadow-[0_4px_32px_rgba(228,49,114,0.15)]' : '',
        ]}
      >
        {/* 主力バッジ（非主力はプレースホルダーで高さを統一） */}
        {plan.highlight ? (
          <div class="bg-pink py-1.5 text-center text-xs font-bold tracking-widest text-paper">
            ★ 主力プラン
          </div>
        ) : (
          <div class="py-1.5 text-xs" aria-hidden="true">&nbsp;</div>
        )}

        {/* ヘッダー */}
        <div class:list={['p-7 pb-5', plan.highlight ? 'bg-navy/[0.02]' : '']}>
          <div class="flex items-start justify-between gap-2">
            <div>
              <span class="font-display text-2xl text-navy">{plan.name}</span>
              <p class="mt-0.5 text-xs text-gray">{plan.tagline}</p>
            </div>
            {plan.aio ? (
              <span class="mt-0.5 flex-shrink-0 rounded-full bg-navy px-2.5 py-1 text-[10px] font-bold text-paper">
                AIO対応
              </span>
            ) : (
              <span class="mt-0.5 flex-shrink-0 rounded-full bg-mist px-2.5 py-1 text-[10px] font-bold text-gray">
                AIO なし
              </span>
            )}
          </div>

          {/* コミット */}
          <div
            class:list={[
              'mt-5 rounded-xl px-4 py-3.5',
              plan.highlight ? 'bg-pink/[0.18] ring-1 ring-pink/20' : 'bg-mist',
            ]}
          >
            <p class="text-[10px] font-bold uppercase tracking-widest text-gray/70">コミット</p>
            <p class="mt-1 text-[15px] font-bold leading-snug text-navy">{plan.commit}</p>
            <p class="mt-0.5 text-xs text-gray">（{plan.commitNote}）</p>
          </div>

          {/* 価格 */}
          <div class="mt-5 flex items-end gap-1">
            <span class="font-display text-[2rem] leading-none text-navy">{plan.price}</span>
            <span class="mb-1 text-xs text-gray">{plan.priceNote}</span>
          </div>
          <p class="mt-1.5 text-xs text-gray">想定工数：{plan.hours}</p>
        </div>

        {/* 機能リスト */}
        {variant === 'full' && (
          <div class="flex flex-1 flex-col border-t border-mist px-7 py-6">
            <ul class="space-y-2.5">
              {plan.groups[0].items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-ink">
                  <span class="mt-0.5 text-pink" aria-hidden="true">✓</span>
                  <span>
                    {item.label}
                    {item.note && (
                      <span class="ml-1 text-[11px] text-gray">（{item.note}）</span>
                    )}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* CTA */}
        <div class="px-7 pb-7 pt-4">
          <a
            href="/contact"
            class:list={[
              'w-full text-sm',
              plan.highlight ? 'btn-pink' : 'btn-navy',
            ]}
          >
            このプランを相談する
          </a>
        </div>
      </div>
    ))
  }
</div>

<!-- 全プラン共通 -->
{
  variant === 'full' && (
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 rounded-xl border border-mist bg-paper px-8 py-4 text-xs text-gray">
      <span class="font-bold text-navy">全プラン共通</span>
      <span>Slack 相談・質問 無制限</span>
      <span>初期費用なし</span>
      <span>最低3ヶ月から</span>
      <span>実装は各プランの枠内で対応</span>
    </div>
  )
}

<!-- ======= 比較テーブル（full のみ） ======= -->
{
  variant === 'full' && (
    <div class="mt-16 overflow-x-auto">
      <h3 class="mb-6 text-center text-lg font-bold text-navy">機能一覧で比較する</h3>
      <table class="w-full min-w-[640px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-navy/10">
            <th class="w-[40%] pb-3 pr-4 text-left font-bold text-gray">機能</th>
            {plans.map((p) => (
              <th
                class:list={[
                  'pb-3 text-center font-display text-base',
                  p.highlight ? 'text-pink' : 'text-navy',
                ]}
              >
                {p.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {categories.map((cat) => {
            const rows = compareRows.filter((r) => r.category === cat);
            return (
              <>
                <tr>
                  <td
                    colspan="4"
                    class="bg-mist/60 px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-gray"
                  >
                    {cat}
                  </td>
                </tr>
                {rows.map((row, ri) => (
                  <tr class:list={['border-b border-mist/60', ri % 2 !== 0 ? 'bg-paper' : '']}>
                    <td class="py-3 pr-4 text-ink">{row.label}</td>
                    {(['keep', 'grow', 'partner'] as const).map((key) => {
                      const cv = cellVal(row[key]);
                      return (
                        <td class="py-3 text-center">
                          <span
                            class:list={[
                              'inline-block text-sm font-medium',
                              cv.positive ? 'text-navy' : 'text-gray/40',
                              cv.label === '✓' ? 'text-base font-bold text-pink' : '',
                            ]}
                          >
                            {cv.label}
                          </span>
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </>
            );
          })}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-navy/10">
            <td class="pt-5 pr-4 font-bold text-navy">月額（税別）</td>
            {plans.map((p) => (
              <td class="pt-5 text-center">
                <span class="font-display text-lg text-navy">{p.price}</span>
                <span class="ml-0.5 text-xs text-gray">〜</span>
              </td>
            ))}
          </tr>
          <tr>
            <td class="pb-2 pr-4" />
            {plans.map((p) => (
              <td class="pb-4 pt-3 text-center">
                <a
                  href="/contact"
                  class:list={[
                    'text-xs',
                    p.highlight ? 'btn-pink !px-5 !py-2' : 'btn-navy !px-5 !py-2',
                  ]}
                >
                  相談する
                </a>
              </td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
  )
}
