---
// TOPのサービス分岐カード（リニューアル / Web運用）。#services アンカー先。
const cards = [
  {
    name: 'リニューアル',
    lead: '作り直しが必要なサイトへ',
    pricePrefix: '',
    priceAmount: '198,000',
    priceUnit: '〜',
    href: '/renewal',
    desc: '診断で減点が集中したサイトを、必要な分だけ作り直します。5ページ構成・スマホ対応・基本SEOを含む定額パッケージ。',
    cta: 'リニューアルの内容を見る',
    highlight: false,
  },
  {
    name: 'Web運用',
    lead: '作り直すほどではないサイトへ',
    pricePrefix: '月',
    priceAmount: '9,800',
    priceUnit: '〜',
    href: '/care',
    desc: 'サーバー管理・更新代行・月次の改善提案まで。最低契約期間なし、いつでも解約できます。',
    cta: 'Web運用の内容を見る',
    highlight: true,
  },
];
---

<section id="services" class="bg-mist">
  <div class="container-pd py-16 md:py-20">
    <div class="text-center" data-animate="fade-in">
      <p class="section-label">- Services -</p>
      <h2 class="section-title">サービスは、2つだけ。</h2>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
        どちらが必要かは、診断が教えてくれます。
      </p>
    </div>

    <!-- 診断スコアによる分岐の図解 -->
    <div class="mx-auto mt-10 max-w-4xl" data-animate="fade-in">
      <div class="rounded-2xl border border-gray/10 bg-paper p-6 md:p-9">
        <p class="text-center text-base font-bold text-navy md:text-lg">
          無料AI診断のスコアが、<span class="text-pink">必要なほう</span>を教えてくれます。
        </p>
        <p class="mt-1.5 text-center text-xs text-gray">100点満点。60点を境に、おすすめが分かれます。</p>

        <!-- スコアバー -->
        <div class="relative mx-auto mt-11 max-w-2xl">
          <!-- 60点フラッグ -->
          <div class="absolute left-[60%] top-[-28px] z-10 -translate-x-1/2 text-center">
            <span class="inline-block rounded-full bg-ink px-3 py-1 font-display text-[11px] font-black text-white [font-variant-numeric:tabular-nums]">60点</span>
            <span class="mx-auto mt-0.5 block h-3 w-px bg-ink/50"></span>
          </div>
          <div class="flex h-4 overflow-hidden rounded-full shadow-[0_2px_10px_rgba(16,51,102,0.10)]">
            <div class="w-[60%] bg-pink"></div>
            <div class="w-[40%] bg-navy"></div>
          </div>
          <div class="mt-2 flex justify-between font-display text-[11px] font-bold text-gray/70 [font-variant-numeric:tabular-nums]">
            <span>0</span>
            <span>100</span>
          </div>
        </div>

        <!-- 2ゾーン（緩急：チップ＋大きめサービス名＋下向き矢印） -->
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="relative rounded-xl bg-pink/[0.07] p-5 text-center">
            <span class="inline-block rounded-full bg-pink px-3 py-1 text-[11px] font-bold text-white [font-variant-numeric:tabular-nums]">60点未満</span>
            <p class="mt-3 text-xl font-black text-navy">リニューアル</p>
            <p class="mt-1 text-xs text-gray">土台から作り直す</p>
            <span class="absolute -bottom-3 left-1/2 hidden -translate-x-1/2 text-pink sm:block" aria-hidden="true">
              <svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M2 2l7 6 7-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="relative rounded-xl bg-navy/[0.05] p-5 text-center">
            <span class="inline-block rounded-full bg-navy px-3 py-1 text-[11px] font-bold text-white [font-variant-numeric:tabular-nums]">60点以上</span>
            <p class="mt-3 text-xl font-black text-navy">Web運用</p>
            <p class="mt-1 text-xs text-gray">今のサイトを育てる</p>
            <span class="absolute -bottom-3 left-1/2 hidden -translate-x-1/2 text-navy sm:block" aria-hidden="true">
              <svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M2 2l7 6 7-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto mt-6 grid max-w-4xl gap-6 md:grid-cols-2">
      {
        cards.map((c) => (
          <a
            href={c.href}
            class:list={[
              'card group flex flex-col p-7 no-underline md:p-8',
              c.highlight ? 'border-navy/20' : '',
            ]}
          >
            <p class="text-xs font-bold text-pink">{c.lead}</p>
            <h3 class="mt-2 text-2xl font-black text-navy">{c.name}</h3>
            <div class="mt-4 flex items-end gap-0.5 border-t border-mist pt-4">
              {c.pricePrefix && (
                <span class="mb-1.5 text-lg font-black text-navy">{c.pricePrefix}</span>
              )}
              <span class="mb-1.5 font-display text-xl font-bold text-navy">¥</span>
              <span class="font-display text-[2.75rem] font-black leading-none text-navy [font-variant-numeric:tabular-nums]">{c.priceAmount}</span>
              <span class="mb-1.5 text-lg font-black text-navy">{c.priceUnit}</span>
              <span class="mb-2 ml-1 text-xs text-gray">（税込）</span>
            </div>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-gray">{c.desc}</p>
            <p class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-navy group-hover:text-pink">
              {c.cta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" /></svg>
            </p>
          </a>
        ))
      }
    </div>

    <!-- 診断CVボタン -->
    <div class="mt-10 text-center" data-animate="fade-in">
      <a href="/check" class="btn-pink">無料で自社サイトを診断する（30秒）</a>
      <p class="mt-3 text-xs text-gray">URLを入れるだけ・30秒／診断は無料・契約不要</p>
    </div>
  </div>
</section>
