---
interface Props {
  title: string;
  description: string;
  accent?: string;
}
const { title, description, accent = 'bg-navy/8' } = Astro.props;
---

<div class="card group flex flex-col p-7" data-animate>
  <div class="flex items-start justify-between">
    <div
      class:list={[
        'flex h-14 w-14 items-center justify-center rounded-xl',
        accent,
      ]}
      aria-hidden="true"
    >
      <slot name="icon" />
    </div>
    <span class="mt-1 text-xl text-pink opacity-0 transition-opacity duration-200 group-hover:opacity-100">→</span>
  </div>
  <h3 class="mt-5 text-lg font-bold text-navy">{title}</h3>
  <p class="mt-2.5 flex-1 text-sm leading-relaxed text-ink/80">{description}</p>
</div>
