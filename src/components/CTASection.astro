---
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = 'そのホームページ、働かせてみませんか。',
  text = 'まずは無料のWeb診断から。現状の課題と、伸ばせるポイントをお返しします。初期費用なし・最低3ヶ月から。',
} = Astro.props;
---

<section class="relative overflow-hidden bg-navy">
  <!-- 背景装飾 -->
  <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-white/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -left-16 bottom-0 h-72 w-72 rounded-full bg-pink/10 blur-3xl"></div>
  <div class="container-pd relative py-20 text-center md:py-24">
    <p class="section-label text-pink/70">
      <span class="block h-px w-8 bg-pink/40"></span>
      Free Consultation
      <span class="block h-px w-8 bg-pink/40"></span>
    </p>
    <h2 class="mt-2 text-2xl font-black text-paper md:text-[2rem]">{heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-white/70 md:text-base">
      {text}
    </p>
    <div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
      <a href="/contact" class="btn-pink">無料でWeb診断を受ける</a>
      <a
        href="/price"
        class="btn border-2 border-white/30 bg-transparent text-white hover:border-white hover:bg-white hover:text-navy"
      >
        料金を見る
      </a>
    </div>
    <p class="mt-6 text-xs text-white/50">初期費用なし・まずは診断だけでもOK</p>
  </div>
</section>
