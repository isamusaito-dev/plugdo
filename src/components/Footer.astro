---
const year = new Date().getFullYear();

const cols = [
  {
    heading: 'サービス',
    links: [
      { label: 'サービス概要', href: '/service' },
      { label: '料金プラン', href: '/price' },
    ],
  },
  {
    heading: '情報',
    links: [
      { label: 'ブログ', href: '/blog' },
      { label: '運営会社', href: '/about' },
      { label: 'お問い合わせ', href: '/contact' },
    ],
  },
];
---

<footer class="mt-auto bg-slate text-paper">
  <div class="container-pd grid gap-10 py-14 md:grid-cols-[1.5fr_1fr_1fr]">
    <div>
      <div>
        <img src="/logo.svg" alt="plugdo" class="w-auto brightness-0 invert" style="height:2.4rem" />
      </div>
      <p class="mt-4 text-sm leading-relaxed text-white/80">
        ホームページを、働かせる。<br />
        作ったまま放置されがちなサイトを、毎月の改善で問い合わせと採用につなげます。
      </p>
      <a href="/contact" class="btn-pink mt-6 text-sm">無料相談する</a>
    </div>

    {
      cols.map((col) => (
        <nav aria-label={col.heading}>
          <h2 class="text-sm font-bold text-white">{col.heading}</h2>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-white/80 transition-colors hover:text-pink">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-white/15">
    <div class="container-pd flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/70 md:flex-row">
      <p>運営: 株式会社ハンチス（HUNCHES）</p>
      <p>&copy; {year} HUNCHES Inc. All rights reserved.</p>
    </div>
  </div>
</footer>
