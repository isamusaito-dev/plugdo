---
// トップページのヒーロー。左:テキスト+CTA / 右:ダッシュボードイラスト / 下:サービス特徴バー

---

<style>
  /* ── グラデーション: 薄いブルー ↔ 白 ─────────────────── */
  .hero-animated {
    background: linear-gradient(
      150deg,
      #bdd8f0 0%,
      #daeeff 20%,
      #f0f8ff 40%,
      #ffffff 55%,
      #e8f5ff 70%,
      #c8e4f8 85%,
      #bdd8f0 100%
    );
    background-size: 400% 400%;
    animation: hero-shift 10s ease-in-out infinite;
  }

  @keyframes hero-shift {
    0%   { background-position: 0%   30%; }
    35%  { background-position: 100% 70%; }
    65%  { background-position: 60%  10%; }
    100% { background-position: 0%   30%; }
  }


  /* ── バッジシマー ──────────────────────────────────────── */
  @keyframes badge-shimmer {
    0%   { transform: translateX(-180%); }
    100% { transform: translateX(180%); }
  }
  .badge-shimmer-bar {
    animation: badge-shimmer 3.5s ease-in-out 0.8s infinite;
  }

  /* ── チャート描画 ────────────────────────────────────────── */
  #hero-chart-line {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: svg-draw 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }
  #hero-area-fill {
    opacity: 0;
    animation: svg-fade 0.7s ease-out 1.5s forwards;
  }
  #hero-pt-1 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s forwards;
  }
  #hero-pt-2 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.0s forwards;
  }
  #hero-pt-3 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.15s forwards;
  }
  #hero-pt-4 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.3s forwards;
  }
  #hero-pt-5 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) 1.45s forwards;
  }
  #hero-tooltip {
    opacity: 0; transform-box: fill-box; transform-origin: bottom center;
    transform: translateY(6px) scale(0.95);
    animation: svg-tooltip 0.4s cubic-bezier(0.34, 1.4, 0.64, 1) 1.7s forwards;
  }
  #hero-notif {
    opacity: 0; transform-box: fill-box; transform-origin: center bottom;
    transform: translateY(18px);
    animation: svg-slide-up 0.55s cubic-bezier(0.34, 1.4, 0.64, 1) 2.1s forwards;
  }

  @keyframes svg-draw    { to { stroke-dashoffset: 0; } }
  @keyframes svg-fade    { to { opacity: 1; } }
  @keyframes svg-pop {
    0%   { opacity: 0; transform: scale(0); }
    70%  { transform: scale(1.25); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes svg-tooltip  { to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes svg-slide-up { to { opacity: 1; transform: translateY(0); } }
</style>

<section class="hero-animated relative overflow-hidden">

  <!-- 流線背景 canvas -->
  <canvas
    id="flow-bg"
    data-color="16,51,102"
    data-opacity="0.13"
    class="pointer-events-none absolute inset-0 h-full w-full"
    style="z-index:0"
    aria-hidden="true"
  ></canvas>

  <!-- 装飾円 -->
  <div class="pointer-events-none absolute -right-32 -top-32 h-[480px] w-[480px] rounded-full bg-sky opacity-60 blur-3xl" style="z-index:1"></div>
  <div class="pointer-events-none absolute -bottom-16 left-1/3 h-[300px] w-[300px] rounded-full bg-pink/5 blur-3xl" style="z-index:1"></div>

  <div class="container-pd relative py-20 md:py-28" style="z-index:10">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- 左カラム: テキスト + CTA -->
      <div>

        <!-- ── 強調バッジ ─────────────────────────────── -->
        <div class="relative mb-6 inline-flex max-w-md items-start gap-3 overflow-hidden rounded-2xl border border-pink/25 bg-white/75 px-5 py-3.5 shadow-md backdrop-blur-sm">
          <!-- シマーオーバーレイ -->
          <div
            class="badge-shimmer-bar pointer-events-none absolute inset-0 -skew-x-12 bg-gradient-to-r from-transparent via-white/60 to-transparent"
          ></div>
          <!-- ピンクドット (パルス) -->
          <span class="relative mt-1 flex h-2.5 w-2.5 flex-shrink-0">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-pink opacity-60"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-pink"></span>
          </span>
          <!-- テキスト -->
          <p class="relative text-sm font-bold leading-snug text-navy">
            デザインに強い<strong class="text-pink">「社外のWeb担当」</strong>が、<br class="sm:hidden" />月額制で伴走します
          </p>
        </div>

        <!-- ── メインキャッチ ────────────────────────── -->
        <h1 class="text-[2.75rem] font-black leading-[1.15] tracking-tight text-navy md:text-[3.5rem]">
          ホームページを、<br />働かせる。
        </h1>
        <p class="mt-6 max-w-md text-base leading-[1.9] text-ink/70">
          社内にWeb担当者がいない中小企業向けに、ホームページの更新・導線改善・SEO/AIO対応・月次改善レポートを月額制で提供する<strong class="font-bold text-navy">社外Web担当サービス</strong>です。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/check" class="btn-pink">無料でサイト診断する</a>
          <a href="/contact" class="btn-outline text-sm">無料相談する</a>
        </div>
        <p class="mt-5 text-xs text-gray">URLを入れるだけ・30秒／契約不要</p>
      </div>

      <!-- 右カラム: FVイメージ -->
      <div class="relative hidden lg:block">
        <div class="overflow-hidden rounded-3xl shadow-[0_8px_48px_rgba(16,51,102,0.14)]">
          <img
            src="/fv001.png"
            alt="Plugdo サービスイメージ"
            class="w-full"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- ── サービス特徴バー ─────────────────────────────────── -->
  <div class="bg-navy" style="position:relative;z-index:10">
    <div class="mx-auto w-full max-w-content px-0 md:px-8">
      <ul class="grid grid-cols-2 md:grid-cols-4">
        {[
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1.5" y="3" width="15" height="13.5" rx="2.5"/><path d="M5.5 1.5v3M12.5 1.5v3M1.5 7.5h15"/><circle cx="5.5" cy="12" r="1" fill="white" stroke="none"/><circle cx="9" cy="12" r="1" fill="white" stroke="none"/><circle cx="12.5" cy="12" r="1" fill="white" stroke="none"/></svg>',
            title: '毎月サイトを改善',
            desc: '更新・導線改善・SEO対策を継続',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 1.5 L16 5.5 L16 12.5 L9 16.5 L2 12.5 L2 5.5 Z"/><circle cx="9" cy="9" r="2.5" fill="white" stroke="none"/></svg>',
            title: 'LINE・SNS・広告と連携',
            desc: '入口をサイトというゴールにつなぐ',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 14 6 8.5 9 11 14.5 4"/><polyline points="11 4 14.5 4 14.5 7.5"/></svg>',
            title: '問い合わせ・採用につなげる',
            desc: '成果まで責任を持って伴走',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="7.5" r="5"/><line x1="11.2" y1="11.2" x2="16" y2="16"/><path d="M5.5 7.5h4M7.5 5.5v4"/></svg>',
            title: 'まずは無料Web診断',
            desc: '現状の課題を3分で整理',
          },
        ].map((f, i) => (
          <li class:list={[
            'flex items-center gap-2 px-4 py-3 md:gap-3 md:px-6 md:py-5',
            i < 2 && 'border-b border-white/15 md:border-b-0',
            (i === 1 || i === 3) && 'border-l border-white/15',
            i === 2 && 'md:border-l md:border-white/15',
          ]}>
            <span
              class="flex h-5 w-5 flex-shrink-0 items-center justify-center opacity-80 md:h-8 md:w-8"
              set:html={f.icon}
            />
            <div>
              <p class="text-[9px] font-bold leading-snug text-white md:text-[13px]">{f.title}</p>
              <p class="mt-0.5 hidden text-[10px] leading-snug text-white/45 md:block">{f.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  function initFlow(canvas) {
    if (canvas.dataset.flowInit) return;
    canvas.dataset.flowInit = "1";
    var ctx = canvas.getContext("2d");
    if (!ctx) return;
    var color = canvas.dataset.color || "16,51,102";
    var baseOpacity = parseFloat(canvas.dataset.opacity || "0.07");
    var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var w = 0, h = 0, t = 0, raf = null, particles = [];
    function build() {
      var mobile = w < 640;
      var density = mobile ? 16000 : 8500;
      var n = Math.max(8, Math.round((w * h) / density));
      particles = [];
      for (var i = 0; i < n; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          s: 0.18 + Math.random() * 0.4,
          r: 1.2 + Math.random() * 2.0
        });
      }
    }
    function resize() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      build();
    }
    function field(x, y) {
      return Math.sin(x * 0.006 + t * 0.01) * 0.6
           + Math.cos(y * 0.008 - t * 0.006) * 0.5;
    }
    function render() {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "rgba(" + color + "," + baseOpacity + ")";
      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        var a = field(p.x, p.y);
        if (!reduce) {
          p.x += Math.cos(a) * p.s + 0.22;
          p.y += Math.sin(a) * p.s;
        }
        if (p.x > w + 20) { p.x = -20; p.y = Math.random() * h; }
        if (p.y > h + 20) p.y = -20;
        if (p.y < -20) p.y = h + 20;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }
    function loop() { render(); t += 1; raf = requestAnimationFrame(loop); }
    function start() { if (!raf) loop(); }
    function stop() { if (raf) { cancelAnimationFrame(raf); raf = null; } }
    resize();
    window.addEventListener("resize", resize);
    if (reduce) { render(); return; }
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) start(); else stop();
    }, { threshold: 0 });
    io.observe(canvas);
    start();
  }
  function boot() {
    document.querySelectorAll("#flow-bg").forEach(function(c) { initFlow(c); });
  }
  if (document.readyState !== "loading") boot();
  else document.addEventListener("DOMContentLoaded", boot);
  document.addEventListener("astro:page-load", boot);
})();
</script>
