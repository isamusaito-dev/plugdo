---
// トップページのヒーロー。左:テキスト+CTA / 右:装飾UIカード / 下:サービス特徴バー
---

<section class="hero-gradient relative overflow-hidden">
  <!-- 背景の装飾円 -->
  <div class="pointer-events-none absolute -right-32 -top-32 h-[480px] w-[480px] rounded-full bg-sky opacity-60 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-16 left-1/3 h-[300px] w-[300px] rounded-full bg-pink/5 blur-3xl"></div>

  <div class="container-pd relative py-20 md:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- 左カラム: テキスト + CTA -->
      <div>
        <p class="section-label-left">Make your website work</p>
        <h1 class="mt-1 text-[2.75rem] font-black leading-[1.15] tracking-tight text-navy md:text-[3.5rem]">
          ホームページを、<br />働かせる。
        </h1>
        <p class="mt-6 max-w-md text-base leading-[1.9] text-ink/80">
          作ったきりになっているサイトを、<br />
          <strong class="font-bold text-navy">問い合わせと採用</strong>につなげる。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-pink text-sm">無料でサイト診断を受ける</a>
          <a href="/service" class="btn-outline text-sm">サービスを見る</a>
        </div>
        <p class="mt-5 flex items-center gap-2 text-xs text-gray">
          <svg class="flex-shrink-0 text-pink" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          Web担当者がいない中小企業の経営者のためのサービスです。
        </p>
      </div>

      <!-- 右カラム: 浮かぶ改善レポートUIカード -->
      <div class="relative hidden lg:block" aria-hidden="true">
        <div class="card relative z-10 overflow-hidden p-0">
          <div class="flex items-center justify-between bg-navy px-5 py-3.5">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-pink"></div>
              <span class="font-grotesk text-xs text-white/80">月次改善レポート</span>
            </div>
            <span class="font-grotesk text-xs text-white/60">2026年5月</span>
          </div>
          <div class="p-5">
            <p class="text-xs text-gray">自然検索からの流入</p>
            <div class="mt-2 flex items-end gap-3">
              <span class="font-display text-3xl font-bold text-navy">+312%</span>
              <span class="mb-1 text-xs font-bold text-pink">▲ 前月比</span>
            </div>
            <!-- ミニグラフ -->
            <div class="mt-4 flex h-14 items-end gap-1.5">
              {[20, 28, 24, 36, 40, 52, 70, 85, 100].map((h) => (
                <div class="flex-1 rounded-sm bg-navy/10" style={`height:${h}%`}></div>
              ))}
              <div class="flex-1 rounded-sm bg-pink" style="height:100%"></div>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2">
              <div class="rounded-lg bg-mist px-2 py-2 text-center">
                <p class="font-display text-base font-bold text-navy">8件</p>
                <p class="text-[10px] text-gray">問い合わせ/月</p>
              </div>
              <div class="rounded-lg bg-mist px-2 py-2 text-center">
                <p class="font-display text-base font-bold text-navy">23↑</p>
                <p class="text-[10px] text-gray">検索順位改善</p>
              </div>
              <div class="rounded-lg bg-pink/10 px-2 py-2 text-center">
                <p class="font-display text-base font-bold text-pink">2件</p>
                <p class="text-[10px] text-gray">受注</p>
              </div>
            </div>
          </div>
        </div>
        <!-- 浮かぶバッジ -->
        <div class="absolute -bottom-6 -right-4 z-20 card flex items-center gap-3 px-4 py-3 shadow-xl">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gold/20">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C8A951" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <div>
            <p class="text-[11px] font-bold text-navy">AIO対応</p>
            <p class="text-[10px] text-gray">AI検索から引用される</p>
          </div>
        </div>
        <div class="absolute -left-8 -top-4 z-20 card flex items-center gap-2.5 px-3.5 py-2.5 shadow-xl">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-pink/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E43172" stroke-width="2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <div>
            <p class="text-[11px] font-bold text-navy">月次サイクル</p>
            <p class="text-[10px] text-gray">診断→改善→計測</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- サービス特徴バー（実績数値ではなくサービス事実） -->
  <div class="border-t border-navy/8 bg-white/60 backdrop-blur-sm">
    <div class="container-pd py-6">
      <dl class="grid grid-cols-2 gap-6 md:grid-cols-4">
        {[
          { value: '¥30,000', unit: '〜/月', label: '初期費用なし・月額制' },
          { value: '3',       unit: 'ヶ月',  label: '最短利用期間から' },
          { value: '3',       unit: 'プラン', label: 'フェーズに合わせて選択' },
          { value: 'AIO',     unit: '対応',  label: 'Growth・Partnerに含む' },
        ].map((s) => (
          <div class="text-center">
            <dt class="text-[10px] uppercase tracking-widest text-gray">{s.label}</dt>
            <dd class="mt-1 font-display text-2xl font-bold text-navy md:text-3xl">
              {s.value}<span class="text-base text-pink">{s.unit}</span>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>
