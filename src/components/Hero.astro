---
// トップページのヒーロー。左:テキスト+CTA / 右:ダッシュボードイラスト / 下:サービス特徴バー

---

<style>
  /* ── グラデーション: 薄いブルー ↔ 白 ─────────────────── */
  .hero-animated {
    background: linear-gradient(
      150deg,
      #bdd8f0 0%,
      #daeeff 20%,
      #f0f8ff 40%,
      #ffffff 55%,
      #e8f5ff 70%,
      #c8e4f8 85%,
      #bdd8f0 100%
    );
    background-size: 400% 400%;
    animation: hero-shift 10s ease-in-out infinite;
  }

  @keyframes hero-shift {
    0%   { background-position: 0%   30%; }
    35%  { background-position: 100% 70%; }
    65%  { background-position: 60%  10%; }
    100% { background-position: 0%   30%; }
  }


  /* ── バッジシマー ──────────────────────────────────────── */
  @keyframes badge-shimmer {
    0%   { transform: translateX(-180%); }
    100% { transform: translateX(180%); }
  }
  .badge-shimmer-bar {
    animation: badge-shimmer 3.5s ease-in-out 0.8s infinite;
  }

  /* ── チャート描画 ────────────────────────────────────────── */
  #hero-chart-line {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: svg-draw 1.4s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }
  #hero-area-fill {
    opacity: 0;
    animation: svg-fade 0.7s ease-out 1.5s forwards;
  }
  #hero-pt-1 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s forwards;
  }
  #hero-pt-2 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.0s forwards;
  }
  #hero-pt-3 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.15s forwards;
  }
  #hero-pt-4 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) 1.3s forwards;
  }
  #hero-pt-5 {
    opacity: 0; transform-box: fill-box; transform-origin: center; transform: scale(0);
    animation: svg-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) 1.45s forwards;
  }
  #hero-tooltip {
    opacity: 0; transform-box: fill-box; transform-origin: bottom center;
    transform: translateY(6px) scale(0.95);
    animation: svg-tooltip 0.4s cubic-bezier(0.34, 1.4, 0.64, 1) 1.7s forwards;
  }
  #hero-notif {
    opacity: 0; transform-box: fill-box; transform-origin: center bottom;
    transform: translateY(18px);
    animation: svg-slide-up 0.55s cubic-bezier(0.34, 1.4, 0.64, 1) 2.1s forwards;
  }

  @keyframes svg-draw    { to { stroke-dashoffset: 0; } }
  @keyframes svg-fade    { to { opacity: 1; } }
  @keyframes svg-pop {
    0%   { opacity: 0; transform: scale(0); }
    70%  { transform: scale(1.25); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes svg-tooltip  { to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes svg-slide-up { to { opacity: 1; transform: translateY(0); } }
</style>

<section class="hero-animated relative overflow-hidden">

  <!-- 流線背景 canvas -->
  <canvas
    id="flow-bg"
    data-color="16,51,102"
    data-opacity="0.13"
    class="pointer-events-none absolute inset-0 h-full w-full"
    style="z-index:0"
    aria-hidden="true"
  ></canvas>

  <!-- 装飾円 -->
  <div class="pointer-events-none absolute -right-32 -top-32 h-[480px] w-[480px] rounded-full bg-sky opacity-60 blur-3xl" style="z-index:1"></div>
  <div class="pointer-events-none absolute -bottom-16 left-1/3 h-[300px] w-[300px] rounded-full bg-pink/5 blur-3xl" style="z-index:1"></div>

  <div class="container-pd relative py-20 md:py-28" style="z-index:10">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- 左カラム: テキスト + CTA -->
      <div>

        <!-- ── 強調バッジ ─────────────────────────────── -->
        <div class="relative mb-6 inline-flex max-w-md items-start gap-3 overflow-hidden rounded-2xl border border-pink/25 bg-white/75 px-5 py-3.5 shadow-md backdrop-blur-sm">
          <!-- シマーオーバーレイ -->
          <div
            class="badge-shimmer-bar pointer-events-none absolute inset-0 -skew-x-12 bg-gradient-to-r from-transparent via-white/60 to-transparent"
          ></div>
          <!-- ピンクドット (パルス) -->
          <span class="relative mt-1 flex h-2.5 w-2.5 flex-shrink-0">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-pink opacity-60"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-pink"></span>
          </span>
          <!-- テキスト -->
          <p class="relative text-sm font-bold leading-snug text-navy">
            デザインに強い<strong class="text-pink">「社外のWeb担当」</strong>が、<br class="sm:hidden" />月額制で伴走します
          </p>
        </div>

        <!-- ── メインキャッチ ────────────────────────── -->
        <h1 class="text-[2.75rem] font-black leading-[1.15] tracking-tight text-navy md:text-[3.5rem]">
          ホームページを、<br />働かせる。
        </h1>
        <p class="mt-6 max-w-md text-base leading-[1.9] text-ink/70">
          社内にWeb担当者がいない中小企業向けに、ホームページの更新・導線改善・SEO/AIO対応・月次改善レポートを月額制で提供する<strong class="font-bold text-navy">社外Web担当サービス</strong>です。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-pink">無料でWeb診断を受ける</a>
          <a href="/price" class="btn-outline text-sm">料金プランを見る</a>
        </div>
        <p class="mt-5 text-xs text-gray">初期費用なし／まずは診断だけでもOK</p>
      </div>

      <!-- 右カラム: ダッシュボードイラスト -->
      <div class="relative hidden lg:block" aria-hidden="true">
        <div class="aspect-[4/3] w-full overflow-hidden rounded-2xl shadow-[0_8px_40px_rgba(16,51,102,0.12)]">
          <svg viewBox="0 0 480 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-full w-full" role="img" aria-label="サイト改善ダッシュボードのイメージ">
            <defs>
              <filter id="h-card" x="-15%" y="-15%" width="130%" height="130%">
                <feDropShadow dx="0" dy="4" stdDeviation="12" flood-color="#103366" flood-opacity="0.08"/>
              </filter>
              <filter id="h-notif" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="8" stdDeviation="20" flood-color="#103366" flood-opacity="0.14"/>
              </filter>
              <linearGradient id="h-area" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#E43172" stop-opacity="0.14"/>
                <stop offset="100%" stop-color="#E43172" stop-opacity="0"/>
              </linearGradient>
              <linearGradient id="h-bg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#EAF3FB"/>
                <stop offset="100%" stop-color="#f2f5f9"/>
              </linearGradient>
            </defs>

            <rect width="480" height="360" fill="url(#h-bg)" rx="16"/>
            <circle cx="420" cy="48" r="110" fill="white" opacity="0.45"/>
            <circle cx="60" cy="310" r="70" fill="#E43172" opacity="0.03"/>

            <rect x="16" y="20" width="360" height="250" rx="14" fill="white" filter="url(#h-card)"/>
            <rect x="16" y="20" width="360" height="36" rx="14" fill="#EBEEF2"/>
            <rect x="16" y="42" width="360" height="14" fill="#EBEEF2"/>
            <circle cx="38" cy="38" r="5" fill="#103366" opacity="0.14"/>
            <circle cx="54" cy="38" r="5" fill="#103366" opacity="0.14"/>
            <circle cx="70" cy="38" r="5" fill="#103366" opacity="0.14"/>
            <rect x="100" y="28" width="160" height="18" rx="9" fill="white" opacity="0.85"/>
            <text x="180" y="41" text-anchor="middle" font-size="8.5" font-family="system-ui,-apple-system,sans-serif" fill="#103366" opacity="0.4">plugdo.jp</text>

            <rect x="28" y="68" width="116" height="60" rx="12" fill="#EAF3FB"/>
            <text x="40" y="85" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#797979">月間問い合わせ</text>
            <text x="40" y="116" font-size="28" font-weight="800" font-family="system-ui,-apple-system,sans-serif" fill="#103366">8件</text>
            <rect x="106" y="69" width="32" height="16" rx="8" fill="#E43172" opacity="0.12"/>
            <text x="122" y="81" text-anchor="middle" font-size="8.5" font-family="system-ui,-apple-system,sans-serif" fill="#E43172" font-weight="700">↑8x</text>

            <rect x="28" y="138" width="116" height="60" rx="12" fill="#EAF3FB"/>
            <text x="40" y="155" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#797979">月間検索流入</text>
            <text x="40" y="186" font-size="28" font-weight="800" font-family="system-ui,-apple-system,sans-serif" fill="#103366">×4</text>
            <rect x="106" y="139" width="32" height="16" rx="8" fill="#E43172" opacity="0.12"/>
            <text x="122" y="151" text-anchor="middle" font-size="8.5" font-family="system-ui,-apple-system,sans-serif" fill="#E43172" font-weight="700">↑UP</text>

            <rect x="28" y="208" width="116" height="48" rx="12" fill="white" stroke="#E43172" stroke-width="1.5" stroke-opacity="0.25"/>
            <text x="40" y="225" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#797979">AI検索引用</text>
            <text x="40" y="248" font-size="24" font-weight="800" font-family="system-ui,-apple-system,sans-serif" fill="#E43172">3語</text>
            <rect x="104" y="209" width="32" height="16" rx="8" fill="#103366" opacity="0.07"/>
            <text x="120" y="221" text-anchor="middle" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#103366" font-weight="700">NEW</text>

            <line x1="157" y1="65" x2="157" y2="258" stroke="#EBEEF2" stroke-width="1.5"/>

            <text x="169" y="80" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#797979">問い合わせ推移（6ヶ月）</text>
            <line x1="169" y1="100" x2="360" y2="100" stroke="#EBEEF2" stroke-width="1" stroke-dasharray="4,4"/>
            <line x1="169" y1="140" x2="360" y2="140" stroke="#EBEEF2" stroke-width="1" stroke-dasharray="4,4"/>
            <line x1="169" y1="180" x2="360" y2="180" stroke="#EBEEF2" stroke-width="1" stroke-dasharray="4,4"/>
            <line x1="169" y1="220" x2="360" y2="220" stroke="#EBEEF2" stroke-width="1" stroke-dasharray="4,4"/>

            <path id="hero-area-fill" d="M178 232 C194 222,212 212,228 202 C244 191,262 184,278 166 C294 148,314 126,334 106 C344 96,352 89,356 84 L356 232 Z" fill="url(#h-area)"/>
            <path id="hero-chart-line" d="M178 232 C194 222,212 212,228 202 C244 191,262 184,278 166 C294 148,314 126,334 106 C344 96,352 89,356 84" stroke="#E43172" stroke-width="2.5" stroke-linecap="round" fill="none"/>

            <circle id="hero-pt-1" cx="178" cy="232" r="3.5" fill="white" stroke="#E43172" stroke-width="2"/>
            <circle id="hero-pt-2" cx="228" cy="202" r="3.5" fill="white" stroke="#E43172" stroke-width="2"/>
            <circle id="hero-pt-3" cx="278" cy="166" r="3.5" fill="white" stroke="#E43172" stroke-width="2"/>
            <circle id="hero-pt-4" cx="334" cy="106" r="3.5" fill="white" stroke="#E43172" stroke-width="2"/>
            <circle id="hero-pt-5" cx="356" cy="84"  r="5.5" fill="#E43172" stroke="white" stroke-width="2.5"/>

            <text x="178" y="248" text-anchor="middle" font-size="7.5" font-family="system-ui,-apple-system,sans-serif" fill="#797979">1月</text>
            <text x="228" y="248" text-anchor="middle" font-size="7.5" font-family="system-ui,-apple-system,sans-serif" fill="#797979">3月</text>
            <text x="278" y="248" text-anchor="middle" font-size="7.5" font-family="system-ui,-apple-system,sans-serif" fill="#797979">5月</text>
            <text x="334" y="248" text-anchor="middle" font-size="7.5" font-family="system-ui,-apple-system,sans-serif" fill="#797979">7月</text>

            <g id="hero-tooltip">
              <rect x="322" y="64" width="54" height="26" rx="8" fill="#103366"/>
              <polygon points="344,90 350,90 347,96" fill="#103366"/>
              <text x="349" y="77" text-anchor="middle" font-size="8.5" font-family="system-ui,-apple-system,sans-serif" fill="white" font-weight="700">8件/月</text>
              <text x="349" y="87" text-anchor="middle" font-size="7"   font-family="system-ui,-apple-system,sans-serif" fill="white" opacity="0.6">達成</text>
            </g>

            <g id="hero-notif">
              <rect x="268" y="278" width="204" height="72" rx="14" fill="white" filter="url(#h-notif)"/>
              <circle cx="290" cy="302" r="10" fill="#E43172" opacity="0.08"/>
              <circle cx="290" cy="302" r="8"  fill="none" stroke="#E43172" stroke-width="1" opacity="0.3"/>
              <circle cx="290" cy="302" r="5"  fill="#E43172"/>
              <text x="307" y="298" font-size="9" font-family="system-ui,-apple-system,sans-serif" fill="#103366" font-weight="700">新着お問い合わせ</text>
              <text x="307" y="313" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#797979">「サイト改善を相談したい」</text>
              <rect x="307" y="322" width="42" height="16" rx="8" fill="#E43172" opacity="0.1"/>
              <text x="328" y="334" text-anchor="middle" font-size="8" font-family="system-ui,-apple-system,sans-serif" fill="#E43172" font-weight="600">たった今</text>
            </g>
          </svg>
        </div>
      </div>

    </div>
  </div>

  <!-- ── サービス特徴バー ─────────────────────────────────── -->
  <div class="bg-navy" style="position:relative;z-index:10">
    <div class="mx-auto w-full max-w-content px-0 md:px-8">
      <ul class="grid grid-cols-2 md:grid-cols-4">
        {[
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1.5" y="3" width="15" height="13.5" rx="2.5"/><path d="M5.5 1.5v3M12.5 1.5v3M1.5 7.5h15"/><circle cx="5.5" cy="12" r="1" fill="white" stroke="none"/><circle cx="9" cy="12" r="1" fill="white" stroke="none"/><circle cx="12.5" cy="12" r="1" fill="white" stroke="none"/></svg>',
            title: '毎月サイトを改善',
            desc: '更新・導線改善・SEO対策を継続',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 1.5 L16 5.5 L16 12.5 L9 16.5 L2 12.5 L2 5.5 Z"/><circle cx="9" cy="9" r="2.5" fill="white" stroke="none"/></svg>',
            title: 'LINE・SNS・広告と連携',
            desc: '入口をサイトというゴールにつなぐ',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 14 6 8.5 9 11 14.5 4"/><polyline points="11 4 14.5 4 14.5 7.5"/></svg>',
            title: '問い合わせ・採用につなげる',
            desc: '成果まで責任を持って伴走',
          },
          {
            icon: '<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="7.5" r="5"/><line x1="11.2" y1="11.2" x2="16" y2="16"/><path d="M5.5 7.5h4M7.5 5.5v4"/></svg>',
            title: 'まずは無料Web診断',
            desc: '現状の課題を30分で整理',
          },
        ].map((f, i) => (
          <li class:list={[
            'flex items-center gap-2 px-4 py-3 md:gap-3 md:px-6 md:py-5',
            i < 2 && 'border-b border-white/15 md:border-b-0',
            (i === 1 || i === 3) && 'border-l border-white/15',
            i === 2 && 'md:border-l md:border-white/15',
          ]}>
            <span
              class="flex h-5 w-5 flex-shrink-0 items-center justify-center opacity-80 md:h-8 md:w-8"
              set:html={f.icon}
            />
            <div>
              <p class="text-[9px] font-bold leading-snug text-white md:text-[13px]">{f.title}</p>
              <p class="mt-0.5 hidden text-[10px] leading-snug text-white/45 md:block">{f.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  function initFlow(canvas) {
    if (canvas.dataset.flowInit) return;
    canvas.dataset.flowInit = "1";
    var ctx = canvas.getContext("2d");
    if (!ctx) return;
    var color = canvas.dataset.color || "16,51,102";
    var baseOpacity = parseFloat(canvas.dataset.opacity || "0.07");
    var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var w = 0, h = 0, t = 0, raf = null, particles = [];
    function build() {
      var mobile = w < 640;
      var density = mobile ? 16000 : 8500;
      var n = Math.max(8, Math.round((w * h) / density));
      particles = [];
      for (var i = 0; i < n; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          s: 0.18 + Math.random() * 0.4,
          r: 1.2 + Math.random() * 2.0
        });
      }
    }
    function resize() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      build();
    }
    function field(x, y) {
      return Math.sin(x * 0.006 + t * 0.01) * 0.6
           + Math.cos(y * 0.008 - t * 0.006) * 0.5;
    }
    function render() {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "rgba(" + color + "," + baseOpacity + ")";
      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        var a = field(p.x, p.y);
        if (!reduce) {
          p.x += Math.cos(a) * p.s + 0.22;
          p.y += Math.sin(a) * p.s;
        }
        if (p.x > w + 20) { p.x = -20; p.y = Math.random() * h; }
        if (p.y > h + 20) p.y = -20;
        if (p.y < -20) p.y = h + 20;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }
    function loop() { render(); t += 1; raf = requestAnimationFrame(loop); }
    function start() { if (!raf) loop(); }
    function stop() { if (raf) { cancelAnimationFrame(raf); raf = null; } }
    resize();
    window.addEventListener("resize", resize);
    if (reduce) { render(); return; }
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) start(); else stop();
    }, { threshold: 0 });
    io.observe(canvas);
    start();
  }
  function boot() {
    document.querySelectorAll("#flow-bg").forEach(function(c) { initFlow(c); });
  }
  if (document.readyState !== "loading") boot();
  else document.addEventListener("DOMContentLoaded", boot);
  document.addEventListener("astro:page-load", boot);
})();
</script>
