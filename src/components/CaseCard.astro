---
import type { Case } from '../lib/microcms';

interface Props {
  item: Case;
}
const { item } = Astro.props;

// トップアクセントライン（旧プラン名バッジは廃止済み）
const accentClass = 'bg-navy';
---

<a href={`/cases/${item.slug}/`} class="card group flex h-full flex-col overflow-hidden">

  <!-- プランカラーのトップアクセントライン -->
  <div class={`h-1 w-full flex-shrink-0 ${accentClass}`}></div>

  <!-- サムネイル / プレースホルダー -->
  <div class="aspect-[16/9] overflow-hidden flex-shrink-0">
    {item.thumbnail ? (
      <img
        src={`${item.thumbnail.url}?w=640&fit=crop`}
        alt={item.title}
        width="640"
        height="360"
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-end bg-gradient-to-br from-sky via-mist to-white p-5">
        <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-bold text-navy/50 backdrop-blur-sm">
          {item.industry ?? 'Case Study'}
        </span>
      </div>
    )}
  </div>

  <!-- テキストエリア -->
  <div class="flex flex-1 flex-col p-6">

    <!-- クライアント名 -->
    <div class="flex flex-wrap items-center gap-1.5">
      <span class="text-xs text-gray">{item.clientName}</span>
    </div>

    <!-- タイトル -->
    <h3 class="mt-3 text-base font-bold leading-snug text-navy transition-colors group-hover:text-pink">
      {item.title}
    </h3>

    <!-- スペーサー：タイトルの長短を吸収して metrics を下部に揃える -->
    <div class="flex-1"></div>

    <!-- Before → After メトリクス -->
    {item.metrics && item.metrics.length > 0 && (
      <dl class="mt-5 space-y-2.5 rounded-xl bg-mist px-4 py-3.5">
        {item.metrics.slice(0, 3).map((m) => (
          <div class="flex items-center justify-between gap-3 text-xs">
            <dt class="min-w-0 truncate text-gray/70">{m.label}</dt>
            <dd class="flex flex-shrink-0 items-center gap-1.5">
              <span class="text-gray/50">{m.before}</span>
              <svg class="h-3 w-3 flex-shrink-0 text-pink/50" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"/>
              </svg>
              <span class="font-bold text-pink">{m.after}</span>
            </dd>
          </div>
        ))}
      </dl>
    )}

    <!-- CTA リンク -->
    <div class="mt-5 flex items-center gap-1.5 text-sm font-bold text-pink">
      事例を見る
      <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
      </svg>
    </div>

  </div>
</a>
