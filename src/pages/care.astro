---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyAffordable from '../components/WhyAffordable.astro';
import TimeCompressSection from '../components/TimeCompressSection.astro';

// 毎月やること比較表（価格は指示書の仮確定値）
type Cell = string | boolean;
const compareRows: { label: string; light: Cell; standard: Cell }[] = [
  { label: 'サーバー・ドメイン・SSL管理', light: true, standard: true },
  { label: 'セキュリティ更新', light: true, standard: true },
  { label: 'テキスト・画像の修正', light: '月2回まで', standard: '回数無制限（1回30分目安）' },
  { label: '障害時の一次対応', light: true, standard: true },
  { label: '月次アクセスレポート', light: false, standard: true },
  { label: '改善提案', light: false, standard: '月1件' },
  { label: 'お知らせ・ブログ入稿代行', light: false, standard: true },
];

function cell(v: Cell): { label: string; positive: boolean } {
  if (v === true) return { label: '✓', positive: true };
  if (v === false) return { label: '—', positive: false };
  return { label: v, positive: true };
}

const faqs = [
  {
    q: '月2回の修正で足りますか？',
    a: '「営業時間の変更」「写真の差し替え」といった日常の更新であれば、月2回で足りるお客様がほとんどです。更新頻度が高い場合は、回数無制限の運用スタンダードをご検討ください。プラン変更は翌月からいつでも可能です。',
  },
  {
    q: '依頼はどうやってすればいいですか？',
    a: 'メールまたはSlackでご依頼ください。原則48時間以内に反映し、完了をご報告します。',
  },
  {
    q: '今のサーバーやドメインのまま契約できますか？',
    a: 'はい。現在の契約内容を確認した上で、そのまま管理を引き継ぐか、より安定した環境への移行をご提案します。',
  },
  {
    q: '解約したらサイトはどうなりますか？',
    a: '最低契約期間はなく、いつでも解約できます。解約時はサイト一式（データ・アカウント情報）をお渡ししますので、他社への引き継ぎも自由です。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Web運用（ホームページ運用代行）',
  provider: { '@id': 'https://plugdo.jp/#organization' },
  serviceType: 'ホームページ運用・保守',
  areaServed: { '@type': 'Country', name: 'Japan' },
  description:
    'サーバー管理から更新代行、月次の改善提案までのWeb運用。運用ライト月¥9,800・運用スタンダード月¥19,800（税込）。最低契約期間なし。',
  offers: [
    { '@type': 'Offer', name: '運用ライト', price: '9800', priceCurrency: 'JPY' },
    { '@type': 'Offer', name: '運用スタンダード', price: '19800', priceCurrency: 'JPY' },
  ],
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: 'Web運用', item: 'https://plugdo.jp/care/' },
  ],
};
---

<BaseLayout
  title="ホームページ運用代行 月¥9,800〜 | Plugdo"
  description="サーバー管理から更新代行、月次の改善提案まで。運用ライト月¥9,800・運用スタンダード月¥19,800（税込）。最低契約期間なし、いつでも解約できます。"
  jsonLd={[faqLd, serviceLd, breadcrumbLd]}
>
  <!-- Hero -->
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-24">
      <div class="max-w-2xl">
        <p class="section-label-left">- Care -</p>
        <h1 class="text-3xl font-black leading-snug text-navy md:text-4xl">
          月<span class="font-display [font-variant-numeric:tabular-nums]">¥9,800</span><span class="text-xl align-middle text-gray md:text-2xl">（税込）</span>からのWeb運用。<br />更新が、止まらない。
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-ink">
          サーバー管理から更新代行、月次の改善提案まで。最低契約期間なし、いつでも解約できます。
        </p>
        <div class="mt-8">
          <a href="/check/" class="btn-pink">無料で自社サイトを診断する（30秒）</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 毎月やること比較表 -->
  <section id="price">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Monthly Work -</p>
        <h2 class="section-title">毎月やること</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          2プランの違いは「どこまで任せるか」。含まれる作業を全項目表示しています。
        </p>
      </div>

      <div class="mx-auto mt-10 max-w-4xl overflow-x-auto">
        <table class="w-full min-w-[560px] border-collapse text-sm">
          <thead>
            <tr class="border-b-2 border-navy/10">
              <th class="w-[40%] pb-4 pr-4 text-left font-bold text-gray">内容</th>
              <th class="pb-4 text-center">
                <span class="block text-base font-bold text-navy">運用ライト</span>
                <span class="mt-1 block font-display text-lg text-navy [font-variant-numeric:tabular-nums]">¥9,800<span class="text-xs text-gray">/月</span></span>
              </th>
              <th class="pb-4 text-center">
                <span class="block text-base font-bold text-navy">運用スタンダード</span>
                <span class="mt-1 block font-display text-lg text-navy [font-variant-numeric:tabular-nums]">¥19,800<span class="text-xs text-gray">/月</span></span>
              </th>
            </tr>
          </thead>
          <tbody>
            {
              compareRows.map((row, i) => (
                <tr class:list={['border-b border-mist/60', i % 2 !== 0 ? 'bg-mist/30' : '']}>
                  <td class="py-3.5 pr-4 text-ink">{row.label}</td>
                  {[cell(row.light), cell(row.standard)].map((c) => (
                    <td class="py-3.5 text-center">
                      <span
                        class:list={[
                          'text-sm',
                          c.positive ? 'font-medium text-navy' : 'text-gray/40',
                          c.label === '✓' ? 'text-base font-bold' : '',
                        ]}
                      >
                        {c.label}
                      </span>
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
          <tfoot>
            <tr>
              <td class="pt-6 pr-4" />
              <td class="pt-6 text-center">
                <a href="/contact/" class="btn-navy !px-6 !py-2.5 text-xs">このプランを相談する</a>
              </td>
              <td class="pt-6 text-center">
                <a href="/contact/" class="btn-pink !px-6 !py-2.5 text-xs">このプランを相談する</a>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
      <p class="mt-6 text-center text-xs text-gray">価格は税込です。</p>
    </div>
  </section>

  <!-- 運用の型 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- How We Work -</p>
        <h2 class="section-title">運用の型</h2>
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-gray/10 bg-paper p-7">
          <h3 class="text-base font-bold text-navy">依頼から48時間以内に反映</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray">
            メールまたはSlackで依頼するだけ。見積もり・発注のやり取りなしで、原則48時間以内に修正を反映し、完了をご報告します。
          </p>
          <div class="mt-5 flex items-center gap-3 border-t border-mist pt-5 text-sm">
            <span class="rounded-full bg-mist px-3 py-1 text-xs font-bold text-navy">依頼</span>
            <span class="text-gray" aria-hidden="true">→</span>
            <span class="rounded-full bg-mist px-3 py-1 text-xs font-bold text-navy">反映</span>
            <span class="text-gray" aria-hidden="true">→</span>
            <span class="rounded-full bg-navy px-3 py-1 text-xs font-bold text-paper">報告</span>
          </div>
        </div>
        <div class="rounded-xl border border-gray/10 bg-paper p-7">
          <h3 class="text-base font-bold text-navy">月次レポートで状態を共有</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray">
            運用スタンダードでは、アクセス数・問い合わせ状況・今月の作業内容を1枚のレポートにまとめてお届けします。数字を見ながら、次に直す場所を決められます。
          </p>
          <!-- TODO: 月次レポートの実物サンプル画像が用意でき次第ここに差し込む（AI生成モックは使用しない） -->
          <ul class="mt-5 space-y-2 border-t border-mist pt-5">
            <li class="flex items-center justify-between text-xs"><span class="text-gray">アクセス数の推移</span><span class="font-bold text-navy">毎月</span></li>
            <li class="flex items-center justify-between text-xs"><span class="text-gray">問い合わせ状況</span><span class="font-bold text-navy">毎月</span></li>
            <li class="flex items-center justify-between text-xs"><span class="text-gray">作業内容と改善提案</span><span class="font-bold text-navy">毎月</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PDCA 時間圧縮 -->
  <TimeCompressSection />

  <!-- なぜこの価格でできるのか -->
  <WhyAffordable />

  <!-- 料金と解約条件 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-3xl text-center" data-animate="fade-in">
        <p class="section-label">- Terms -</p>
        <h2 class="section-title">最低契約期間はありません。</h2>
        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-ink md:text-base">
          いつでも解約できます。解約時はサイト一式をお渡しします。「囲い込まれない」ことも、サービスの一部だと考えています。
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- FAQ -</p>
        <h2 class="section-title">よくある質問</h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl space-y-4">
        {
          faqs.map((f) => (
            <details class="group rounded-xl border border-gray/10 bg-paper">
              <summary class="flex cursor-pointer list-none items-start gap-3 px-6 py-5">
                <span class="font-display text-base font-bold text-pink">Q</span>
                <span class="flex-1 text-sm font-bold leading-relaxed text-navy md:text-base">{f.q}</span>
                <span class="mt-1 text-gray transition-transform group-open:rotate-180" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="2 5 7 10 12 5" /></svg>
                </span>
              </summary>
              <div class="flex gap-3 border-t border-mist px-6 py-5">
                <span class="font-display text-base font-bold text-navy">A</span>
                <p class="flex-1 text-sm leading-relaxed text-ink">{f.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 最終診断CTA -->
  <section class="bg-navy">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-black leading-snug text-paper md:text-3xl">
          まず、いまのサイトが<br class="sm:hidden" />何点か知ることから。
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-white/80">
          URLを入れるだけ。30秒で現状を採点し、運用で伸ばせる状態かどうかが分かります。
        </p>
        <a href="/check/" class="btn-pink mt-7">無料で自社サイトを診断する（30秒）</a>
      </div>
    </div>
  </section>
</BaseLayout>
