---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: '無料Web診断', item: 'https://plugdo.jp/check/' },
  ],
};

// 副CTA「結果をメールで受け取る」の送信先（既存 contact と同じ Formspree を流用）。
const FORMSPREE_ENDPOINT =
  import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || 'https://formspree.io/f/mwvjwbll';

// 診断中に順番に点灯するチェック項目（7軸。専門用語は使わない）。
const checkSteps = [
  '第一印象をチェック中…',
  '何の会社か伝わるか確認中…',
  '問い合わせのしやすさを確認中…',
  'スマホ表示をチェック中…',
  '検索・AIに見つけてもらえるか確認中…',
  '実績・お客様の声を確認中…',
  'ページの表示速度をチェック中…',
];
---

<BaseLayout
  title="無料Web診断｜URLを入れるだけ、30秒で採点"
  description="ホームページのURLを入れるだけ。プロのWebデザイナーが設計した診断ロジックが、30秒で「問い合わせにつながる状態か」を5つの視点で採点します。中小企業の経営者向け、無料。"
  ogImage="/og-check.png"
  jsonLd={breadcrumbLd}
>
  <!-- ══ 画面① 入口（URL入力） ══ -->
  <section id="screen-input" class="hero-gradient">
    <div class="container-pd py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="section-label justify-center">- Web Check -</p>
        <h1 class="section-title mt-2">
          そのホームページ、<br class="md:hidden" />問い合わせに<br />つながっていますか？
        </h1>
        <p class="mt-6 text-base leading-relaxed text-ink md:text-lg">
          URLを入れるだけ。30秒で、プロの視点であなたのサイトを採点します。
        </p>

        <form id="check-form" class="mx-auto mt-8 max-w-xl">
          <div class="flex flex-col gap-3 sm:flex-row">
            <input
              id="url-input"
              type="text"
              inputmode="url"
              autocomplete="url"
              required
              placeholder="例：plugdo.jp"
              class="w-full flex-1 rounded-full border border-mist px-6 py-4 text-base shadow-sm focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/20"
            />
            <button type="submit" class="btn-pink shrink-0 whitespace-nowrap !px-8 !py-4">
              無料で診断する
            </button>
          </div>
          <p id="input-error" class="mt-3 hidden text-sm font-bold text-pink" role="alert"></p>
        </form>

        <p class="mt-6 text-xs text-gray">
          ＊ プロのWebデザイナーが設計した診断ロジック。入力されたURLは診断のみに利用します。
        </p>
      </div>
    </div>
  </section>

  <!-- ══ 画面② 診断中 ══ -->
  <section id="screen-loading" class="hidden">
    <div class="container-pd py-20 md:py-28">
      <div class="mx-auto max-w-md text-center">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.2em] text-pink">
          Analyzing
        </p>
        <p id="loading-url" class="mt-2 break-all text-sm text-gray"></p>
        <h2 class="mt-3 text-2xl font-black text-navy">プロの視点で診断しています</h2>

        <ul class="mx-auto mt-10 max-w-sm space-y-4 text-left">
          {
            checkSteps.map((step, i) => (
              <li
                class="check-step flex items-center gap-3 text-sm text-gray opacity-40 transition-all duration-500"
                data-step={i}
              >
                <span class="check-dot flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 border-mist">
                  <span class="check-spinner hidden h-3 w-3 animate-spin rounded-full border-2 border-pink border-t-transparent" />
                  <svg class="check-done hidden h-4 w-4 text-paper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </span>
                <span class="check-label font-bold">{step}</span>
              </li>
            ))
          }
        </ul>

        <!-- チェック完了後〜結果表示までの待ち時間を埋める -->
        <div id="analyze-finalizing" class="mt-9 hidden items-center justify-center gap-2.5 text-sm font-bold text-navy">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-pink border-t-transparent"></span>
          <span>結果をまとめています…</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 画面③ 結果 ══ -->
  <section id="screen-result" class="hidden">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-3xl">
        <p class="reveal text-center text-sm text-gray" data-reveal="0">
          診断結果：<span id="result-url" class="break-all font-bold text-navy"></span>
        </p>

        <!-- 総合スコア ゲージ -->
        <div class="reveal mt-6 text-center" data-reveal="1">
          <div class="relative mx-auto h-48 w-48">
            <svg class="h-full w-full -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#EBEEF2" stroke-width="12" />
              <circle
                id="gauge-arc"
                cx="60"
                cy="60"
                r="52"
                fill="none"
                stroke="#E43172"
                stroke-width="12"
                stroke-linecap="round"
                stroke-dasharray="326.7"
                stroke-dashoffset="326.7"
                style="transition: stroke-dashoffset 1.4s cubic-bezier(0.22,1,0.36,1);"
              />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span id="gauge-number" class="font-display text-5xl font-black text-navy">0</span>
              <span class="text-xs font-bold tracking-wider text-gray">/ 100点</span>
            </div>
          </div>
          <p id="band-message" class="mx-auto mt-5 max-w-md text-base font-bold leading-relaxed text-navy"></p>
        </div>

        <!-- 5軸スコア -->
        <div class="reveal mt-12" data-reveal="2">
          <h3 class="text-lg font-black text-navy">7つの視点で見ると</h3>
          <p class="mt-1.5 text-xs leading-relaxed text-gray">
            各項目は、あなたのサイトを実際にチェックした結果です（<span class="font-bold" style="color:#1F9D6B">✓</span>＝できている／<span class="font-bold text-pink">✕</span>＝もったいない）。
          </p>
          <div id="axes" class="mt-5 space-y-3"></div>
        </div>

        <!-- 気づき -->
        <div class="reveal mt-12" data-reveal="3">
          <h3 class="text-lg font-black text-navy">見つかった“もったいない”ポイント</h3>
          <ul id="findings" class="mt-5 space-y-3"></ul>
        </div>

        <!-- ゲート＋CTA（スコアで /renewal と /care に振り分け） -->
        <div class="reveal mt-12" data-reveal="4">
          <div class="card border-pink/30 bg-pink/5 p-7 text-center md:p-9">
            <p id="gate-headline" class="text-base font-bold leading-relaxed text-navy"></p>
            <p id="gate-desc" class="mt-3 text-sm leading-relaxed text-ink"></p>
            <a id="cta-primary" href="/renewal/" class="btn-pink mt-6 w-full sm:w-auto"></a>
            <div class="mt-4">
              <a id="cta-secondary" href="/contact/" class="text-sm font-bold text-navy underline underline-offset-4 hover:text-pink">
                この結果を持って30分相談する
              </a>
            </div>
            <p class="mt-4 text-xs text-gray">無料・オンライン30分・契約不要</p>
          </div>

          <!-- 副CTA：結果をメールで受け取る（リード取得→ナーチャリング）
               NOTE: 結果メールは自動送信ではなく、Formspree リードに担当者が手動返信する運用。
               TODO: 返信メールテンプレートの末尾に任意アンケート（Van Westendorp 価格調査）への
                     リンク枠を追加する。リンク先URLは未確定（kaishu-todo.md 参照）。 -->
          <div class="mt-6 rounded-xl border border-mist bg-paper p-6 text-center md:p-7">
            <p class="text-sm font-bold text-navy">今すぐ相談しなくても大丈夫です</p>
            <p class="mt-1.5 text-xs leading-relaxed text-gray">
              診断結果と「改善のヒント」を、メールでお届けします。
            </p>
            <form id="mail-form" action={FORMSPREE_ENDPOINT} method="POST" class="mx-auto mt-4 flex max-w-md flex-col gap-2 sm:flex-row">
              <!-- ハニーポット（スパム対策） -->
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
              <input
                id="mail-input"
                type="email"
                name="email"
                required
                placeholder="メールアドレス"
                class="w-full flex-1 rounded-full border border-mist px-5 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
              />
              <button type="submit" class="btn-outline shrink-0 !px-6 !py-3 text-sm">
                結果をメールで受け取る
              </button>
            </form>
            <p id="mail-done" class="mt-3 hidden text-sm font-bold leading-relaxed text-navy" role="status"></p>
            <p id="mail-error" class="mt-2 hidden text-xs text-pink" role="alert"></p>
          </div>

          <div class="mt-6 text-center">
            <button id="retry" class="text-sm font-bold text-navy underline underline-offset-4 hover:text-pink">
              別のサイトを診断する
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const screens = {
      input: $('screen-input'),
      loading: $('screen-loading'),
      result: $('screen-result'),
    };
    const show = (name) => {
      Object.entries(screens).forEach(([k, el]) => el.classList.toggle('hidden', k !== name));
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    const colorHex = { red: '#E43172', yellow: '#C8A951', green: '#1F9D6B' };
    let lastResult = null; // 副CTA（メール受取）に引き継ぐ最新の診断結果

    // ── 診断中アニメ：チェック項目を順に点灯 ──
    let stepTimers = [];
    function runLoadingAnimation() {
      const steps = Array.from(document.querySelectorAll('.check-step'));
      stepTimers.forEach(clearTimeout);
      stepTimers = [];
      const fin = $('analyze-finalizing');
      fin.classList.add('hidden');
      fin.classList.remove('flex');
      steps.forEach((el) => {
        el.classList.add('opacity-40');
        el.querySelector('.check-dot').classList.remove('bg-pink', 'border-pink');
        el.querySelector('.check-spinner').classList.add('hidden');
        el.querySelector('.check-done').classList.add('hidden');
      });
      // 全ステップ完了後、結果がまだなら「まとめています…」を表示
      stepTimers.push(
        setTimeout(() => {
          fin.classList.remove('hidden');
          fin.classList.add('flex');
        }, steps.length * 720 + 850)
      );
      steps.forEach((el, i) => {
        // 点灯（スピナー表示）
        stepTimers.push(
          setTimeout(() => {
            el.classList.remove('opacity-40');
            el.querySelector('.check-dot').classList.add('border-pink');
            el.querySelector('.check-spinner').classList.remove('hidden');
          }, i * 720 + 200)
        );
        // 完了（チェック表示）
        stepTimers.push(
          setTimeout(() => {
            const dot = el.querySelector('.check-dot');
            dot.classList.add('bg-pink');
            el.querySelector('.check-spinner').classList.add('hidden');
            el.querySelector('.check-done').classList.remove('hidden');
          }, i * 720 + 720)
        );
      });
    }

    // ── 結果レンダリング ──
    function renderResult(data) {
      lastResult = data;
      // 副CTA（メール受取）を初期状態に戻す（再診断時）
      $('mail-form').classList.remove('hidden');
      $('mail-form').reset();
      $('mail-done').classList.add('hidden');
      $('mail-error').classList.add('hidden');
      $('result-url').textContent = data.url;
      $('band-message').textContent = data.bandMessage;

      // ゲージ
      const circumference = 326.7;
      const arc = $('gauge-arc');
      arc.setAttribute('stroke', colorHex[data.total >= 75 ? 'green' : data.total >= 50 ? 'yellow' : 'red']);
      arc.style.strokeDashoffset = String(circumference);
      // 数字カウントアップ
      const numEl = $('gauge-number');
      let start = null;
      const duration = 1400;
      function tick(ts) {
        if (!start) start = ts;
        const p = Math.min((ts - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        numEl.textContent = String(Math.round(data.total * eased));
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(() => {
        arc.style.strokeDashoffset = String(circumference * (1 - data.total / 100));
        requestAnimationFrame(tick);
      });

      // 7軸カード
      const axesEl = $('axes');
      axesEl.innerHTML = '';
      const tint = { red: '#FCE9F0', yellow: '#F7F1DE', green: '#E4F3EC' };
      data.axes.forEach((ax, i) => {
        const row = document.createElement('div');
        row.className = 'rounded-xl border border-mist bg-paper p-4 md:p-5';
        const evHtml = (ax.evidence || [])
          .map(function (e) {
            const mark =
              '<span style="color:' + (e.ok ? '#1F9D6B' : '#E43172') + ';font-weight:700">' +
              (e.ok ? '✓' : '✕') + '</span>';
            const val = e.value ? ' <span class="text-gray/60">' + esc(e.value) + '</span>' : '';
            return (
              '<span class="inline-flex items-center gap-1 text-xs ' +
              (e.ok ? 'text-ink' : 'text-gray') + '">' + mark + esc(e.label) + val + '</span>'
            );
          })
          .join('');
        row.innerHTML =
          '<div class="flex items-center justify-between gap-3">' +
          '<span class="font-bold text-navy">' + ax.label + '</span>' +
          '<span class="inline-flex min-w-[2.6rem] justify-center rounded-full px-2.5 py-0.5 font-display text-sm font-bold" ' +
          'style="color:' + colorHex[ax.color] + ';background:' + tint[ax.color] + '">' + ax.score + '</span>' +
          '</div>' +
          '<div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-mist">' +
          '<div class="axis-bar h-full rounded-full" style="width:0%;background:' + colorHex[ax.color] + ';transition:width 1s cubic-bezier(0.22,1,0.36,1) ' + (0.3 + i * 0.1) + 's"></div>' +
          '</div>' +
          '<div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 border-t border-mist pt-3">' + evHtml + '</div>';
        axesEl.appendChild(row);
        requestAnimationFrame(() => {
          row.querySelector('.axis-bar').style.width = ax.score + '%';
        });
      });

      // 気づき（根拠つき）
      const fEl = $('findings');
      fEl.innerHTML = '';
      data.findings.forEach((f) => {
        // 後方互換：文字列でもオブジェクト{text,evidence}でも受ける
        const text = typeof f === 'string' ? f : f.text;
        const evidence = typeof f === 'string' ? '' : f.evidence;
        const li = document.createElement('li');
        li.className = 'flex gap-3 rounded-lg border border-mist bg-paper p-4 text-sm leading-relaxed text-ink';
        const ev = evidence
          ? '<span class="mt-1.5 block text-xs text-gray">根拠：' + esc(evidence) + '</span>'
          : '';
        li.innerHTML =
          '<span class="mt-0.5 shrink-0 text-pink">●</span><span>' + esc(text) + ev + '</span>';
        fEl.appendChild(li);
      });

      // ゲート出口：スコアで /renewal（<60）と /care（>=60）に振り分け
      const gh = $('gate-headline');
      const gd = $('gate-desc');
      const cta = $('cta-primary');
      if (data.total < 60) {
        gh.textContent = 'この課題は、更新では直りません。';
        gd.textContent = '減点の多くはサイトの土台（構造・スマホ対応・速度）にあります。作り直しの内容と料金をご確認ください。';
        cta.textContent = 'リニューアルの内容を見る';
        cta.href = '/renewal/';
      } else {
        gh.textContent = '土台は良好。運用で伸ばせます。';
        gd.textContent = '作り直しは不要です。月々の更新と改善で、いまのサイトを問い合わせが増える状態に育てられます。';
        cta.textContent = 'Web運用の内容を見る';
        cta.href = '/care/';
      }

      // 副CTA：スコア・URLを相談フォームに引き継ぐ
      const params = new URLSearchParams({ url: data.url, score: String(data.total) });
      $('cta-secondary').href = '/contact/?' + params.toString();

      // リビール（上から順に出す）
      document.querySelectorAll('.reveal').forEach((el) => {
        const delay = parseInt(el.dataset.reveal, 10) * 140;
        setTimeout(() => el.classList.add('is-in'), delay + 60);
      });
    }

    // ── 送信 ──
    const form = $('check-form');
    const errEl = $('input-error');
    let analyzeStart = 0;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.classList.add('hidden');
      const url = $('url-input').value.trim();
      if (!url) {
        errEl.textContent = 'URLを入力してください。';
        errEl.classList.remove('hidden');
        return;
      }

      $('loading-url').textContent = url;
      show('loading');
      runLoadingAnimation();
      analyzeStart = Date.now();

      try {
        const res = await fetch('/api/check', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ url }),
        });
        const data = await res.json();

        // 演出を最低限見せる（7ステップ完了まで＝約5.2秒）。
        const wait = Math.max(0, 5200 - (Date.now() - analyzeStart));
        setTimeout(() => {
          if (!res.ok) {
            errEl.textContent = data.error || '診断に失敗しました。時間をおいて再度お試しください。';
            errEl.classList.remove('hidden');
            show('input');
            return;
          }
          renderResult(data);
          show('result');
        }, wait);
      } catch {
        const wait = Math.max(0, 1500 - (Date.now() - analyzeStart));
        setTimeout(() => {
          errEl.textContent = 'サイトを読み込めませんでした。URLをご確認ください。';
          errEl.classList.remove('hidden');
          show('input');
        }, wait);
      }
    });

    $('retry').addEventListener('click', () => {
      $('url-input').value = '';
      show('input');
    });

    // ── 副CTA：結果をメールで受け取る（Formspreeでリード取得）──
    const mailForm = $('mail-form');
    mailForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errP = $('mail-error');
      errP.classList.add('hidden');
      const email = $('mail-input').value.trim();
      if (!email) return;

      const fd = new FormData(mailForm); // email と _gotcha を含む
      fd.append('種別', 'Web診断 結果メール希望');
      fd.append('_subject', '【plugdo】Web診断 結果メールのご希望');
      if (lastResult) {
        fd.append('診断URL', lastResult.url);
        fd.append('総合スコア', String(lastResult.total) + '点');
      }
      try {
        const res = await fetch(mailForm.action, {
          method: 'POST',
          body: fd,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          mailForm.classList.add('hidden');
          const done = $('mail-done');
          done.textContent =
            'ありがとうございます。担当者より、診断結果と改善のヒントをメールでお送りします。';
          done.classList.remove('hidden');
        } else {
          errP.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
          errP.classList.remove('hidden');
        }
      } catch {
        errP.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
        errP.classList.remove('hidden');
      }
    });
  })();
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.is-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
