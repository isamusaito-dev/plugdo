---
import BaseLayout from '../layouts/BaseLayout.astro';
import PriceTable from '../components/PriceTable.astro';
import CTASection from '../components/CTASection.astro';

const faqs = [
  {
    q: '契約期間はありますか？',
    a: '最低利用期間は3ヶ月です。サイトの改善は数ヶ月単位で効果が現れるため、一定期間の継続をお願いしています。',
  },
  {
    q: '解約はいつでもできますか？',
    a: '最低利用期間（3ヶ月）以降は、当月末締めでいつでも解約いただけます。違約金などは発生しません。',
  },
  {
    q: 'プランの途中変更はできますか？',
    a: 'はい。事業の状況に合わせて、翌月から上位・下位プランへ変更いただけます。まずはKeepから始めて、必要に応じてGrow・Partnerへ広げる方が多いです。',
  },
  {
    q: '料金以外に初期費用はかかりますか？',
    a: '運用プランには初期費用はかかりません。サイトの新規制作や大規模なリニューアルが必要な場合のみ、別途お見積もりとなります。',
  },
  {
    q: '表示価格以外の費用は？',
    a: '掲載の月額は税別の最低金額です。サイトの規模や対応範囲により変動するため、無料診断時に正確な金額をご提示します。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: '料金', item: 'https://plugdo.jp/price/' },
  ],
};
---

<BaseLayout
  title="料金プラン｜月額3万円〜の社外Web担当サービス｜Plugdo"
  description="Plugdoの料金プラン。Keep月額3万円〜、Grow月額8万円〜、Partner月額15万円〜。ホームページ改善、SEO/AIO対応、月次改善レポートを月額制で提供します。"
  jsonLd={[faqLd, breadcrumbLd]}
>
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-20">
      <p class="section-label-left">- Price -</p>
      <h1 class="text-3xl font-black text-navy md:text-4xl">料金プラン</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink">
        プランの差は「作業量」ではなく、<strong class="font-bold text-navy">何にコミットするか</strong>で決まります。上に行くほど成果への責任が増す3段階。共通の役割は「デザインに強い、社外のWeb担当」です。
      </p>
    </div>
  </section>

  <section>
    <div class="container-pd py-16 md:py-20">
      <PriceTable variant="full" />
      <p class="mt-8 text-center text-xs text-gray">
        ※ 表示は税別の最低月額です。サイト規模・対応範囲により変動します。正確な金額は無料診断時にご提示します。
      </p>
    </div>
  </section>

  <!-- 月次対応例 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Monthly -</p>
        <h2 class="section-title">月に何をするか。</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          「任せっきりで何をされているかわからない」にならないよう、毎月の動きを明示します。
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <!-- Keep -->
        <div class="rounded-2xl border border-navy/8 bg-white p-7" data-animate>
          <div class="mb-5 flex items-center justify-between">
            <h3 class="text-lg font-black text-navy">Keep</h3>
            <span class="rounded-full bg-navy/8 px-3 py-1 text-xs font-bold text-navy/60">¥30,000〜/月</span>
          </div>
          <ol class="space-y-4">
            {[
              { step: '月初', label: 'ヒアリング', text: '更新・修正の依頼をSlackで受け付け。優先順位を整理します。' },
              { step: '月中', label: '更新作業', text: 'テキスト修正・画像差し替えなどの更新を実施。表示・動作チェックも行います。' },
              { step: '月末', label: 'レポート', text: '簡易アクセスレポートを送付。前月比でサイトの状態を確認します。' },
            ].map((item) => (
              <li class="flex gap-4">
                <div class="flex flex-col items-center">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-navy/8 text-[10px] font-bold text-navy">{item.step[0]}</span>
                  <div class="mt-1 h-full w-px bg-navy/8"></div>
                </div>
                <div class="pb-4">
                  <p class="text-[10px] font-bold uppercase tracking-wider text-gray/60">{item.step}</p>
                  <p class="mt-0.5 text-sm font-bold text-navy">{item.label}</p>
                  <p class="mt-1 text-xs leading-relaxed text-ink/60">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <!-- Grow -->
        <div class="rounded-2xl border-2 border-pink bg-white p-7 shadow-[0_4px_32px_rgba(228,49,114,0.10)]" data-animate>
          <div class="mb-5 flex items-center justify-between">
            <h3 class="text-lg font-black text-navy">Grow</h3>
            <span class="rounded-full bg-pink/10 px-3 py-1 text-xs font-bold text-pink">¥80,000〜/月</span>
          </div>
          <ol class="space-y-4">
            {[
              { step: '月初', label: '改善提案レポート', text: 'アクセスデータを分析し「今月直すべき箇所」を優先度つきでまとめて送付します。' },
              { step: '月中前半', label: '改善実装', text: 'デザイン・導線・コンテンツの改善を実施。AIO対応（構造化データ・FAQの整備）も継続します。' },
              { step: '月中後半', label: 'AIO対応', text: 'JSON-LD・メタ情報・HTML構造を見直し、AI検索に引用されやすい状態を維持します。' },
              { step: '月末', label: 'MTG・翌月計画', text: 'オンラインMTGで成果を確認し、翌月の改善計画を共有します。' },
            ].map((item) => (
              <li class="flex gap-4">
                <div class="flex flex-col items-center">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-pink/15 text-[10px] font-bold text-pink">{item.step[0]}</span>
                  <div class="mt-1 h-full w-px bg-pink/15"></div>
                </div>
                <div class="pb-4">
                  <p class="text-[10px] font-bold uppercase tracking-wider text-pink/60">{item.step}</p>
                  <p class="mt-0.5 text-sm font-bold text-navy">{item.label}</p>
                  <p class="mt-1 text-xs leading-relaxed text-ink/60">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <!-- Partner -->
        <div class="rounded-2xl border border-navy/8 bg-white p-7" data-animate>
          <div class="mb-5 flex items-center justify-between">
            <h3 class="text-lg font-black text-navy">Partner</h3>
            <span class="rounded-full bg-navy/8 px-3 py-1 text-xs font-bold text-navy/60">¥150,000〜/月</span>
          </div>
          <ol class="space-y-4">
            {[
              { step: '月初', label: '戦略レビュー', text: '共同目標の進捗を確認し、今月の優先アクションを決定します。隔週MTGの1回目。' },
              { step: '月中前半', label: 'デザイン・改善実装', text: 'サイト全体のデザイン改善・採用ページ対応・AIO本格対応を並行して実施します。' },
              { step: '月中後半', label: 'MTG・軌道修正', text: '隔週MTGの2回目。数値確認と残タスクの調整を行い、月末に向けて動きます。' },
              { step: '月末', label: 'レポート・翌月計画', text: '成果レポートと翌月の数値目標・アクション計画を共有します。' },
            ].map((item) => (
              <li class="flex gap-4">
                <div class="flex flex-col items-center">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-navy/8 text-[10px] font-bold text-navy">{item.step[0]}</span>
                  <div class="mt-1 h-full w-px bg-navy/8"></div>
                </div>
                <div class="pb-4">
                  <p class="text-[10px] font-bold uppercase tracking-wider text-gray/60">{item.step}</p>
                  <p class="mt-0.5 text-sm font-bold text-navy">{item.label}</p>
                  <p class="mt-1 text-xs leading-relaxed text-ink/60">{item.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">- FAQ -</p>
        <h2 class="section-title">よくあるご質問</h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl space-y-4">
        {
          faqs.map((f) => (
            <details class="card group p-6 [&_summary]:cursor-pointer">
              <summary class="flex items-center justify-between gap-4 list-none font-bold text-navy">
                <span>{f.q}</span>
                <span class="text-pink transition-transform group-open:rotate-45" aria-hidden="true">
                  ＋
                </span>
              </summary>
              <p class="mt-4 text-sm leading-relaxed text-ink">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
