---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getCases } from '../../lib/microcms';
import { sampleCases } from '../../lib/sampleData';

const res = await getCases();
const cases = res.contents.length ? res.contents : sampleCases;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: '導入事例', item: 'https://plugdo.jp/cases' },
  ],
};
---

<BaseLayout
  title="導入事例"
  description="plugdoの導入事例。更新の止まったサイトを問い合わせ源に変えた中小企業の事例を、課題・施策・成果（数字）とともにご紹介します。"
  jsonLd={breadcrumbLd}
>
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-20">
      <p class="section-label">- Works -</p>
      <h1 class="text-3xl font-black text-navy md:text-4xl">導入事例</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink">
        plugdoで「作ったきり」を脱却した企業の事例です。課題・施策・成果を具体的にご紹介します。
      </p>
    </div>
  </section>

  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="grid gap-6 md:grid-cols-3">
        {cases.map((item) => <CaseCard item={item} />)}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
