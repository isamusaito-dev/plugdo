---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getCases } from '../../lib/microcms';
import { sampleCases } from '../../lib/sampleData';

const res = await getCases();
const cases = res.contents.length ? res.contents : sampleCases;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: '導入事例', item: 'https://plugdo.jp/cases/' },
  ],
};
---

<BaseLayout
  title="導入事例"
  description="plugdoの導入事例。更新の止まったサイトを問い合わせ源に変えた中小企業の事例を、課題・施策・成果（数字）とともにご紹介します。"
  jsonLd={breadcrumbLd}
  noindex={true}
>
  <!-- ページヘッダー -->
  <section class="hero-gradient border-b border-navy/6">
    <div class="container-pd py-16 md:py-20">
      <p class="section-label">Works</p>
      <h1 class="mt-2 text-3xl font-black text-navy md:text-4xl">導入事例</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink/70">
        「作ったきり」を脱却し、サイトを問い合わせ・採用の武器に変えた企業の事例です。<br class="hidden md:inline" />
        課題・施策・成果を数字とともにご紹介します。
      </p>
    </div>
  </section>

  <!-- 事例一覧 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="grid gap-6 md:grid-cols-3 md:items-stretch">
        {cases.map((item, i) => (
          <div class="h-full" data-animate data-animate-delay={String(i * 80)}>
            <CaseCard item={item} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
