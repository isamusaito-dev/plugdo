---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getBlogs, type Blog } from '../../lib/microcms';
import { sampleBlogs } from '../../lib/sampleData';

export async function getStaticPaths() {
  const res = await getBlogs();
  const valid = res.contents.filter((p) => p.slug);
  const blogs = valid.length ? valid : sampleBlogs;
  return blogs.map((post) => ({
    params: { slug: post.slug },
    props: { post, all: blogs },
  }));
}

interface Props {
  post: Blog;
  all: Blog[];
}
const { post, all }: Props = Astro.props;

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://plugdo.jp';

const date = new Date(post.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// --- 本文に見出しID付与 + 目次抽出 ---
type Heading = { level: 2 | 3; text: string; id: string };
const headings: Heading[] = [];
let counter = 0;
const bodyWithIds = post.body.replace(
  /<h([23])>(.*?)<\/h\1>/g,
  (_m, level: string, text: string) => {
    const id = `heading-${counter++}`;
    const plain = text.replace(/<[^>]+>/g, '');
    headings.push({ level: Number(level) as 2 | 3, text: plain, id });
    return `<h${level} id="${id}">${text}</h${level}>`;
  }
);

// --- h2 に連番を付与 ---
let h2n = 0;
const numberedHeadings = headings.map(h => ({
  ...h,
  num: h.level === 2 ? ++h2n : null,
}));

// --- 関連記事（同カテゴリ優先、最大3件） ---
const related = all
  .filter((p) => p.id !== post.id)
  .sort((a, b) => {
    const sameA = a.category?.id === post.category?.id ? 0 : 1;
    const sameB = b.category?.id === post.category?.id ? 0 : 1;
    return sameA - sameB;
  })
  .slice(0, 3);

// --- Article 構造化データ ---
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.publishedAt,
  dateModified: post.revisedAt || post.publishedAt,
  ...(post.eyecatch ? { image: post.eyecatch.url } : {}),
  ...(post.category ? { articleSection: post.category.name } : {}),
  inLanguage: 'ja-JP',
  author: { '@id': `${SITE_URL}/#founder` },
  publisher: { '@id': `${SITE_URL}/#organization` },
  isPartOf: { '@id': `${SITE_URL}/#website` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/blog/${post.slug}/` },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'ブログ', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.title, item: `${SITE_URL}/blog/${post.slug}/` },
  ],
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  ogType="article"
  ogImage={post.eyecatch?.url}
  publishedTime={post.publishedAt}
  modifiedTime={post.revisedAt || post.publishedAt}
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article>
    <!-- 記事ヘッダー（パンくず・カテゴリ・日付のみ） -->
    <header class="hero-gradient">
      <div class="container-pd pb-0 pt-14 md:pt-16">
        <nav class="mb-5 text-xs text-gray" aria-label="パンくず">
          <a href="/" class="hover:text-pink">ホーム</a>
          <span class="mx-1.5">/</span>
          <a href="/blog/" class="hover:text-pink">ブログ</a>
        </nav>
        <div class="flex items-center gap-2 text-xs">
          {
            post.category && (
              <span class="rounded-full bg-pink/10 px-2.5 py-1 font-bold text-pink">
                {post.category.name}
              </span>
            )
          }
          <time datetime={post.publishedAt} class="text-gray">{date}</time>
          <span class="text-gray/40">·</span>
          <span class="text-gray">齋藤 勇</span>
        </div>
      </div>
    </header>

    <div class="container-pd py-12 md:py-16">
      <div class="grid gap-12 lg:grid-cols-[1fr_260px]">
        <!-- 左カラム：アイキャッチ → 本文 -->
        <div>
          {post.eyecatch && (
            <div class="mb-10 overflow-hidden rounded-2xl shadow-[0_4px_24px_rgba(16,51,102,0.10)]">
              <img
                src={post.eyecatch.url}
                alt={post.title}
                width={post.eyecatch.width}
                height={post.eyecatch.height}
                class="w-full"
                loading="eager"
              />
            </div>
          )}
          <div class="prose-pd max-w-none" set:html={bodyWithIds} />
        </div>

        <!-- 右カラム：見出し → 目次（スティッキー） -->
        <aside class="lg:sticky lg:top-24 lg:self-start">
          <h1 class="mb-6 text-xl font-black leading-snug text-navy">
            {post.title}
          </h1>
          {
            numberedHeadings.length > 0 && (
              <div class="overflow-hidden rounded-2xl border border-gray/10 bg-white shadow-sm">
                {/* ヘッダー */}
                <div class="border-b border-gray/8 px-5 py-3.5">
                  <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-pink">Contents</p>
                  <p class="mt-0.5 text-sm font-bold text-navy">この記事でわかること</p>
                </div>
                {/* 目次リスト */}
                <nav class="p-4" aria-label="目次">
                  <ul class="space-y-0.5">
                    {numberedHeadings.map((h) => (
                      <li class:list={[h.level === 3 && 'ml-7 border-l-2 border-gray/10 pl-3']}>
                        <a
                          href={`#${h.id}`}
                          class:list={[
                            'flex items-start gap-2.5 rounded-lg py-1.5 leading-snug transition-colors hover:text-pink',
                            h.level === 2 ? 'text-sm text-ink' : 'text-xs text-gray py-1',
                          ]}
                        >
                          {h.level === 2 && (
                            <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-pink/10 text-[10px] font-black text-pink">
                              {h.num}
                            </span>
                          )}
                          <span>{h.text}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            )
          }
        </aside>
      </div>
    </div>

    <!-- 関連記事 -->
    {
      related.length > 0 && (
        <section class="bg-mist">
          <div class="container-pd py-16">
            <h2 class="section-title text-center">関連記事</h2>
            <div class="mt-10 grid gap-6 md:grid-cols-3">
              {related.map((item) => <BlogCard item={item} />)}
            </div>
          </div>
        </section>
      )
    }
  </article>

  <CTASection />
</BaseLayout>
