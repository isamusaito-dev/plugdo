---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyAffordable from '../components/WhyAffordable.astro';

// 対象となるサイト（診断の減点パターンに対応）
const targets = [
  {
    title: 'スマホで崩れる・文字が小さい',
    desc: 'アクセスの過半はスマホから。表示が崩れているだけで、問い合わせの機会を失っています。',
  },
  {
    title: '表示に3秒以上かかる',
    desc: '表示が遅いサイトは読まれる前に閉じられ、検索評価も下がります。',
  },
  {
    title: '情報が数年前のまま',
    desc: '営業時間・料金・実績が古いままだと、見た人の信頼を静かに損ないます。',
  },
  {
    title: 'AI検索（ChatGPT等）に内容を読まれない構造',
    desc: 'AIが読み取れない作りのサイトは、AI検索の回答に引用されず、新しい入口を逃します。',
  },
  {
    title: '問い合わせフォーム・電話番号が見つけにくい',
    desc: '連絡先までの導線が分かりにくいと、興味を持った人がそこで離れてしまいます。',
  },
  {
    title: 'お客様の声・実績が載っていない',
    desc: '第三者の評価がないと、初めての人は「本当に大丈夫か」と不安になります。',
  },
  {
    title: '会社概要・所在地が曖昧',
    desc: '運営者情報がはっきりしないサイトは、それだけで信頼を得にくくなります。',
  },
  {
    title: '何のサービスか一目で伝わらない',
    desc: 'トップページの数秒で「誰向けの何のサイトか」が伝わらないと、そのまま離脱されます。',
  },
];

// 料金プラン
const plans = [
  {
    name: 'ライト',
    priceAmount: '198,000',
    priceNote: '税込',
    period: '2〜3週間',
    items: ['5ページ構成', 'スマホ対応', '基本SEO', 'お問い合わせフォーム', '公開作業'],
  },
  {
    name: 'スタンダード',
    priceAmount: '298,000',
    priceNote: '税込',
    period: '4〜6週間',
    items: ['10ページ構成', 'オリジナルデザイン', 'CMS導入（自社更新可）', '構造化データ・AI検索対応', '公開作業'],
  },
];

// オプション（基本プランに含まれない追加対応）
const options = [
  { label: 'ページ追加', price: '¥15,000', note: '/ページ（税込）' },
  { label: '予約システム連携（外部ツール導入）', price: 'お見積り' },
  { label: 'ECサイト機能（オンライン販売）', price: 'お見積り' },
  { label: '会員・マイページ機能', price: 'お見積り' },
  { label: 'LINE公式アカウント連携・導線設計', price: 'お見積り' },
  { label: '多言語対応（英語・中国語など）', price: 'お見積り' },
  { label: 'ロゴ・ブランドデザイン制作', price: 'お見積り' },
  { label: 'デザインシステム構築（コンポーネント・ガイドライン整備）', price: 'お見積り' },
  { label: '写真・動画撮影', price: 'お見積り' },
  { label: '独自ドメイン取得・移管代行', price: 'お見積り' },
];

// 制作の流れ
const steps = [
  { no: '1', title: '診断', desc: '無料のAI診断で現状を採点。課題を数字で確認します。' },
  { no: '2', title: '設計', desc: '診断結果をもとに、必要なページ構成と直す範囲を決めます。' },
  { no: '3', title: '制作', desc: '制作中は週次で進捗を共有。認識のズレをなくします。' },
  { no: '4', title: '公開', desc: 'ドメイン・サーバー設定まで含めて公開作業を行います。' },
];

const faqs = [
  {
    q: '今の制作会社との契約はどうなりますか？',
    a: '現在のサーバー・ドメインの契約状況を確認した上で、移管や引き継ぎの段取りをこちらで整理します。現契約の解約手続きはお客様に行っていただきますが、必要な情報はすべてお渡しします。',
  },
  {
    q: '元のサイトの写真や文章は使えますか？',
    a: 'はい。使える素材は流用し、足りない部分のみ新規で用意します。文章のリライトは制作範囲に含まれます。',
  },
  {
    q: '公開までどのくらいかかりますか？',
    a: 'ライトプランで2〜3週間、スタンダードプランで4〜6週間が目安です。素材のご用意状況により前後します。',
  },
  {
    q: '補助金は使えますか？',
    a: '小規模事業者持続化補助金の対象となる場合、実質負担を約1/3に抑えられる可能性があります。申請可否は公募要領によりますので、無料相談時に状況を確認します。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ホームページリニューアル',
  provider: { '@id': 'https://plugdo.jp/#organization' },
  serviceType: 'Webサイト制作・リニューアル',
  areaServed: { '@type': 'Country', name: 'Japan' },
  description:
    '無料のAI診断で現状を採点してから、必要な分だけ作り直すホームページリニューアル。ライト¥198,000（税込）・スタンダード¥298,000（税込）。',
  offers: [
    { '@type': 'Offer', name: 'ライト', price: '198000', priceCurrency: 'JPY' },
    { '@type': 'Offer', name: 'スタンダード', price: '298000', priceCurrency: 'JPY' },
  ],
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: 'リニューアル', item: 'https://plugdo.jp/renewal/' },
  ],
};
---

<BaseLayout
  title="ホームページリニューアル ¥198,000〜 | Plugdo"
  description="無料のAI診断で現状を採点してから、必要な分だけ作り直す。ライト¥198,000・スタンダード¥298,000（税込）。補助金対象なら実質負担は約1/3。全国対応。"
  jsonLd={[faqLd, serviceLd, breadcrumbLd]}
>
  <!-- Hero -->
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-24">
      <div class="max-w-2xl">
        <p class="section-label-left">- Renewal -</p>
        <h1 class="text-3xl font-black leading-snug text-navy md:text-4xl">
          ホームページのリニューアル<br />
          <span class="font-display [font-variant-numeric:tabular-nums]">¥198,000</span><span class="text-xl align-middle text-gray md:text-2xl">（税込）</span>から。
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-ink">
          無料のAI診断で現状を採点してから、必要な分だけ作り直す。補助金対象なら実質負担は約1/3。
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-5">
          <a href="/check/" class="btn-pink">無料で自社サイトを診断する（30秒）</a>
          <a href="#price" class="text-sm font-bold text-navy underline underline-offset-4 hover:text-pink">
            料金の内訳を見る
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 対象となるサイト -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- For These Sites -</p>
        <h2 class="section-title">こんなサイトが対象です</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          無料診断で減点が集中しやすい、代表的なパターンです。
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-x-10 gap-y-8 md:grid-cols-2">
        {
          targets.map((t) => (
            <div class="border-t border-navy/10 pt-5">
              <h3 class="text-base font-bold text-navy">{t.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">{t.desc}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-12 text-center" data-animate="fade-in">
        <a href="/check/" class="btn-pink">無料で自社サイトを診断する（30秒）</a>
        <p class="mt-3 text-xs text-gray">URLを入れるだけ・30秒／自分のサイトが何個当てはまるか確認できます</p>
      </div>
    </div>
  </section>

  <!-- 料金 -->
  <section id="price" class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Price -</p>
        <h2 class="section-title">料金</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          含まれるものを全項目表示しています。追加費用が出にくい、定額のパッケージです。
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-4xl gap-6 md:grid-cols-2">
        {
          plans.map((plan) => (
            <div class="card flex flex-col p-7">
              <div class="flex items-start justify-between gap-3">
                <span class="text-lg font-bold text-navy">{plan.name}</span>
                <span class="rounded-full bg-mist px-3 py-1 text-xs font-bold text-gray">納期目安 {plan.period}</span>
              </div>
              <div class="mt-4 flex items-end gap-0.5">
                <span class="mb-1.5 font-display text-xl font-bold text-navy">¥</span>
                <span class="font-display text-[2.75rem] font-black leading-none text-navy [font-variant-numeric:tabular-nums]">{plan.priceAmount}</span>
                <span class="mb-2 ml-1 text-xs text-gray">（{plan.priceNote}）</span>
              </div>
              <ul class="mt-6 flex-1 space-y-2.5 border-t border-mist pt-5">
                {plan.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-ink">
                    <span class="mt-0.5 font-bold text-navy" aria-hidden="true">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a href="/check/" class="btn-navy mt-7 w-full text-sm">まず無料診断から始める</a>
            </div>
          ))
        }
      </div>

      <div class="mx-auto mt-8 max-w-4xl">
        <p class="text-center text-xs text-gray">
          大規模システム開発 / ECサイト構築 / 広告運用は対象外です。
        </p>

        <!-- オプション -->
        <div class="mt-8 overflow-hidden rounded-xl border border-gray/10 bg-paper">
          <p class="border-b border-mist px-6 py-3 text-xs font-bold uppercase tracking-widest text-gray">オプション</p>
          <table class="w-full text-sm">
            <tbody>
              {
                options.map((o, i) => (
                  <tr class:list={[i !== options.length - 1 && 'border-b border-mist/60']}>
                    <td class="px-6 py-3.5 text-ink">{o.label}</td>
                    <td class="px-6 py-3.5 text-right font-display text-navy [font-variant-numeric:tabular-nums]">
                      {o.price}
                      {o.note && <span class="ml-1 text-xs text-gray">{o.note}</span>}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-center text-xs text-gray">
          上記以外のご要望も、まずはご相談ください。
        </p>
      </div>
    </div>
  </section>

  <!-- 制作の流れ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Process -</p>
        <h2 class="section-title">制作の流れ</h2>
      </div>
      <ol class="mx-auto mt-10 grid max-w-4xl gap-6 md:grid-cols-4">
        {
          steps.map((s) => (
            <li class="border-t-2 border-navy pt-4">
              <p class="text-xs font-bold text-gray">STEP {s.no}</p>
              <h3 class="mt-1 text-base font-bold text-navy">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">{s.desc}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- なぜこの価格でできるのか -->
  <WhyAffordable />

  <!-- 補助金の案内 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-3xl">
        <div class="text-center" data-animate="fade-in">
          <p class="section-label">- Subsidy -</p>
          <h2 class="section-title">補助金を使うと、実質負担は約1/3。</h2>
        </div>
        <div class="mt-8 rounded-xl border border-gray/10 bg-paper p-7 md:p-9">
          <p class="text-sm leading-relaxed text-ink">
            小規模事業者持続化補助金の対象になる場合、スタンダードプラン（<span class="font-display font-bold [font-variant-numeric:tabular-nums]">¥298,000</span>・税込）の実質負担は約<span class="font-display font-bold text-navy [font-variant-numeric:tabular-nums]">¥99,000</span>まで抑えられる試算です。対象になるかどうか・申請の段取りは、無料相談時にあわせてご案内します。
          </p>
          <p class="mt-4 border-t border-mist pt-4 text-xs text-gray">
            ※ 試算は補助率2/3の場合の一例です。申請可否は公募要領によります。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 公開後は運用へ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-3xl text-center" data-animate="fade-in">
        <p class="section-label">- After Launch -</p>
        <h2 class="section-title">公開して、終わりにしない。</h2>
        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-ink md:text-base">
          作り直したサイトは、月々の運用で育てていけます。リニューアルをご契約の方は、運用ライトが3ヶ月無料。
        </p>
        <a href="/care/" class="btn-outline mt-7">Web運用の内容を見る</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- FAQ -</p>
        <h2 class="section-title">よくある質問</h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl space-y-4">
        {
          faqs.map((f) => (
            <details class="group rounded-xl border border-gray/10 bg-paper">
              <summary class="flex cursor-pointer list-none items-start gap-3 px-6 py-5">
                <span class="font-display text-base font-bold text-pink">Q</span>
                <span class="flex-1 text-sm font-bold leading-relaxed text-navy md:text-base">{f.q}</span>
                <span class="mt-1 text-gray transition-transform group-open:rotate-180" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="2 5 7 10 12 5" /></svg>
                </span>
              </summary>
              <div class="flex gap-3 border-t border-mist px-6 py-5">
                <span class="font-display text-base font-bold text-navy">A</span>
                <p class="flex-1 text-sm leading-relaxed text-ink">{f.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 最終診断CTA -->
  <section class="bg-navy">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-black leading-snug text-paper md:text-3xl">
          まず、いまのサイトが<br class="sm:hidden" />何点か知ることから。
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-white/80">
          URLを入れるだけ。30秒で現状を採点し、リニューアルが必要かどうかが分かります。
        </p>
        <a href="/check/" class="btn-pink mt-7">無料で自社サイトを診断する（30秒）</a>
      </div>
    </div>
  </section>
</BaseLayout>
