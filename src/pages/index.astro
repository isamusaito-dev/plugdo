---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PriceTable from '../components/PriceTable.astro';
import CaseCard from '../components/CaseCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import { getCases, getBlogs } from '../lib/microcms';
import { sampleCases, sampleBlogs } from '../lib/sampleData';

// 事例・ブログを取得（未接続時はサンプルにフォールバック）
const casesRes = await getCases({ limit: 3 });
const cases = casesRes.contents.length ? casesRes.contents : sampleCases;

const blogsRes = await getBlogs({ limit: 3 });
const blogs = blogsRes.contents.length ? blogsRes.contents : sampleBlogs.slice(0, 3);

// 出典つきの定量データ（裏付け）。数字は一次ソースで検証済み。出典は脚注で控えめに掲載。
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';

const problems = [
  {
    title: '更新できていない',
    text: '公開したきり、情報が古いまま止まっている。その状態は、見る人に不信感を与えます。',
    stat: '49.8',
    unit: '%',
    statLabel: '更新されていないと「本当に営業しているのか不安になる」',
    note: 1,
  },
  {
    title: '問い合わせが増えない',
    text: '訪れても、行動に至らない。情報が古いだけで、ビジネスの機会を逃しています。',
    stat: '32.6',
    unit: '%',
    statLabel: '更新が止まった会社とは「取引しようと思わない」',
    note: 1,
  },
  {
    title: '直す人が社内にいない',
    text: '改善したくても、判断・実装できる人材が社内にいない。打ち手が見えないまま止まります。',
    stat: '48.2',
    unit: '%',
    statLabel: '従業員10〜29人の企業で「システム担当者がいない」',
    note: 2,
  },
];

// サービス（毎月やること付き）
const services = [
  {
    title: '継続的な改善',
    description: '作って終わりにしない。月次でサイトを更新し、改善提案と実装を繰り返します。',
    accent: 'bg-navy/8',
    iconStroke: '#103366',
    items: [
      'コンテンツ更新・追加（月2〜4本）',
      '検索キーワードの調査と最適化',
      'お問い合わせ導線の改善提案',
      '競合サイト・検索トレンドの調査',
    ],
  },
  {
    title: 'AI検索（AIO）対応',
    description: 'ChatGPTやPerplexityなどのAI検索でも、あなたの会社の情報が出てくるよう、サイトの構造を整えます。',
    accent: 'bg-pink/10',
    iconStroke: '#E43172',
    items: [
      '構造化データ（Schema.org）の実装',
      'AI引用されやすいコンテンツ設計',
      'FAQ・Q&Aセクションの整備',
      'AI検索への引用状況チェック',
    ],
  },
  {
    title: '社内のWeb担当のように動きます',
    description: 'Web担当者を雇わなくても大丈夫。社外のパートナーが、社内のWeb担当のように向き合います。',
    accent: 'bg-gold/15',
    iconStroke: '#C8A951',
    items: [
      '月次改善レポートの提出',
      '翌月の改善計画・優先順位の提案',
      '専任担当による質問・相談対応',
      '月次オンラインMTG（30分）',
    ],
  },
];

// トップページの Service 構造化データ
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'ホームページ運用・改善サービス',
  name: 'plugdo',
  provider: { '@type': 'Organization', name: '株式会社ハンチス' },
  areaServed: 'JP',
  description:
    '作ったきりのホームページを、毎月の更新・改善とAI検索対応で問い合わせ・採用につなげるサービス。',
};
---

<BaseLayout
  title="ホームページを、働かせる。｜中小企業のWeb改善サービス plugdo"
  description="ホームページを、働かせる。作ったきりのサイトを毎月の改善で問い合わせと採用につなげます。Web担当がいない中小企業・小規模事業者のためのWeb運用サービス plugdo（プラグドゥ）。"
  jsonLd={serviceLd}
>
  <Hero />

  <!-- 課題提起 -->
  <section class="bg-mist">
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Problem</p>
        <h2 class="section-title">サイトはある。でも——</h2>
        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-gray">
          「ホームページがある会社は信頼できる」と答えた経営者は79.8%<sup class="text-pink">※1</sup>。
          でも<strong class="text-navy">何年も更新されていないサイトは、逆に不信感につながります。</strong>
        </p>
      </div>

      <!-- 3つの数字 -->
      <div class="mt-14 grid gap-12 md:grid-cols-3">

        <!-- 数字 0 -->
        <div class="text-center" data-animate data-animate-delay="0">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[0].stat} data-count-suffix={problems[0].unit}>
            {problems[0].stat}{problems[0].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[0].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[0].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[0].note}</sup>
          </p>
        </div>

        <!-- 数字 1 -->
        <div class="text-center" data-animate data-animate-delay="120">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[1].stat} data-count-suffix={problems[1].unit}>
            {problems[1].stat}{problems[1].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[1].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[1].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[1].note}</sup>
          </p>
        </div>

        <!-- 数字 2 -->
        <div class="text-center" data-animate data-animate-delay="240">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[2].stat} data-count-suffix={problems[2].unit}>
            {problems[2].stat}{problems[2].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[2].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[2].note}</sup>
          </p>
        </div>

      </div>

      <!-- ブリッジ -->
      <div class="mt-16 border-t border-navy/10 pt-10 text-center" data-animate="fade-in">
        <p class="text-base font-bold text-navy md:text-lg">その「もったいない」を、plugdoが解決します。</p>
      </div>

      <!-- 出典（控えめな脚注） -->
      <p class="mt-6 text-center text-[11px] leading-relaxed text-gray/40">
        ※1
        <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
        </a>
        ／ ※2
        <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
        </a>
      </p>
    </div>
  </section>

  <!-- How it works: 3ステップ -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">How it works</p>
        <h2 class="section-title">毎月のくり返しで、<br />サイトが育っていく。</h2>
        <p class="mx-auto mt-5 max-w-md text-sm leading-relaxed text-gray">
          3つのステップを毎月繰り返すことで、サイトが「問い合わせにつながる状態」になっていきます。
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3 md:items-stretch">

        <!-- Step 01: 診断する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="0">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-sky to-mist">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- ブラウザ -->
              <rect x="8" y="10" width="76" height="58" rx="8" fill="white" opacity="0.9"/>
              <rect x="8" y="10" width="76" height="18" rx="8" fill="#EBEEF2"/>
              <rect x="8" y="22" width="76" height="6" fill="#EBEEF2"/>
              <circle cx="16" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <circle cx="23" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <rect x="32" y="13" width="38" height="10" rx="5" fill="white" opacity="0.7"/>
              <!-- コンテンツライン -->
              <rect x="16" y="36" width="48" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <rect x="16" y="46" width="36" height="5" rx="2.5" fill="#E43172" opacity="0.2"/>
              <rect x="16" y="56" width="42" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <!-- ルーペ -->
              <circle cx="98" cy="54" r="22" fill="white" opacity="0.7"/>
              <circle cx="94" cy="50" r="13" fill="none" stroke="#103366" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="103" y1="59" x2="112" y2="68" stroke="#103366" stroke-width="3" stroke-linecap="round"/>
              <!-- ハイライト -->
              <rect x="16" y="46" width="22" height="5" rx="2.5" fill="#E43172" opacity="0.5"/>
              <!-- 発見バッジ -->
              <rect x="72" y="20" width="38" height="18" rx="9" fill="#103366"/>
              <text x="91" y="32.5" text-anchor="middle" font-size="8" font-family="system-ui,sans-serif" fill="white" font-weight="700">5件発見</text>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">01</p>
            <h3 class="mt-3 text-xl font-bold text-navy">診断する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">今のサイトを分析し、課題を見つけます。何から手をつければいいかがわかります。</p>
          </div>
        </div>

        <!-- Step 02: 改善する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="120">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-pink/8 to-white">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- ブラウザ -->
              <rect x="22" y="10" width="76" height="58" rx="8" fill="white" opacity="0.9"/>
              <rect x="22" y="10" width="76" height="18" rx="8" fill="#EBEEF2"/>
              <rect x="22" y="22" width="76" height="6" fill="#EBEEF2"/>
              <circle cx="30" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <circle cx="37" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <!-- コンテンツライン (更新中) -->
              <rect x="30" y="36" width="52" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <rect x="30" y="46" width="40" height="5" rx="2.5" fill="#E43172" opacity="0.15"/>
              <rect x="30" y="56" width="46" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <!-- 更新中バッジ -->
              <rect x="30" y="43" width="34" height="11" rx="5.5" fill="white" stroke="#E43172" stroke-width="1.2" stroke-opacity="0.5"/>
              <text x="47" y="51.5" text-anchor="middle" font-size="6" font-family="system-ui,sans-serif" fill="#E43172" font-weight="700">更新中...</text>
              <!-- チェックマーク群 -->
              <circle cx="112" cy="30" r="12" fill="#E43172" opacity="0.1"/>
              <path d="M106 30 L110 34 L118 24" stroke="#E43172" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="112" cy="56" r="10" fill="#103366" opacity="0.08"/>
              <path d="M107 56 L110 59 L117 51" stroke="#103366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <!-- 月次ラベル -->
              <rect x="86" y="72" width="46" height="16" rx="8" fill="#E43172"/>
              <text x="109" y="83.5" text-anchor="middle" font-size="7.5" font-family="system-ui,sans-serif" fill="white" font-weight="700">毎月実施</text>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">02</p>
            <h3 class="mt-3 text-xl font-bold text-navy">改善する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">コンテンツ更新・SEO・AI検索対応を毎月実施。作って終わりにせず、動かし続けます。</p>
          </div>
        </div>

        <!-- Step 03: 計測する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="240">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-navy/5 to-mist">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- レポートカード -->
              <rect x="14" y="8" width="112" height="76" rx="10" fill="white" opacity="0.9"/>
              <rect x="14" y="8" width="112" height="22" rx="10" fill="#EAF3FB"/>
              <rect x="14" y="24" width="112" height="6" fill="#EAF3FB"/>
              <text x="24" y="22" font-size="7.5" font-family="system-ui,sans-serif" fill="#103366" font-weight="700">月次レポート</text>
              <!-- バーチャート (増加傾向) -->
              <rect x="26" y="65" width="10" height="12" rx="2" fill="#EBEEF2"/>
              <rect x="41" y="58" width="10" height="19" rx="2" fill="#EBEEF2"/>
              <rect x="56" y="50" width="10" height="27" rx="2" fill="#103366" opacity="0.18"/>
              <rect x="71" y="42" width="10" height="35" rx="2" fill="#103366" opacity="0.28"/>
              <rect x="86" y="34" width="10" height="43" rx="2" fill="#E43172" opacity="0.7"/>
              <!-- トレンドライン -->
              <path d="M31 69 L46 61 L61 53 L76 45 L91 37" stroke="#E43172" stroke-width="1.5" stroke-dasharray="3,2" stroke-linecap="round"/>
              <!-- 最新値バッジ -->
              <rect x="80" y="22" width="38" height="15" rx="7.5" fill="#103366"/>
              <text x="99" y="32.5" text-anchor="middle" font-size="8" font-family="system-ui,sans-serif" fill="white" font-weight="700">+8件/月</text>
              <!-- ベースライン -->
              <line x1="22" y1="77" x2="102" y2="77" stroke="#EBEEF2" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">03</p>
            <h3 class="mt-3 text-xl font-bold text-navy">計測する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">毎月レポートで成果を確認し、次の改善に活かします。このくり返しがサイトを育てます。</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- サービス概要（毎月やることリスト付き） -->
  <section class="bg-mist">
    <div class="container-pd py-20 md:py-28">
      <div class="text-center">
        <p class="section-label">Service</p>
        <h2 class="section-title">毎月、こんなことをやります</h2>
        <p class="mx-auto mt-4 max-w-lg text-sm text-gray">plugdoは、ホームページの更新と改善をまるごと担います。<br />毎月やることを3つに整理しました。</p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">

        <!-- 継続的な改善 -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="0">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-navy/8">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#103366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[0].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[0].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[0].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- AI検索（AIO）対応 -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="120">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-pink/10">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E43172" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>
              <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[1].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[1].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[1].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- 社内のWeb担当のように動きます -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="240">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gold/15">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C8A951" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="7" r="2"/>
              <path d="M6 21v-2a4 4 0 0 1 4-4h.5"/>
              <circle cx="17" cy="7" r="2"/>
              <path d="M14 21v-2a4 4 0 0 1 4-4h.5"/>
              <path d="M12 11v2.5"/>
              <path d="M12 16v2"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[2].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[2].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="mt-10 text-center">
        <a href="/service" class="btn-outline">サービスの詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- 無料診断でお渡しするもの -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Free Diagnosis</p>
        <h2 class="section-title">まず、無料診断から<br />始めませんか。</h2>
        <p class="mx-auto mt-5 max-w-lg text-sm leading-relaxed text-gray">
          「何を直せばいいか分からない」状態が一番もったいない。<br />
          30分の相談で、改善すべき箇所と優先順位を書いたレポートをお届けします。
        </p>
      </div>

