  <!-- よくある質問（FAQ） -->
  <section class="relative overflow-hidden bg-mist">
    <svg class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"><defs><pattern id="geo-faq" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1.2" fill="#103366" opacity="0.05"/></pattern></defs><rect width="100%" height="100%" fill="url(#geo-faq)"/></svg>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">FAQ</p>
        <h2 class="section-title">よくあるご質問</h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl space-y-4">
        {faqs.map((f, i) => (
          <details class="card group p-6 [&_summary]:cursor-pointer" data-animate data-animate-delay={i * 60}>
            <summary class="flex list-none items-center justify-between gap-4 font-bold text-navy">
              <span>{f.q}</span>
              <span class="flex-shrink-0 text-pink transition-transform group-open:rotate-45" aria-hidden="true">＋</span>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-ink">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
