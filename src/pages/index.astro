---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PriceTable from '../components/PriceTable.astro';
import CaseCard from '../components/CaseCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import { getCases, getBlogs } from '../lib/microcms';
import { sampleCases, sampleBlogs } from '../lib/sampleData';

// 事例・ブログを取得（未接続時はサンプルにフォールバック）
const casesRes = await getCases({ limit: 3 });
const cases = casesRes.contents.length ? casesRes.contents : sampleCases;

const blogsRes = await getBlogs({ limit: 3 });
const blogs = blogsRes.contents.length ? blogsRes.contents : sampleBlogs.slice(0, 3);

// 出典つきの定量データ（裏付け）。数字は一次ソースで検証済み。出典は脚注で控えめに掲載。
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';

const problems = [
  {
    title: '更新できていない',
    text: '公開したきり、情報が古いまま止まっている。その状態は、見る人に不信感を与えます。',
    stat: '49.8',
    unit: '%',
    statLabel: '更新されていないと「本当に営業しているのか不安になる」',
    note: 1,
  },
  {
    title: '問い合わせ・取引につながらない',
    text: '訪れても、行動に至らない。情報が古いだけで、ビジネスの機会を逃しています。',
    stat: '32.6',
    unit: '%',
    statLabel: '更新が止まった会社とは「取引しようと思わない」',
    note: 1,
  },
  {
    title: '直す人が社内にいない',
    text: '改善したくても、判断・実装できる人材が社内にいない。打ち手が見えないまま止まります。',
    stat: '48.2',
    unit: '%',
    statLabel: '従業員10〜29人の企業で「システム担当者がいない」',
    note: 2,
  },
];

// サービスカードはSVGスロット渡しに変更（以下は title/description/accent のみ）
const services = [
  {
    title: '継続的な改善',
    description: '作って終わりにしない。月次でサイトを更新し、改善提案と実装を繰り返して、問い合わせにつながる状態へ育てます。',
    accent: 'bg-navy/8',
  },
  {
    title: 'AI検索（AIO）対応',
    description: 'ChatGPTやPerplexityなどのAI検索に正しく読まれ、引用される構造へ。これからの流入経路に先回りで対応します。',
    accent: 'bg-pink/10',
  },
  {
    title: '社内担当のように伴走',
    description: 'Web担当者を雇わなくても大丈夫。社外のパートナーが社内担当のように、あなたのサイトに継続的に向き合います。',
    accent: 'bg-gold/15',
  },
];

// トップページの Service 構造化データ
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'ホームページ運用・改善サービス',
  name: 'plugdo',
  provider: { '@type': 'Organization', name: '株式会社ハンチス' },
  areaServed: 'JP',
  description:
    '作ったきりのホームページを、継続的な改善とAIO対応で問い合わせ・採用につなげる伴走型サービス。',
};
---

<BaseLayout
  title="plugdo（プラグドゥ）"
  description="ホームページを、働かせる。作ったきりのサイトを、継続的な改善とAI検索対応で問い合わせと採用につなげる伴走型サービス。Web担当者がいない中小企業のためのplugdo。"
  jsonLd={serviceLd}
>
  <Hero />

  <!-- 課題提起 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Problem</p>
        <h2 class="section-title">サイトはある。でも——</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          「ホームページがある会社は信頼できる」と答えた経営者は79.8%<sup class="text-pink">※1</sup>。
          でも"作ったきり"では、その信頼はむしろ逆効果になります。
        </p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-3">

        <!-- Card 0: 更新できていない -->
        <div class="card flex flex-col overflow-hidden" data-animate data-animate-delay="0">
          <div class="flex h-28 items-center justify-center bg-sky/60">
            <div class="flex flex-col items-center gap-1.5 rounded-lg border-2 border-dashed border-navy/20 px-8 py-4 text-navy/30">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <span class="text-[10px] font-medium tracking-wide">イラスト（後で追加）</span>
            </div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-base font-bold text-navy">{problems[0].title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/80">{problems[0].text}</p>
            <div class="mt-5 border-t border-mist pt-4">
              <div class="flex items-baseline gap-1">
                <span class="font-display text-4xl leading-none text-pink" data-count={problems[0].stat} data-count-suffix={problems[0].unit}>{problems[0].stat}{problems[0].unit}</span>
                <sup class="ml-1 text-[10px] text-gray/50">※{problems[0].note}</sup>
              </div>
              <p class="mt-1.5 text-xs leading-snug text-ink">{problems[0].statLabel}</p>
            </div>
          </div>
        </div>

        <!-- Card 1: 問い合わせにつながらない -->
        <div class="card flex flex-col overflow-hidden" data-animate data-animate-delay="120">
          <div class="flex h-28 items-center justify-center bg-pink/5">
            <div class="flex flex-col items-center gap-1.5 rounded-lg border-2 border-dashed border-pink/30 px-8 py-4 text-pink/30">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <span class="text-[10px] font-medium tracking-wide">イラスト（後で追加）</span>
            </div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-base font-bold text-navy">{problems[1].title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/80">{problems[1].text}</p>
            <div class="mt-5 border-t border-mist pt-4">
              <div class="flex items-baseline gap-1">
                <span class="font-display text-4xl leading-none text-pink" data-count={problems[1].stat} data-count-suffix={problems[1].unit}>{problems[1].stat}{problems[1].unit}</span>
                <sup class="ml-1 text-[10px] text-gray/50">※{problems[1].note}</sup>
              </div>
              <p class="mt-1.5 text-xs leading-snug text-ink">{problems[1].statLabel}</p>
            </div>
          </div>
        </div>

        <!-- Card 2: 直す人が社内にいない -->
        <div class="card flex flex-col overflow-hidden" data-animate data-animate-delay="240">
          <div class="flex h-28 items-center justify-center bg-gold/10">
            <div class="flex flex-col items-center gap-1.5 rounded-lg border-2 border-dashed border-gold/40 px-8 py-4 text-gold/50">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <span class="text-[10px] font-medium tracking-wide">イラスト（後で追加）</span>
            </div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-base font-bold text-navy">{problems[2].title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/80">{problems[2].text}</p>
            <div class="mt-5 border-t border-mist pt-4">
              <div class="flex items-baseline gap-1">
                <span class="font-display text-4xl leading-none text-pink" data-count={problems[2].stat} data-count-suffix={problems[2].unit}>{problems[2].stat}{problems[2].unit}</span>
                <sup class="ml-1 text-[10px] text-gray/50">※{problems[2].note}</sup>
              </div>
              <p class="mt-1.5 text-xs leading-snug text-ink">{problems[2].statLabel}</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-10 flex items-center justify-center gap-4">
        <div class="h-px max-w-xs flex-1 bg-navy/10"></div>
        <p class="text-sm font-bold text-navy">その「もったいない」を、plugdoが解決します。</p>
        <div class="h-px max-w-xs flex-1 bg-navy/10"></div>
      </div>

      {/* 出典（控えめな脚注） */}
      <p class="mt-6 text-center text-[11px] leading-relaxed text-gray/40">
        ※1
        <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
        </a>
        ／ ※2
        <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
        </a>
      </p>
    </div>
  </section>

  <!-- サービス概要 -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">Service</p>
        <h2 class="section-title">3つの価値で、サイトを動かす</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <!-- 継続的な改善: 循環する矢印 -->
        <ServiceCard title={services[0].title} description={services[0].description} accent={services[0].accent} data-animate data-animate-delay="0">
          <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#103366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
          </svg>
        </ServiceCard>

        <!-- AI検索（AIO）対応: ニューラルネット風の脳/AI -->
        <ServiceCard title={services[1].title} description={services[1].description} accent={services[1].accent} data-animate data-animate-delay="120">
          <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E43172" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>
            <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
          </svg>
        </ServiceCard>

        <!-- 社内担当のように伴走: 並走する2人 -->
        <ServiceCard title={services[2].title} description={services[2].description} accent={services[2].accent} data-animate data-animate-delay="240">
          <svg slot="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C8A951" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="7" r="2"/>
            <path d="M6 21v-2a4 4 0 0 1 4-4h.5"/>
            <circle cx="17" cy="7" r="2"/>
            <path d="M14 21v-2a4 4 0 0 1 4-4h.5"/>
            <path d="M12 11v2.5"/>
            <path d="M12 16v2"/>
          </svg>
        </ServiceCard>
      </div>
      <div class="mt-10 text-center">
        <a href="/service" class="btn-outline">サービスの詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- 導入事例 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="flex items-end justify-between">
        <div>
          <p class="section-label-left">Works</p>
          <h2 class="section-title">導入事例</h2>
        </div>
        <a href="/cases" class="hidden text-sm font-bold text-pink hover:text-pinkAlt md:inline">
          すべて見る →
        </a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {cases.map((item, i) => (
          <div data-animate data-animate-delay={i * 100}>
            <CaseCard item={item} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 料金プラン -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">Price</p>
        <h2 class="section-title">料金プラン</h2>
        <p class="mt-4 text-sm text-gray">事業のフェーズに合わせて選べる3プラン。</p>
      </div>
      <div class="mt-12">
        <PriceTable variant="summary" />
      </div>
      <div class="mt-10 text-center">
        <a href="/price" class="btn-outline">料金の詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- ブログ最新記事 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="flex items-end justify-between">
        <div>
          <p class="section-label-left">Blog</p>
          <h2 class="section-title">最新記事</h2>
        </div>
        <a href="/blog" class="hidden text-sm font-bold text-pink hover:text-pinkAlt md:inline">
          すべて見る →
        </a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {blogs.map((item, i) => (
          <div data-animate data-animate-delay={i * 100}>
            <BlogCard item={item} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
