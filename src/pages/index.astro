---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import WhyAffordable from '../components/WhyAffordable.astro';
import { SITE_URL } from '../lib/site';

// 実績（ノエクリ事例）の表示フラグ。
// TODO: ノエクリ様の掲載許可が取れたら true にする。数値・文言も許可時に確定させること。
const SHOW_NOEKURI_CASE = false;

// 制作実績（実際に制作したサイト。画像は各サイトの実物ビジュアル）
const works = [
  {
    name: 'HUNCHES メンタリング',
    category: 'サービスサイト',
    desc: 'Webデザイナー向け伴走型サポートのサービスサイト。LINE導線と実績数値を軸にした構成で設計・制作。',
    url: 'https://hunches-mentoring.com/',
    image: '/works/hunches-mentoring.png',
    imgW: 1200,
    imgH: 630,
  },
  {
    name: 'HIROHISA SATO DESIGN GARALLY',
    category: 'ポートフォリオサイト',
    desc: '建築デザイナー佐藤博久氏の作品ギャラリー。写真を主役にした静かなダークトーンで制作。',
    url: 'https://www.baku-ado.com/',
    image: null, // 実物スクリーンショット未取得のためロゴ＋タイポグラフィで構成
    logo: '/works/baku-logo.png',
    logoW: 868,
    logoH: 204,
  },
  {
    name: '東京人間ドッククリニック',
    category: '医療機関LP',
    desc: '人間ドックの集患LP。WEB予約・LINE相談への導線と、不安を解く説明重視の構成で制作。',
    url: 'https://www.e-dock.jp/lp',
    image: '/works/e-dock.png',
    imgW: 786,
    imgH: 1278,
  },
];

// 出典つきの定量データ（一次ソースで検証済み。出典は脚注で控えめに掲載）
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';
const stats = [
  { value: '49.8', unit: '%', label: '更新されていないサイトは「本当に営業しているのか不安になる」', note: 1 },
  { value: '32.6', unit: '%', label: '更新が止まった会社とは「取引しようと思わない」', note: 1 },
  { value: '48.2', unit: '%', label: '従業員10〜29人の企業で「システム担当者がいない」', note: 2 },
];

// 悩みの提示（4項目）
const problems = [
  {
    title: '作ってから3年以上そのまま',
    text: '情報が古いまま放置されたサイトは、見た人に「本当に営業しているのか」という不安を与えます。',
  },
  {
    title: '更新のたびに見積もりと納期待ち',
    text: '文言ひとつ直すのに見積もり依頼と数週間の納期。だんだん更新を頼まなくなっていきます。',
  },
  {
    title: 'スマホで崩れている',
    text: 'アクセスの過半はスマホから。表示が崩れているだけで、問い合わせの機会を失っています。',
  },
  {
    title: '誰に頼めばいいかわからない',
    text: '制作会社・フリーランス・広告代理店。相場も違いもわからず、比較のしようがありません。',
  },
];

// 進め方4ステップ
const steps = [
  {
    no: '1',
    title: '30秒のAI診断',
    desc: 'URLを入れるだけで、今のサイトを採点。課題が数字で見えます。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="5.5"/><line x1="13" y1="13" x2="17.5" y2="17.5"/><path d="M7 9h4M9 7v4"/></svg>',
  },
  {
    no: '2',
    title: '結果をもとに無料相談',
    desc: '30分・オンライン。診断結果を見ながら、直すべき範囲を整理します。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10a7 7 0 1 1-3.2-5.9L17 3l-.6 3.4A7 7 0 0 1 17 10z"/><line x1="7" y1="8.5" x2="13" y2="8.5"/><line x1="7" y1="11.5" x2="11" y2="11.5"/></svg>',
  },
  {
    no: '3',
    title: '必要ならリニューアル',
    desc: '作り直しが必要な場合のみ。2週間〜、¥198,000からの定額です。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="3.5" width="15" height="13" rx="2"/><line x1="2.5" y1="7.5" x2="17.5" y2="7.5"/><path d="M6.5 11l2 2 4.5-4"/></svg>',
  },
  {
    no: '4',
    title: '月1万円台の運用で育てる',
    desc: '公開後は運用へ。更新が止まらない状態を月¥9,800から維持します。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 15.5 7 10.5 10 13 17 5.5"/><polyline points="13 5.5 17 5.5 17 9.5"/></svg>',
  },
];

// よくある質問（4問）
const faqs = [
  {
    q: '今の制作会社との契約はどうなりますか？',
    a: '現在のサーバー・ドメインの契約状況を確認した上で、移管や引き継ぎの段取りをこちらで整理します。現契約の解約手続きはお客様に行っていただきますが、必要な情報はすべてお渡しします。',
  },
  {
    q: '月2回の修正で足りますか？',
    a: '「営業時間の変更」「写真の差し替え」といった日常の更新であれば、月2回で足りるお客様がほとんどです。更新頻度が高い場合は、回数無制限の運用スタンダード（月¥19,800）をご検討ください。',
  },
  {
    q: '補助金は使えますか？',
    a: 'リニューアルが小規模事業者持続化補助金の対象となる場合、実質負担を約1/3に抑えられる可能性があります。申請可否は公募要領によりますので、無料相談時に状況を確認します。',
  },
  {
    q: '解約したらサイトはどうなりますか？',
    a: '運用に最低契約期間はなく、いつでも解約できます。解約時はサイト一式（データ・アカウント情報）をお渡ししますので、他社への引き継ぎも自由です。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// トップページの Service 構造化データ（リニューアル＋運用の2商品）
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE_URL}/#service`,
  serviceType: 'ホームページ制作・運用サービス',
  name: 'Plugdo（プラグド）',
  url: SITE_URL,
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'Japan' },
  audience: {
    '@type': 'BusinessAudience',
    name: 'Web担当者のいない中小企業・小規模事業者',
  },
  description:
    '無料のAI診断でホームページの現状を採点し、必要ならリニューアル（¥198,000〜）、その後は月¥9,800からの運用で更新が止まらないサイトを維持するサービス。',
  offers: [
    {
      '@type': 'Offer',
      name: 'ホームページリニューアル',
      description: '診断してから必要な分だけ作り直す定額パッケージ',
      price: '198000',
      priceCurrency: 'JPY',
      url: `${SITE_URL}/renewal`,
    },
    {
      '@type': 'Offer',
      name: 'Web運用',
      description: 'サーバー管理・更新代行・月次改善提案。最低契約期間なし',
      price: '9800',
      priceCurrency: 'JPY',
      url: `${SITE_URL}/care`,
    },
  ],
};
---

<BaseLayout
  title="ホームページのリニューアルと月1万円台のWeb運用 | Plugdo"
  description="無料のAI診断で現状を採点。リニューアルは¥198,000から、運用は月¥9,800から。長野から全国対応、最低契約期間なし。"
  jsonLd={[serviceLd, faqLd]}
>
  <Hero />

  <!-- 悩みの提示 -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Problem -</p>
        <h2 class="section-title">こんな状態、<br class="sm:hidden" />ありませんか。</h2>
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-x-10 gap-y-8 md:grid-cols-2">
        {
          problems.map((p) => (
            <div class="border-t border-navy/10 pt-5">
              <h3 class="text-base font-bold text-navy">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">{p.text}</p>
            </div>
          ))
        }
      </div>

      <!-- 数字で見る現実（出典つき統計） -->
      <div class="mx-auto mt-14 max-w-4xl">
        <div class="grid gap-6 md:grid-cols-3">
          {
            stats.map((s, i) => (
              <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-7 shadow-[0_2px_16px_rgba(16,51,102,0.06)]" data-animate data-animate-delay={String(i * 120)}>
                <div class="mb-4 h-1 w-10 rounded-full bg-pink"></div>
                <div
                  class="font-display text-[3rem] font-black leading-none text-pink [font-variant-numeric:tabular-nums]"
                  data-count={s.value}
                  data-count-suffix={s.unit}
                >
                  {s.value}{s.unit}
                </div>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-gray">
                  {s.label}<sup class="ml-0.5 text-[9px] text-gray/40">※{s.note}</sup>
                </p>
              </div>
            ))
          }
        </div>
        <p class="mt-4 text-center text-[11px] leading-relaxed text-gray/40">
          ※1
          <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
            プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
          </a>
          ／ ※2
          <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
            kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
          </a>
        </p>
      </div>

      <div class="mt-12 border-t border-navy/10 pt-8 text-center" data-animate="fade-in">
        <p class="text-base font-bold text-navy md:text-lg">
          Plugdoは、診断で現状を数字にしてから、作り直しと運用で更新が止まらないサイトにします。
        </p>
      </div>
    </div>
  </section>

  <!-- サービス分岐カード -->
  <ServiceCards />

  <!-- 進め方4ステップ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Process -</p>
        <h2 class="section-title">進め方</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          入口は無料のAI診断。そこから必要なものだけを選べます。
        </p>
      </div>
      <ol class="mx-auto mt-10 grid max-w-4xl gap-6 md:grid-cols-4">
        {
          steps.map((s) => (
            <li class="border-t-2 border-navy pt-4">
              <div class="flex items-center justify-between gap-2">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-mist text-navy" set:html={s.icon} />
                <span class="font-display text-xs font-bold tracking-widest text-gray">STEP {s.no}</span>
              </div>
              <h3 class="mt-3 text-base font-bold text-navy">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">{s.desc}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- なぜこの価格でできるのか -->
  <WhyAffordable />

  <!-- 制作実績 -->
  <section id="works" class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Works -</p>
        <h2 class="section-title">制作実績</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          実際に制作したサイトの一部です。
        </p>
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-6 md:grid-cols-3">
        {
          works.map((w) => (
            <a
              href={w.url}
              target="_blank"
              rel="noopener noreferrer"
              class="card group flex flex-col overflow-hidden no-underline"
            >
              <div class="aspect-[16/10] overflow-hidden border-b border-mist bg-white">
                {w.image ? (
                  <img
                    src={w.image}
                    alt={`${w.name} のサイトビジュアル`}
                    width={w.imgW}
                    height={w.imgH}
                    loading="lazy"
                    class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-slate px-8">
                    <img
                      src={w.logo}
                      alt={`${w.name} のロゴ`}
                      width={w.logoW}
                      height={w.logoH}
                      loading="lazy"
                      class="w-full max-w-[240px]"
                    />
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-[10px] font-bold uppercase tracking-widest text-pink">{w.category}</p>
                <h3 class="mt-1.5 text-base font-bold leading-snug text-navy group-hover:text-pink">{w.name}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-gray">{w.desc}</p>
                <p class="mt-4 inline-flex items-center gap-1.5 text-xs font-bold text-navy">
                  サイトを見る
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 2H10v5.5M10 2 2 10" /></svg>
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 実績（ノエクリ事例）
       TODO: 掲載許可が取れたら SHOW_NOEKURI_CASE を true にし、実際の数値・スクリーンショット・
             コメントを掲載許可の範囲で確定させ、上の works 配列にカードとして追加すること。 -->
  {
    SHOW_NOEKURI_CASE && (
      <section class="bg-paper">
        <div class="container-pd py-16 md:py-20">
          <div class="mx-auto max-w-3xl rounded-xl border border-gray/10 bg-paper p-7 md:p-9">
            <p class="text-xs font-bold text-gray">株式会社ノエクリ 様</p>
            <h3 class="mt-2 text-lg font-bold text-navy">コーポレートサイト リニューアル＋運用</h3>
          </div>
        </div>
      </section>
    )
  }

  <!-- よくある質問（FAQ） -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- FAQ -</p>
        <h2 class="section-title">よくあるご質問</h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl space-y-4">
        {
          faqs.map((f) => (
            <details class="group rounded-xl border border-gray/10 bg-paper">
              <summary class="flex cursor-pointer list-none items-start gap-3 px-6 py-5">
                <span class="font-display text-base font-bold text-pink">Q</span>
                <span class="flex-1 text-sm font-bold leading-relaxed text-navy md:text-base">{f.q}</span>
                <span class="mt-1 text-gray transition-transform group-open:rotate-180" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="2 5 7 10 12 5" /></svg>
                </span>
              </summary>
              <div class="flex gap-3 border-t border-mist px-6 py-5">
                <span class="font-display text-base font-bold text-navy">A</span>
                <p class="flex-1 text-sm leading-relaxed text-ink">{f.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 最終CTA -->
  <section class="bg-navy">
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-black leading-snug text-paper md:text-3xl">
          まず、いまのサイトが<br class="sm:hidden" />何点か知ることから。
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-white/80">
          URLを入れるだけ・30秒で採点。診断は無料、契約は不要です。
        </p>
        <a href="/check" class="btn-pink mt-7">無料で自社サイトを診断する（30秒）</a>
      </div>
    </div>
  </section>
</BaseLayout>
