---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import WhyAffordable from '../components/WhyAffordable.astro';
import BlogCard from '../components/BlogCard.astro';
import { getBlogs } from '../lib/microcms';
import { sampleBlogs } from '../lib/sampleData';
import { SITE_URL } from '../lib/site';

// ブログを取得（未接続時はサンプルにフォールバック）
const blogsRes = await getBlogs({ limit: 3 });
const blogs = blogsRes.contents.length ? blogsRes.contents : sampleBlogs.slice(0, 3);

// 実績（ノエクリ事例）の表示フラグ。
// TODO: ノエクリ様の掲載許可が取れたら true にする。数値・文言も許可時に確定させること。
const SHOW_NOEKURI_CASE = false;

// 制作実績（実際に制作したサイト。画像は制作物のモックアップ）
const works = [
  {
    name: 'HUNCHES メンタリング',
    category: 'サービスサイト',
    desc: 'Webデザイナー向け伴走型サポートのサービスサイト。LINE導線と実績数値を軸にした構成で設計・制作。',
    url: 'https://hunches-mentoring.com/',
    image: '/works/exa_01.png',
  },
  {
    name: 'HIROHISA SATO DESIGN GARALLY',
    category: 'ポートフォリオサイト',
    desc: '建築デザイナー佐藤博久氏の作品ギャラリー。写真を主役にした静かなダークトーンで制作。',
    url: 'https://www.baku-ado.com/',
    image: '/works/exa_02.png',
  },
  {
    name: '東京人間ドッククリニック',
    category: '医療機関LP',
    desc: '人間ドックの集患LP。WEB予約・LINE相談への導線と、不安を解く説明重視の構成で制作。',
    url: 'https://www.e-dock.jp/lp',
    image: '/works/exa_03.png',
  },
];

// 出典つきの定量データ（一次ソースで検証済み。出典は脚注で控えめに掲載）
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';
const stats = [
  { value: '49.8', unit: '%', label: '更新されていないサイトは「本当に営業しているのか不安になる」', note: 1 },
  { value: '32.6', unit: '%', label: '更新が止まった会社とは「取引しようと思わない」', note: 1 },
  { value: '48.2', unit: '%', label: '従業員10〜29人の企業で「システム担当者がいない」', note: 2 },
];

// 悩みの提示（4項目・項目ごとのフラットイラスト）
const problems = [
  {
    title: '作ってから3年以上そのまま',
    text: '情報が古いまま放置されたサイトは、見た人に「本当に営業しているのか」という不安を与えます。',
    // カレンダー＋止まった時計
    svg: `<svg viewBox="0 0 120 84" class="h-28 w-auto" role="img" aria-label="止まったカレンダー">
      <rect x="30" y="18" width="60" height="52" rx="7" fill="#FFFFFF" stroke="#EBEEF2" stroke-width="2"/>
      <path d="M30 25a7 7 0 0 1 7-7h46a7 7 0 0 1 7 7v9H30z" fill="#E43172"/>
      <rect x="42" y="12" width="4" height="12" rx="2" fill="#103366"/>
      <rect x="74" y="12" width="4" height="12" rx="2" fill="#103366"/>
      <g fill="#103366" opacity="0.12"><rect x="38" y="42" width="8" height="6" rx="2"/><rect x="50" y="42" width="8" height="6" rx="2"/><rect x="62" y="42" width="8" height="6" rx="2"/><rect x="38" y="54" width="8" height="6" rx="2"/><rect x="50" y="54" width="8" height="6" rx="2"/></g>
      <circle cx="84" cy="60" r="14" fill="#FFFFFF" stroke="#EBEEF2" stroke-width="2"/>
      <line x1="84" y1="60" x2="84" y2="52" stroke="#E43172" stroke-width="2.2" stroke-linecap="round"/>
      <line x1="84" y1="60" x2="90" y2="63" stroke="#E43172" stroke-width="2.2" stroke-linecap="round"/>
      <circle cx="84" cy="60" r="1.8" fill="#E43172"/>
    </svg>`,
  },
  {
    title: '更新のたびに見積もりと納期待ち',
    text: '文言ひとつ直すのに見積もり依頼と数週間の納期。だんだん更新を頼まなくなっていきます。',
    // 書類＋砂時計
    svg: `<svg viewBox="0 0 120 84" class="h-28 w-auto" role="img" aria-label="見積書と砂時計">
      <path d="M28 14h28l14 14v40a2 2 0 0 1-2 2H28a2 2 0 0 1-2-2V16a2 2 0 0 1 2-2z" fill="#FFFFFF" stroke="#EBEEF2" stroke-width="2"/>
      <path d="M56 14v14h14" fill="none" stroke="#EBEEF2" stroke-width="2"/>
      <rect x="33" y="40" width="30" height="4" rx="2" fill="#EBEEF2"/>
      <rect x="33" y="49" width="24" height="4" rx="2" fill="#EBEEF2"/>
      <rect x="33" y="59" width="18" height="8" rx="4" fill="#E43172" opacity="0.14"/>
      <g stroke="#103366" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="82" y1="30" x2="102" y2="30"/><line x1="82" y1="70" x2="102" y2="70"/><path d="M84 30c0 9 8 13 8 20s-8 11-8 20"/><path d="M100 30c0 9-8 13-8 20s8 11 8 20"/></g>
      <path d="M87 35h10l-5 7z" fill="#E43172"/>
      <path d="M89 65h6l-3-5z" fill="#E43172"/>
    </svg>`,
  },
  {
    title: 'スマホで崩れている',
    text: 'アクセスの過半はスマホから。表示が崩れているだけで、問い合わせの機会を失っています。',
    // スマホ（レイアウト崩れ）
    svg: `<svg viewBox="0 0 120 84" class="h-28 w-auto" role="img" aria-label="表示が崩れたスマホ">
      <rect x="40" y="8" width="46" height="68" rx="10" fill="#103366"/>
      <rect x="45" y="16" width="36" height="53" rx="4" fill="#FFFFFF"/>
      <rect x="50" y="23" width="46" height="6" rx="2" fill="#EBEEF2"/>
      <rect x="50" y="34" width="20" height="5" rx="2" fill="#EBEEF2"/>
      <rect x="50" y="44" width="38" height="5" rx="2" fill="#EBEEF2"/>
      <rect x="50" y="55" width="14" height="10" rx="2" fill="#EAF3FB"/>
      <rect x="70" y="55" width="28" height="10" rx="2" fill="#EBEEF2"/>
      <circle cx="84" cy="18" r="10" fill="#E43172"/>
      <rect x="82.8" y="13" width="2.4" height="6" rx="1.2" fill="#FFFFFF"/>
      <circle cx="84" cy="22" r="1.5" fill="#FFFFFF"/>
    </svg>`,
  },
  {
    title: '誰に頼めばいいかわからない',
    text: '制作会社・フリーランス・広告代理店。相場も違いもわからず、比較のしようがありません。',
    // ？＋3つの選択肢
    svg: `<svg viewBox="0 0 120 84" class="h-28 w-auto" role="img" aria-label="選択肢に迷う">
      <circle cx="60" cy="26" r="18" fill="#EAF3FB"/>
      <text x="60" y="35" font-size="26" font-weight="900" fill="#103366" text-anchor="middle" font-family="system-ui, sans-serif">?</text>
      <rect x="12" y="58" width="28" height="16" rx="4" fill="#FFFFFF" stroke="#EBEEF2" stroke-width="2"/>
      <rect x="46" y="58" width="28" height="16" rx="4" fill="#FFFFFF" stroke="#E43172" stroke-width="2"/>
      <rect x="80" y="58" width="28" height="16" rx="4" fill="#FFFFFF" stroke="#EBEEF2" stroke-width="2"/>
      <rect x="18" y="65" width="16" height="3" rx="1.5" fill="#EBEEF2"/>
      <rect x="52" y="65" width="16" height="3" rx="1.5" fill="#E43172" opacity="0.4"/>
      <rect x="86" y="65" width="16" height="3" rx="1.5" fill="#EBEEF2"/>
    </svg>`,
  },
];

// 進め方4ステップ
const steps = [
  {
    no: '1',
    title: '30秒のAI診断',
    desc: 'URLを入れるだけで、今のサイトを採点。課題が数字で見えます。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="5.5"/><line x1="13" y1="13" x2="17.5" y2="17.5"/><path d="M7 9h4M9 7v4"/></svg>',
  },
  {
    no: '2',
    title: '結果をもとに無料相談',
    desc: '30分・オンライン。診断結果を見ながら、直すべき範囲を整理します。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10a7 7 0 1 1-3.2-5.9L17 3l-.6 3.4A7 7 0 0 1 17 10z"/><line x1="7" y1="8.5" x2="13" y2="8.5"/><line x1="7" y1="11.5" x2="11" y2="11.5"/></svg>',
  },
  {
    no: '3',
    title: '必要ならリニューアル',
    desc: '作り直しが必要な場合のみ。2週間〜、¥198,000（税込）からの定額です。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="3.5" width="15" height="13" rx="2"/><line x1="2.5" y1="7.5" x2="17.5" y2="7.5"/><path d="M6.5 11l2 2 4.5-4"/></svg>',
  },
  {
    no: '4',
    title: '月々の運用で育てる',
    desc: '公開後は運用へ。更新が止まらない状態を、月¥9,800（税込）から維持します。',
    icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2.5 15.5 7 10.5 10 13 17 5.5"/><polyline points="13 5.5 17 5.5 17 9.5"/></svg>',
  },
];

// よくある質問（4問）
const faqs = [
  {
    q: '今の制作会社との契約はどうなりますか？',
    a: '現在のサーバー・ドメインの契約状況を確認した上で、移管や引き継ぎの段取りをこちらで整理します。現契約の解約手続きはお客様に行っていただきますが、必要な情報はすべてお渡しします。',
  },
  {
    q: '月2回の修正で足りますか？',
    a: '「営業時間の変更」「写真の差し替え」といった日常の更新であれば、月2回で足りるお客様がほとんどです。更新頻度が高い場合は、回数無制限の運用スタンダード（月¥19,800）をご検討ください。',
  },
  {
    q: '補助金は使えますか？',
    a: 'リニューアルが小規模事業者持続化補助金の対象となる場合、実質負担を約1/3に抑えられる可能性があります。申請可否は公募要領によりますので、無料相談時に状況を確認します。',
  },
  {
    q: '解約したらサイトはどうなりますか？',
    a: '運用に最低契約期間はなく、いつでも解約できます。解約時はサイト一式（データ・アカウント情報）をお渡ししますので、他社への引き継ぎも自由です。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// トップページの Service 構造化データ（リニューアル＋運用の2商品）
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE_URL}/#service`,
  serviceType: 'ホームページ制作・運用サービス',
  name: 'Plugdo（プラグド）',
  url: SITE_URL,
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'Japan' },
  audience: {
    '@type': 'BusinessAudience',
    name: 'Web担当者のいない中小企業・小規模事業者',
  },
  description:
    '無料のAI診断でホームページの現状を採点し、必要ならリニューアル（¥198,000〜）、その後は月¥9,800からの運用で更新が止まらないサイトを維持するサービス。',
  offers: [
    {
      '@type': 'Offer',
      name: 'ホームページリニューアル',
      description: '診断してから必要な分だけ作り直す定額パッケージ',
      price: '198000',
      priceCurrency: 'JPY',
      url: `${SITE_URL}/renewal/`,
    },
    {
      '@type': 'Offer',
      name: 'Web運用',
      description: 'サーバー管理・更新代行・月次改善提案。最低契約期間なし',
      price: '9800',
      priceCurrency: 'JPY',
      url: `${SITE_URL}/care/`,
    },
  ],
};
---

<BaseLayout
  title="ホームページのリニューアルと月¥9,800からのWeb運用 | Plugdo"
  description="無料のAI診断で現状を採点。リニューアルは¥198,000から、運用は月¥9,800から。長野から全国対応、最低契約期間なし。"
  jsonLd={[serviceLd, faqLd]}
>
  <Hero />

  <!-- 悩みの提示 -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Problem -</p>
        <h2 class="section-title">こんな状態、<br class="sm:hidden" />ありませんか。</h2>
      </div>

      <!-- 悩み4項目（項目ごとのフラットイラスト付きカード） -->
      <div class="mx-auto mt-10 grid max-w-4xl gap-6 sm:grid-cols-2">
        {
          problems.map((p, i) => (
            <div
              class="flex flex-col overflow-hidden rounded-2xl border border-gray/10 bg-white shadow-[0_2px_16px_rgba(16,51,102,0.05)]"
              data-animate
              data-animate-delay={String(i * 90)}
            >
              <div class="flex items-center justify-center bg-mist/50 py-9" set:html={p.svg} />
              <div class="p-6">
                <h3 class="text-base font-bold text-navy">{p.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray">{p.text}</p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- 数字で見る現実（出典つき統計） -->
      <div class="mx-auto mt-16 max-w-4xl">
        <div class="text-center" data-animate="fade-in">
          <h3 class="text-xl font-black text-navy md:text-2xl">数字で見る、放置サイトのリスク</h3>
          <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-gray">
            更新の止まったサイトは、信頼も、取引の機会も静かに失っています。
          </p>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {
            stats.map((s, i) => (
              <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-7 shadow-[0_2px_16px_rgba(16,51,102,0.06)]" data-animate data-animate-delay={String(i * 120)}>
                <div class="mb-4 h-1 w-10 rounded-full bg-pink"></div>
                <div
                  class="font-display text-[3rem] font-black leading-none text-pink [font-variant-numeric:tabular-nums]"
                  data-count={s.value}
                  data-count-suffix={s.unit}
                >
                  {s.value}{s.unit}
                </div>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-gray">
                  {s.label}<sup class="ml-0.5 text-[9px] text-gray/40">※{s.note}</sup>
                </p>
              </div>
            ))
          }
        </div>
        <p class="mt-4 text-center text-[11px] leading-relaxed text-gray/40">
          ※1
          <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
            プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
          </a>
          ／ ※2
          <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
            kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
          </a>
        </p>
      </div>

      <div class="mt-12 border-t border-navy/10 pt-8 text-center" data-animate="fade-in">
        <p class="text-base font-bold text-navy md:text-lg">
          Plugdoは、診断で現状を数字にしてから、作り直しと運用で更新が止まらないサイトにします。
        </p>
      </div>
    </div>
  </section>

  <!-- サービス分岐カード -->
  <ServiceCards />

  <!-- 進め方4ステップ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">- Process -</p>
        <h2 class="section-title">進め方</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gray">
          入口は無料のAI診断。そこから必要なものだけを選べます。
        </p>
      </div>
      <div class="relative mx-auto mt-12 max-w-4xl">
        <!-- 横プログレスライン（PC：ノード中心を結ぶ） -->
        <div class="absolute left-[12.5%] right-[12.5%] top-5 hidden h-0.5 bg-mist md:block" aria-hidden="true"></div>
        <ol class="grid gap-0 md:grid-cols-4 md:gap-4">
          {
            steps.map((s, i) => (
              <li class="relative flex items-start gap-4 pb-8 last:pb-0 md:flex-col md:items-center md:gap-0 md:pb-0 md:text-center">
                {i < steps.length - 1 && (
                  <span
                    class="absolute left-5 top-11 h-[calc(100%-2.75rem)] w-0.5 -translate-x-1/2 bg-mist md:hidden"
                    aria-hidden="true"
                  />
                )}
                <span class="relative z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-navy font-display text-base font-black text-white ring-4 ring-paper [font-variant-numeric:tabular-nums]">
                  {s.no}
                </span>
                <div class="pt-1.5 md:mt-4 md:pt-0">
                  <div class="mb-1 flex items-center gap-2 md:justify-center">
                    <span class="inline-flex h-5 w-5 items-center justify-center text-pink" set:html={s.icon} />
                    <span class="font-display text-[10px] font-bold uppercase tracking-widest text-gray">STEP {s.no}</span>
                  </div>
                  <h3 class="text-base font-bold text-navy">{s.title}</h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-gray">{s.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- なぜこの価格でできるのか -->
  <WhyAffordable />

  <!-- 選ばれる理由 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Why plugdo</p>
        <h2 class="section-title">選ばれる理由</h2>
        <p class="mx-auto mt-5 max-w-lg text-sm leading-relaxed text-gray">
          デザイン・マーケティング・プロダクト開発——それぞれの領域で10年以上の実績を持つ専門家が、あなたのサイト改善を支えます。
        </p>
      </div>
      <div class="mt-12 grid gap-8 md:grid-cols-3">

        <!-- 齋藤 勇 / UI/UX Designer -->
        <div data-animate data-animate-delay="0">
          <div class="relative overflow-hidden rounded-2xl">
            <img src="/about-a.jpg.webp" alt="齋藤 勇 UI/UX Designer" class="h-80 w-full object-cover object-[center_15%] grayscale" loading="lazy" width="600" height="400" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/70"></div>
            <div class="absolute left-0 top-0 p-6">
              <span class="mb-2 block h-0.5 w-8 bg-pink"></span>
              <h3 class="text-xl font-black leading-snug text-white drop-shadow">デザインに<br />強い。</h3>
            </div>
            <div class="absolute bottom-0 left-0 p-6">
              <p class="font-display text-xl font-black leading-snug text-pink drop-shadow-sm">UI/UX Designer</p>
              <p class="mt-1 text-sm font-medium text-white/80">齋藤 勇</p>
            </div>
          </div>
          <p class="mt-4 text-sm leading-relaxed text-ink/70">デザイナー歴10年以上、制作会社や事業会社を経て、独立。新規事業やPoC案件を数多く経験。デザイン視点から経営課題やゴールを可視化し、事業の骨格づくりを得意とする。</p>
        </div>

        <!-- 吉楽 一平 / Marketer -->
        <div data-animate data-animate-delay="80">
          <div class="relative overflow-hidden rounded-2xl">
            <img src="/about-b.jpg.webp" alt="吉楽 一平 Marketer" class="h-80 w-full object-cover object-[center_20%] grayscale" loading="lazy" width="600" height="400" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/70"></div>
            <div class="absolute left-0 top-0 p-6">
              <span class="mb-2 block h-0.5 w-8 bg-pink"></span>
              <h3 class="text-xl font-black leading-snug text-white drop-shadow">作業者ではなく、<br />設計者。</h3>
            </div>
            <div class="absolute bottom-0 left-0 p-6">
