---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PriceTable from '../components/PriceTable.astro';
import CaseCard from '../components/CaseCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import { getCases, getBlogs } from '../lib/microcms';
import { sampleCases, sampleBlogs } from '../lib/sampleData';

// 事例・ブログを取得（未接続時はサンプルにフォールバック）
const casesRes = await getCases({ limit: 3 });
const cases = casesRes.contents.length ? casesRes.contents : sampleCases;

const blogsRes = await getBlogs({ limit: 3 });
const blogs = blogsRes.contents.length ? blogsRes.contents : sampleBlogs.slice(0, 3);

// 出典つきの定量データ（裏付け）。数字は一次ソースで検証済み。出典は脚注で控えめに掲載。
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';

const problems = [
  {
    title: '更新できていない',
    text: '公開したきり、情報が古いまま止まっている。その状態は、見る人に不信感を与えます。',
    stat: '49.8',
    unit: '%',
    statLabel: '更新されていないと「本当に営業しているのか不安になる」',
    note: 1,
  },
  {
    title: '問い合わせ・取引につながらない',
    text: '訪れても、行動に至らない。情報が古いだけで、ビジネスの機会を逃しています。',
    stat: '32.6',
    unit: '%',
    statLabel: '更新が止まった会社とは「取引しようと思わない」',
    note: 1,
  },
  {
    title: '直す人が社内にいない',
    text: '改善したくても、判断・実装できる人材が社内にいない。打ち手が見えないまま止まります。',
    stat: '48.2',
    unit: '%',
    statLabel: '従業員10〜29人の企業で「システム担当者がいない」',
    note: 2,
  },
];

// サービス（毎月やること付き）
const services = [
  {
    title: '継続的な改善',
    description: '作って終わりにしない。月次でサイトを更新し、改善提案と実装を繰り返します。',
    accent: 'bg-navy/8',
    iconStroke: '#103366',
    items: [
      'コンテンツ更新・追加（月2〜4本）',
      '検索キーワードの調査と最適化',
      'お問い合わせ導線の改善提案',
      '競合サイト・検索トレンドの調査',
    ],
  },
  {
    title: 'AI検索（AIO）対応',
    description: 'ChatGPTやPerplexityなどのAI検索に正しく読まれ、引用される構造へ対応します。',
    accent: 'bg-pink/10',
    iconStroke: '#E43172',
    items: [
      '構造化データ（Schema.org）の実装',
      'AI引用されやすいコンテンツ設計',
      'FAQ・Q&Aセクションの整備',
      'AI検索への引用状況チェック',
    ],
  },
  {
    title: '社内担当のように伴走',
    description: 'Web担当者を雇わなくても大丈夫。社外のパートナーが社内担当のように向き合います。',
    accent: 'bg-gold/15',
    iconStroke: '#C8A951',
    items: [
      '月次改善レポートの提出',
      '翌月の改善計画・優先順位の提案',
      '専任担当による質問・相談対応',
      '月次オンラインMTG（30分）',
    ],
  },
];

// トップページの Service 構造化データ
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'ホームページ運用・改善サービス',
  name: 'plugdo',
  provider: { '@type': 'Organization', name: '株式会社ハンチス' },
  areaServed: 'JP',
  description:
    '作ったきりのホームページを、継続的な改善とAIO対応で問い合わせ・採用につなげる伴走型サービス。',
};
---

<BaseLayout
  title="plugdo（プラグドゥ）"
  description="ホームページを、働かせる。作ったきりのサイトを、継続的な改善とAI検索対応で問い合わせと採用につなげる伴走型サービス。Web担当者がいない中小企業のためのplugdo。"
  jsonLd={serviceLd}
>
  <Hero />

  <!-- 課題提起 -->
  <section class="bg-mist">
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Problem</p>
        <h2 class="section-title">サイトはある。でも——</h2>
        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-gray">
          「ホームページがある会社は信頼できる」と答えた経営者は79.8%<sup class="text-pink">※1</sup>。
          でも<strong class="text-navy">作ったきり</strong>では、その信頼はむしろ逆効果になります。
        </p>
      </div>

      <!-- 3つの数字 -->
      <div class="mt-14 grid gap-12 md:grid-cols-3">

        <!-- 数字 0 -->
        <div class="text-center" data-animate data-animate-delay="0">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[0].stat} data-count-suffix={problems[0].unit}>
            {problems[0].stat}{problems[0].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[0].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[0].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[0].note}</sup>
          </p>
        </div>

        <!-- 数字 1 -->
        <div class="text-center" data-animate data-animate-delay="120">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[1].stat} data-count-suffix={problems[1].unit}>
            {problems[1].stat}{problems[1].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[1].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[1].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[1].note}</sup>
          </p>
        </div>

        <!-- 数字 2 -->
        <div class="text-center" data-animate data-animate-delay="240">
          <div class="font-display text-[5.5rem] font-black leading-none text-pink"
               data-count={problems[2].stat} data-count-suffix={problems[2].unit}>
            {problems[2].stat}{problems[2].unit}
          </div>
          <h3 class="mt-5 text-base font-bold text-navy">{problems[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray">
            {problems[2].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[2].note}</sup>
          </p>
        </div>

      </div>

      <!-- ブリッジ -->
      <div class="mt-16 border-t border-navy/10 pt-10 text-center" data-animate="fade-in">
        <p class="text-base font-bold text-navy md:text-lg">その「もったいない」を、plugdoが解決します。</p>
      </div>

      <!-- 出典（控えめな脚注） -->
      <p class="mt-6 text-center text-[11px] leading-relaxed text-gray/40">
        ※1
        <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
        </a>
        ／ ※2
        <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
        </a>
      </p>
    </div>
  </section>

  <!-- How it works: 3ステップ -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">How it works</p>
        <h2 class="section-title">月次サイクルで、<br />サイトが育っていく。</h2>
        <p class="mx-auto mt-5 max-w-md text-sm leading-relaxed text-gray">
          3ステップを毎月繰り返すことで、サイトが「成果を出す状態」になっていきます。
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">

        <!-- Step 01 -->
        <div class="overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="0">
          <div class="flex h-36 items-center justify-center border-b border-navy/6 bg-white">
            <div class="flex flex-col items-center gap-2 text-navy/20">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
              <span class="text-[10px] font-medium tracking-wide">イメージ（後で追加）</span>
            </div>
          </div>
          <div class="bg-mist p-7 text-center">
            <p class="select-none font-grotesk text-[3rem] font-bold leading-none text-navy/10">01</p>
            <h3 class="mt-2 text-xl font-bold text-navy">診断する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">現状のサイトを分析し、改善すべき課題を特定します。何から手をつければいいかが明確になります。</p>
          </div>
        </div>

        <!-- Step 02 -->
        <div class="overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="120">
          <div class="flex h-36 items-center justify-center border-b border-navy/6 bg-white">
            <div class="flex flex-col items-center gap-2 text-navy/20">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
              <span class="text-[10px] font-medium tracking-wide">イメージ（後で追加）</span>
            </div>
          </div>
          <div class="bg-mist p-7 text-center">
            <p class="select-none font-grotesk text-[3rem] font-bold leading-none text-navy/10">02</p>
            <h3 class="mt-2 text-xl font-bold text-navy">改善する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">コンテンツ更新・SEO・AIO対応を毎月実施。作って終わりではなく、継続的に動かし続けます。</p>
          </div>
        </div>

        <!-- Step 03 -->
        <div class="overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="240">
          <div class="flex h-36 items-center justify-center border-b border-navy/6 bg-white">
            <div class="flex flex-col items-center gap-2 text-navy/20">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
              </svg>
              <span class="text-[10px] font-medium tracking-wide">イメージ（後で追加）</span>
            </div>
          </div>
          <div class="bg-mist p-7 text-center">
            <p class="select-none font-grotesk text-[3rem] font-bold leading-none text-navy/10">03</p>
            <h3 class="mt-2 text-xl font-bold text-navy">計測する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">月次レポートで成果を確認し、次の改善に活かします。PDCAが自然に回り続けます。</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- サービス概要（毎月やることリスト付き） -->
  <section class="bg-mist">
    <div class="container-pd py-20 md:py-28">
      <div class="text-center">
        <p class="section-label">Service</p>
        <h2 class="section-title">毎月、こんなことをやります</h2>
        <p class="mx-auto mt-4 max-w-lg text-sm text-gray">plugdoはホームページの「継続運用」を丸ごと担います。<br />毎月やることを3つのカテゴリに分けて整理しました。</p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">

        <!-- 継続的な改善 -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="0">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-navy/8">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#103366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[0].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[0].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[0].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- AI検索（AIO）対応 -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="120">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-pink/10">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E43172" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>
              <path d="M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[1].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[1].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[1].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- 社内担当のように伴走 -->
        <div class="card flex flex-col p-7" data-animate data-animate-delay="240">
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gold/15">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C8A951" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="7" r="2"/>
              <path d="M6 21v-2a4 4 0 0 1 4-4h.5"/>
              <circle cx="17" cy="7" r="2"/>
              <path d="M14 21v-2a4 4 0 0 1 4-4h.5"/>
              <path d="M12 11v2.5"/>
              <path d="M12 16v2"/>
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{services[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink/70">{services[2].description}</p>
          <ul class="mt-5 space-y-2.5 border-t border-mist pt-5">
            {services[2].items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="mt-10 text-center">
        <a href="/service" class="btn-outline">サービスの詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- 導入事例 -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="flex items-end justify-between">
        <div>
          <p class="section-label-left">Works</p>
          <h2 class="section-title">導入事例</h2>
        </div>
        <a href="/cases" class="hidden text-sm font-bold text-pink hover:text-pinkAlt md:inline">
          すべて見る →
        </a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {cases.map((item, i) => (
          <div data-animate data-animate-delay={i * 100}>
            <CaseCard item={item} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 料金プラン -->
  <section class="bg-mist">
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Price</p>
        <h2 class="section-title">料金プラン</h2>
        <p class="mt-4 text-sm text-gray">事業のフェーズに合わせて選べる3プラン。まずは無料相談から。</p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3 md:items-stretch">

        <!-- Basic -->
        <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-8 shadow-sm" data-animate data-animate-delay="0">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-display text-xl font-bold text-navy">Basic</h3>
              <p class="mt-0.5 text-sm text-gray">まず動かす</p>
            </div>
            <span class="rounded-full bg-mist px-2.5 py-1 text-[10px] font-bold text-gray">AIO なし</span>
          </div>
          <div class="mt-5 flex items-end gap-1.5">
            <span class="font-display text-4xl font-bold leading-none text-navy">¥30,000</span>
            <span class="mb-0.5 text-sm text-gray">〜/月（税別）</span>
          </div>
          <p class="mt-4 rounded-xl bg-mist px-4 py-3 text-xs leading-relaxed text-ink/70">
            「とにかくサイトを最新の状態に保ちたい」方に。
          </p>
          <ul class="mt-5 flex-1 space-y-2.5">
            {[
              'コンテンツ更新 月1回',
              '月次アクセスレポート',
              '軽微な修正・差し替え対応',
              'メール相談 月3件まで',
            ].map((f) => (
              <li class="flex items-start gap-2 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-navy/30" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn-navy mt-8 w-full text-center text-sm">このプランを相談する</a>
        </div>

        <!-- Growth (おすすめ) -->
        <div class="relative flex flex-col rounded-2xl border-2 border-pink bg-white p-8 shadow-[0_4px_32px_rgba(228,49,114,0.12)]" data-animate data-animate-delay="120">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-pink px-4 py-1 text-xs font-bold text-white">★ おすすめ</span>
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-display text-xl font-bold text-navy">Growth</h3>
              <p class="mt-0.5 text-sm text-gray">改善して増やす</p>
            </div>
            <span class="rounded-full bg-navy px-2.5 py-1 text-[10px] font-bold text-white">AIO対応</span>
          </div>
          <div class="mt-5 flex items-end gap-1.5">
            <span class="font-display text-4xl font-bold leading-none text-navy">¥60,000</span>
            <span class="mb-0.5 text-sm text-gray">〜/月（税別）</span>
          </div>
          <p class="mt-4 rounded-xl bg-pink/6 px-4 py-3 text-xs leading-relaxed text-navy/80">
            「問い合わせを増やしたい。何を改善すればいいか教えてほしい」方に。
          </p>
          <ul class="mt-5 flex-1 space-y-2.5">
            {[
              'コンテンツ更新 月2回',
              '月次改善提案レポート',
              'AIO・構造化データ対応',
              'ブログ記事制作 月1本',
            ].map((f) => (
              <li class="flex items-start gap-2 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-pink" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn-pink mt-8 w-full text-center text-sm">このプランを相談する</a>
        </div>

        <!-- Partner -->
        <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-8 shadow-sm" data-animate data-animate-delay="240">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-display text-xl font-bold text-navy">Partner</h3>
              <p class="mt-0.5 text-sm text-gray">戦略から伴走</p>
            </div>
            <span class="rounded-full bg-navy px-2.5 py-1 text-[10px] font-bold text-white">AIO対応</span>
          </div>
          <div class="mt-5 flex items-end gap-1.5">
            <span class="font-display text-4xl font-bold leading-none text-navy">¥100,000</span>
            <span class="mb-0.5 text-sm text-gray">〜/月（税別）</span>
          </div>
          <p class="mt-4 rounded-xl bg-mist px-4 py-3 text-xs leading-relaxed text-ink/70">
            「サイトをビジネスの核に育てたい。採用・問い合わせ両方で成果を出したい」方に。
          </p>
          <ul class="mt-5 flex-1 space-y-2.5">
            {[
              '更新対応 無制限（緊急対応含む）',
              '月次MTG + Web戦略の立案',
              'AIO本格対応・引用モニタリング',
              'ブログ記事制作 月2〜3本',
            ].map((f) => (
              <li class="flex items-start gap-2 text-sm text-ink/80">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-navy/30" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn-navy mt-8 w-full text-center text-sm">このプランを相談する</a>
        </div>

      </div>

      <div class="mt-10 text-center">
        <a href="/price" class="btn-outline">詳細な機能一覧を見る</a>
      </div>
    </div>
  </section>

  <!-- ブログ最新記事 -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="flex items-end justify-between">
        <div>
          <p class="section-label-left">Blog</p>
          <h2 class="section-title">最新記事</h2>
        </div>
        <a href="/blog" class="hidden text-sm font-bold text-pink hover:text-pinkAlt md:inline">
          すべて見る →
        </a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {blogs.map((item, i) => (
          <div data-animate data-animate-delay={i * 100}>
            <BlogCard item={item} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
