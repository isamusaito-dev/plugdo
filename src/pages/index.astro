---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PriceTable from '../components/PriceTable.astro';
import BlogCard from '../components/BlogCard.astro';
import CTASection from '../components/CTASection.astro';
import { getBlogs } from '../lib/microcms';
import { sampleBlogs } from '../lib/sampleData';
import { plans } from '../lib/plans';
import { SITE_URL } from '../lib/site';

// ブログを取得（未接続時はサンプルにフォールバック）
const blogsRes = await getBlogs({ limit: 3 });
const blogs = blogsRes.contents.length ? blogsRes.contents : sampleBlogs.slice(0, 3);

// 出典つきの定量データ（裏付け）。数字は一次ソースで検証済み。出典は脚注で控えめに掲載。
const SRC_PLUST = 'https://www.profuture.co.jp/mk/column/11182';
const SRC_KUBELL = 'https://www.kubell.com/news/2025/12/research.html';

const problems = [
  {
    title: 'サイトが止まっている',
    text: '最後に更新したのが、いつか思い出せない。その状態は、見る人に不信感を与えます。',
    stat: '49.8',
    unit: '%',
    statLabel: '更新されていないと「本当に営業しているのか不安になる」',
    note: 1,
  },
  {
    title: '問い合わせにつながらない',
    text: 'サイトはあるけれど、訪れても行動に至らない。ビジネスの機会を逃しています。',
    stat: '32.6',
    unit: '%',
    statLabel: '更新が止まった会社とは「取引しようと思わない」',
    note: 1,
  },
  {
    title: '何から手をつければいいか分からない',
    text: '相談できる相手がいない。SNSもLINEもやった方がいい気はするけど、手が回らない。',
    stat: '48.2',
    unit: '%',
    statLabel: '従業員10〜29人の企業で「システム担当者がいない」',
    note: 2,
  },
];

// サービス（毎月やること付き）
const services = [
  {
    title: 'サイトを改善して、受け皿をつくる',
    description: 'デザインの力で見た目と導線を整え、サイトを問い合わせの受け皿として機能させます。改善を毎月繰り返すことで、問い合わせ・採用が増える状態をつくります。',
    accent: 'bg-navy/8',
    iconStroke: '#103366',
    items: [
      'デザイン・導線の改善実装',
      'コンテンツ更新・追加',
      'AIO（AI検索）対応',
      '毎月の改善提案レポート',
    ],
  },
  {
    title: '入口をつなぐ',
    description: 'LINE公式・SNS・広告など、バラバラになりがちな入口をサイトというゴールに向けて設計・接続します。続けるほど成果の土台が積み上がります。',
    accent: 'bg-pink/10',
    iconStroke: '#E43172',
    items: [
      'LINE公式アカウントとの導線設計',
      'SNS投稿設計・サイトへの接続',
      '広告LP・流入経路の整備',
      'チャネル別成果の計測・改善',
    ],
  },
  {
    title: '社内のWeb担当のように動きます',
    description: 'Web担当者がいなくても問題ありません。デザインに強い社外パートナーが、社内担当のように毎月向き合い続けます。',
    accent: 'bg-gold/15',
    iconStroke: '#C8A951',
    items: [
      '毎月の改善レポート提出',
      '翌月の改善計画・優先順位の提案',
      'Slackでいつでも相談対応',
      '毎月のオンラインMTG',
    ],
  },
];

// トップページの Service 構造化データ
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE_URL}/#service`,
  serviceType: 'ホームページ運用・改善サービス',
  name: 'plugdo（プラグドゥ）',
  url: SITE_URL,
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'Japan' },
  audience: {
    '@type': 'BusinessAudience',
    name: 'Web担当者のいない中小企業・小規模事業者',
  },
  description:
    'ホームページを"集客の受け皿（ハブ）"として立て直し、LINE・SNS・広告などの入口をつなぐ。デザインに強い社外のWeb担当が、月額制で問い合わせ・採用を増やします。',
  offers: plans.map((p) => ({
    '@type': 'Offer',
    name: p.name,
    description: `${p.commit}（${p.commitNote}）`,
    price: p.price.replace(/[¥,]/g, ''),
    priceCurrency: 'JPY',
    url: `${SITE_URL}/price`,
  })),
};

// よくある質問（FAQPage = AI検索に引用されやすいQ&A形式）
const faqs = [
  {
    q: 'plugdoはどんなサービスですか？',
    a: 'ホームページを"集客の受け皿（ハブ）"として立て直し、LINE・SNS・広告などの入口をつないで問い合わせ・採用を増やすWeb運用サービスです。デザインに強い社外のパートナーが「社内のWeb担当」のように毎月伴走します。',
  },
  {
    q: '料金はいくらですか？',
    a: '月額制で、Keep（¥30,000〜）・Grow（¥80,000〜）・Partner（¥150,000〜）の3プランがあります（いずれも税別の最低月額）。サイトの規模や対応範囲により変動し、正確な金額は無料診断時にお伝えします。初期費用はかかりません。',
  },
  {
    q: 'AIO（AI検索対応）とは何ですか？',
    a: 'ChatGPTやPerplexity、GoogleのAI Overviewsなどの生成AI検索で「○○を相談したい」と調べたときに、あなたの会社の情報が正しく引用・紹介される状態をつくる取り組みです。構造化データ（JSON-LD）の整備、意味のあるHTML構造、FAQの整備などを行います。',
  },
  {
    q: 'Web担当者がいなくても利用できますか？',
    a: 'はい。むしろWeb担当者がいない会社のためのサービスです。更新・改善の提案から実装、レポートまでをplugdoが代行するため、専門知識がなくてもサイトを改善し続けられます。',
  },
  {
    q: '契約期間や解約の条件はありますか？',
    a: '最低利用期間は3ヶ月です。サイト改善は数ヶ月単位で効果が現れるため、一定期間の継続をお願いしています。4ヶ月目以降は当月末締めでいつでも解約でき、違約金はありません。',
  },
  {
    q: 'まず何から始めればいいですか？',
    a: '無料のサイト診断からお試しいただけます。30分のオンライン相談で、今のサイトのどこを直せば問い合わせが増えるのか、改善すべき箇所と優先順位をまとめたレポートをお渡しします。費用・契約は不要です。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Plugdo｜デザインに強い、社外のWeb担当｜月額制で集客と採用を"
  description="ホームページを軸に、LINE・SNS・広告までつないで問い合わせと採用を増やす。デザインに強い社外のWeb担当が、月額制で毎月伴走します。まずは無料Web診断から。"
  jsonLd={[serviceLd, faqLd]}
>
  <Hero />

  <!-- 課題提起 -->
  <section class="relative overflow-hidden bg-mist">
    <svg class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"><defs><pattern id="geo-problem" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1.2" fill="#103366" opacity="0.05"/></pattern></defs><rect width="100%" height="100%" fill="url(#geo-problem)"/></svg>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">Problem</p>
        <h2 class="section-title">こんな状態、<br />ありませんか。</h2>
        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-gray">
          多くの会社で、ホームページは<strong class="text-navy">「作って終わり」のまま眠っています。</strong>
          更新されていないサイトは、信頼より不信感につながります<sup class="text-pink">※1</sup>。
        </p>
      </div>

      <!-- 3つの数字 -->
      <div class="mt-14 grid gap-6 md:grid-cols-3 md:items-stretch">

        <!-- 数字 0 -->
        <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-8 shadow-sm" data-animate data-animate-delay="0">
          <div class="mb-5 h-1 w-10 rounded-full bg-pink"></div>
          <div class="font-display text-[3.5rem] font-black leading-none text-pink"
               data-count={problems[0].stat} data-count-suffix={problems[0].unit}>
            {problems[0].stat}{problems[0].unit}
          </div>
          <h3 class="mt-4 text-base font-bold text-navy">{problems[0].title}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-gray">
            {problems[0].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[0].note}</sup>
          </p>
        </div>

        <!-- 数字 1 -->
        <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-8 shadow-sm" data-animate data-animate-delay="120">
          <div class="mb-5 h-1 w-10 rounded-full bg-pink"></div>
          <div class="font-display text-[3.5rem] font-black leading-none text-pink"
               data-count={problems[1].stat} data-count-suffix={problems[1].unit}>
            {problems[1].stat}{problems[1].unit}
          </div>
          <h3 class="mt-4 text-base font-bold text-navy">{problems[1].title}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-gray">
            {problems[1].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[1].note}</sup>
          </p>
        </div>

        <!-- 数字 2 -->
        <div class="flex flex-col rounded-2xl border border-gray/10 bg-white p-8 shadow-sm" data-animate data-animate-delay="240">
          <div class="mb-5 h-1 w-10 rounded-full bg-pink"></div>
          <div class="font-display text-[3.5rem] font-black leading-none text-pink"
               data-count={problems[2].stat} data-count-suffix={problems[2].unit}>
            {problems[2].stat}{problems[2].unit}
          </div>
          <h3 class="mt-4 text-base font-bold text-navy">{problems[2].title}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-gray">
            {problems[2].statLabel}<sup class="ml-0.5 text-[9px] text-gray/40">※{problems[2].note}</sup>
          </p>
        </div>

      </div>

      <!-- ブリッジ -->
      <div class="mt-16 border-t border-navy/10 pt-10 text-center" data-animate="fade-in">
        <p class="text-base font-bold text-navy md:text-lg">plugdoは、サイトを受け皿にして入口をつなぎ、成果まで一緒に追います。</p>
      </div>

      <!-- 出典（控えめな脚注） -->
      <p class="mt-6 text-center text-[11px] leading-relaxed text-gray/40">
        ※1
        <a href={SRC_PLUST} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          プラスト「中小企業のホームページに関する調査」2020年（n=1,127）
        </a>
        ／ ※2
        <a href={SRC_KUBELL} target="_blank" rel="noopener" class="underline decoration-gray/20 underline-offset-2 hover:text-gray/70">
          kubell「中小企業のデジタル化に関する調査」2025年（n=1,093）
        </a>
      </p>
    </div>
  </section>

  <!-- How it works: 3ステップ -->
  <section>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center" data-animate="fade-in">
        <p class="section-label">How it works</p>
        <h2 class="section-title">診断して、直して、成果を確認する。<br />このサイクルを毎月まわします。</h2>
        <p class="mx-auto mt-5 max-w-md text-sm leading-relaxed text-gray">
          このサイクルを続けることで、サイトが「問い合わせにつながる状態」に育っていきます。
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3 md:items-stretch">

        <!-- Step 01: 診断する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="0">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-sky to-mist">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- ブラウザ -->
              <rect x="8" y="10" width="76" height="58" rx="8" fill="white" opacity="0.9"/>
              <rect x="8" y="10" width="76" height="18" rx="8" fill="#EBEEF2"/>
              <rect x="8" y="22" width="76" height="6" fill="#EBEEF2"/>
              <circle cx="16" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <circle cx="23" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <rect x="32" y="13" width="38" height="10" rx="5" fill="white" opacity="0.7"/>
              <!-- コンテンツライン -->
              <rect x="16" y="36" width="48" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <rect x="16" y="46" width="36" height="5" rx="2.5" fill="#E43172" opacity="0.2"/>
              <rect x="16" y="56" width="42" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <!-- ルーペ -->
              <circle cx="98" cy="54" r="22" fill="white" opacity="0.7"/>
              <circle cx="94" cy="50" r="13" fill="none" stroke="#103366" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="103" y1="59" x2="112" y2="68" stroke="#103366" stroke-width="3" stroke-linecap="round"/>
              <!-- ハイライト -->
              <rect x="16" y="46" width="22" height="5" rx="2.5" fill="#E43172" opacity="0.5"/>
              <!-- 発見バッジ -->
              <rect x="72" y="20" width="38" height="18" rx="9" fill="#103366"/>
              <text x="91" y="32.5" text-anchor="middle" font-size="8" font-family="system-ui,sans-serif" fill="white" font-weight="700">5件発見</text>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">01</p>
            <h3 class="mt-3 text-xl font-bold text-navy">今のサイトを診断する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">デザイン・導線・SEO・AIへの対応状況を確認し、何を直せば成果が出るかを整理します。</p>
          </div>
        </div>

        <!-- Step 02: 改善する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="120">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-sky to-mist">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- ブラウザ -->
              <rect x="22" y="10" width="76" height="58" rx="8" fill="white" opacity="0.9"/>
              <rect x="22" y="10" width="76" height="18" rx="8" fill="#EBEEF2"/>
              <rect x="22" y="22" width="76" height="6" fill="#EBEEF2"/>
              <circle cx="30" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <circle cx="37" cy="19" r="2.5" fill="#103366" opacity="0.2"/>
              <!-- コンテンツライン (更新中) -->
              <rect x="30" y="36" width="52" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <rect x="30" y="46" width="40" height="5" rx="2.5" fill="#E43172" opacity="0.15"/>
              <rect x="30" y="56" width="46" height="5" rx="2.5" fill="#103366" opacity="0.08"/>
              <!-- 更新中バッジ -->
              <rect x="30" y="43" width="34" height="11" rx="5.5" fill="white" stroke="#E43172" stroke-width="1.2" stroke-opacity="0.5"/>
              <text x="47" y="51.5" text-anchor="middle" font-size="6" font-family="system-ui,sans-serif" fill="#E43172" font-weight="700">更新中...</text>
              <!-- チェックマーク群 -->
              <circle cx="112" cy="30" r="12" fill="#E43172" opacity="0.1"/>
              <path d="M106 30 L110 34 L118 24" stroke="#E43172" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="112" cy="56" r="10" fill="#103366" opacity="0.08"/>
              <path d="M107 56 L110 59 L117 51" stroke="#103366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <!-- 月次ラベル -->
              <rect x="86" y="72" width="46" height="16" rx="8" fill="#E43172"/>
              <text x="109" y="83.5" text-anchor="middle" font-size="7.5" font-family="system-ui,sans-serif" fill="white" font-weight="700">毎月実施</text>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">02</p>
            <h3 class="mt-3 text-xl font-bold text-navy">実際に手を動かして改善する</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">デザイン・コンテンツ・問い合わせ導線を毎月改善します。「言われた通り直す」のではなく、成果につながる改善を実装します。</p>
          </div>
        </div>

        <!-- Step 03: 計測する -->
        <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-gray/10 shadow-sm" data-animate data-animate-delay="240">
          <div class="flex h-56 flex-shrink-0 items-center justify-center bg-gradient-to-br from-navy/5 to-mist">
            <svg viewBox="0 0 140 96" class="h-44 w-auto" fill="none" aria-hidden="true">
              <!-- レポートカード -->
              <rect x="14" y="8" width="112" height="76" rx="10" fill="white" opacity="0.9"/>
              <rect x="14" y="8" width="112" height="22" rx="10" fill="#EAF3FB"/>
              <rect x="14" y="24" width="112" height="6" fill="#EAF3FB"/>
              <text x="24" y="22" font-size="7.5" font-family="system-ui,sans-serif" fill="#103366" font-weight="700">月次レポート</text>
              <!-- バーチャート (増加傾向) -->
              <rect x="26" y="65" width="10" height="12" rx="2" fill="#EBEEF2"/>
              <rect x="41" y="58" width="10" height="19" rx="2" fill="#EBEEF2"/>
              <rect x="56" y="50" width="10" height="27" rx="2" fill="#103366" opacity="0.18"/>
              <rect x="71" y="42" width="10" height="35" rx="2" fill="#103366" opacity="0.28"/>
              <rect x="86" y="34" width="10" height="43" rx="2" fill="#E43172" opacity="0.7"/>
              <!-- トレンドライン -->
              <path d="M31 69 L46 61 L61 53 L76 45 L91 37" stroke="#E43172" stroke-width="1.5" stroke-dasharray="3,2" stroke-linecap="round"/>
              <!-- 最新値バッジ -->
              <rect x="80" y="22" width="38" height="15" rx="7.5" fill="#103366"/>
              <text x="99" y="32.5" text-anchor="middle" font-size="8" font-family="system-ui,sans-serif" fill="white" font-weight="700">+8件/月</text>
              <!-- ベースライン -->
              <line x1="22" y1="77" x2="102" y2="77" stroke="#EBEEF2" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="flex-1 bg-white p-7">
            <p class="select-none font-grotesk text-2xl font-bold leading-none text-navy/10">03</p>
            <h3 class="mt-3 text-xl font-bold text-navy">成果を確認して次に活かす</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">毎月レポートで問い合わせの変化を可視化。何が効いたか確認しながら、翌月の改善を決めます。</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- サービス概要（毎月やることリスト付き） -->
  <section class="relative overflow-hidden bg-mist">
    <svg class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"><defs><pattern id="geo-service" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1.2" fill="#103366" opacity="0.05"/></pattern></defs><rect width="100%" height="100%" fill="url(#geo-service)"/></svg>
    <div class="container-pd py-20 md:py-28">
      <div class="text-center">
        <p class="section-label">Service</p>
        <h2 class="section-title">Plugdoがやること</h2>
        <p class="mx-auto mt-4 max-w-lg text-sm text-gray">サイトを改善し、入口をつなぎ、成果まで一緒に追う。<br />毎月の役割を3つに整理しました。</p>
      </div>

      <div class="mt-10 space-y-4">

        <!-- 01: 継続的な改善（フルワイド） -->
        <div class="overflow-hidden rounded-2xl border border-gray/10 bg-white shadow-sm" data-animate data-animate-delay="0">
          <div class="flex items-start gap-7 p-9">
            <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-navy">
              <span class="font-display text-xl font-black text-white">01</span>
            </div>
            <div class="flex-1">
              <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-navy/35">サイト改善・デザイン</p>
              <h3 class="mt-1 text-2xl font-black text-navy">{services[0].title}</h3>
