---
import BaseLayout from '../layouts/BaseLayout.astro';

const FORMSPREE_ENDPOINT = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT;
const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://plugdo.jp';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: 'お問い合わせ', item: 'https://plugdo.jp/contact' },
  ],
};
---

<BaseLayout
  title="お問い合わせ"
  description="plugdoへのお問い合わせ・無料サイト診断のお申し込みはこちら。会社名・お名前・ご相談内容をお送りください。Web担当者がいなくても、サイト改善の第一歩を無料で始められます。"
  jsonLd={breadcrumbLd}
>
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-20">
      <p class="section-label">- Contact -</p>
      <h1 class="text-3xl font-black text-navy md:text-4xl">お問い合わせ</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink">
        無料サイト診断のお申し込み、サービスへのご質問など、お気軽にご連絡ください。通常2営業日以内にご返信します。
      </p>
    </div>
  </section>

  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="mx-auto max-w-2xl">
        <!-- 送信完了メッセージ（JSで ?success=true 時に表示） -->
        <div
          id="thanks"
          class="card hidden border-pink bg-pink/5 p-8 text-center"
          role="status"
        >
          <p class="font-display text-2xl text-navy">Thank you!</p>
          <p class="mt-3 text-sm leading-relaxed text-ink">
            お問い合わせありがとうございます。<br />
            内容を確認のうえ、担当者より2営業日以内にご連絡いたします。
          </p>
          <a href="/" class="btn-navy mt-6 text-sm">トップへ戻る</a>
        </div>

        <form
          id="contact-form"
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="space-y-6"
        >
          <!-- 成功時に戻すURL（JS無効環境のフォールバック） -->
          <input type="hidden" name="_next" value={`${SITE_URL}/contact?success=true`} />
          <input type="hidden" name="_subject" value="【plugdo】お問い合わせがありました" />

          <!-- ハニーポット（スパム対策・人間には非表示） -->
          <div class="absolute left-[-9999px]" aria-hidden="true">
            <label>このフィールドは空のままにしてください
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div>
            <label for="company" class="block text-sm font-bold text-navy">
              会社名 <span class="text-pink">*</span>
            </label>
            <input
              id="company"
              name="会社名"
              type="text"
              required
              class="mt-2 w-full rounded-md border border-mist px-4 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
            />
          </div>

          <div>
            <label for="name" class="block text-sm font-bold text-navy">
              お名前 <span class="text-pink">*</span>
            </label>
            <input
              id="name"
              name="氏名"
              type="text"
              required
              class="mt-2 w-full rounded-md border border-mist px-4 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-bold text-navy">
              メールアドレス <span class="text-pink">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="mt-2 w-full rounded-md border border-mist px-4 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
            />
          </div>

          <div>
            <label for="tel" class="block text-sm font-bold text-navy">
              電話番号 <span class="text-gray">（任意）</span>
            </label>
            <input
              id="tel"
              name="電話番号"
              type="tel"
              class="mt-2 w-full rounded-md border border-mist px-4 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-bold text-navy">
              ご相談内容 <span class="text-pink">*</span>
            </label>
            <textarea
              id="message"
              name="相談内容"
              rows="6"
              required
              class="mt-2 w-full rounded-md border border-mist px-4 py-3 text-sm focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input
              id="consent"
              type="checkbox"
              required
              class="mt-1 h-4 w-4 flex-shrink-0 accent-pink"
            />
            <label for="consent" class="text-sm leading-relaxed text-ink">
              個人情報の取り扱いに同意します。お預かりした情報は、お問い合わせへの対応のみに利用します。
              <span class="text-pink">*</span>
            </label>
          </div>

          <p id="form-error" class="hidden text-sm text-pink" role="alert">
            送信に失敗しました。お手数ですが時間をおいて再度お試しください。
          </p>

          <button type="submit" class="btn-pink w-full">この内容で送信する</button>

          {
            !FORMSPREE_ENDPOINT && (
              <p class="text-center text-xs text-gray">
                ※ 送信先（Formspree）が未設定です。環境変数 PUBLIC_FORMSPREE_ENDPOINT を設定してください。
              </p>
            )
          }
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // 成功リダイレクト時にサンクスメッセージを表示
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    document.getElementById('thanks')?.classList.remove('hidden');
    document.getElementById('contact-form')?.classList.add('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // JSが有効ならAjax送信し、ページ遷移なしでサンクス表示（フォールバックは通常POST）
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', async (e) => {
    if (!form.action || form.action.includes('xxxxx')) return; // 未設定なら通常動作
    e.preventDefault();
    const errorEl = document.getElementById('form-error');
    errorEl?.classList.add('hidden');
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        document.getElementById('thanks')?.classList.remove('hidden');
        form.classList.add('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    }
  });
</script>
