---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { plans } from '../lib/plans';

const steps = [
  {
    no: '01',
    title: '診断',
    text: '現状のサイトを分析し、問い合わせや採用につながらない原因を可視化します。',
  },
  {
    no: '02',
    title: '提案',
    text: '優先度をつけた改善プランを提示。何を、なぜ直すのかを明確にお伝えします。',
  },
  {
    no: '03',
    title: '実装',
    text: 'コンテンツ制作・修正・AIO対応まで、改善を実際のサイトに反映します。',
  },
  {
    no: '04',
    title: '計測',
    text: '効果をレポートで確認し、次の改善へ。このサイクルを毎月まわします。',
  },
];

const aioBenefits = [
  {
    title: '速い',
    text: 'AIを活用することで、コンテンツ制作や改善のスピードが上がり、打ち手を素早く試せます。だから機会を逃しません。',
  },
  {
    title: '継続的',
    text: '少ない工数で更新を継続できる体制をつくります。だからサイトが止まらず、検索でも評価され続けます。',
  },
];

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'ホームページ運用・改善サービス',
  name: 'plugdo',
  provider: { '@type': 'Organization', name: '株式会社ハンチス' },
  areaServed: 'JP',
  description:
    '作った後の改善に特化したホームページ運用サービス。診断・提案・実装・計測を毎月くり返してサイトを成長させます。',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://plugdo.jp/' },
    { '@type': 'ListItem', position: 2, name: 'サービス', item: 'https://plugdo.jp/service' },
  ],
};
---

<BaseLayout
  title="サービス"
  description="plugdoは「作った後」の改善に特化したホームページ運用サービス。診断・提案・実装・計測のサイクルと、Basic / Growth / Partnerの3プランで、中小企業のサイトを問い合わせと採用につなげます。"
  jsonLd={[serviceLd, breadcrumbLd]}
>
  <!-- ページヘッダー -->
  <section class="hero-gradient">
    <div class="container-pd py-16 md:py-20">
      <p class="section-label">- Service -</p>
      <h1 class="text-3xl font-black text-navy md:text-4xl">作った後を、改善する。</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink">
        多くのホームページは「作って終わり」になっています。plugdoは制作後の<strong class="font-bold text-navy">改善・運用</strong>に特化し、サイトを問い合わせと採用につながる状態へ育て続けます。
      </p>
    </div>
  </section>

  <!-- 改善の流れ -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">- Flow -</p>
        <h2 class="section-title">改善の流れ</h2>
        <p class="mt-4 text-sm text-gray">診断から計測まで、毎月まわす4ステップ。</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-4">
        {
          steps.map((s) => (
            <div class="card p-6">
              <span class="font-display text-3xl text-pink">{s.no}</span>
              <h3 class="mt-3 text-lg font-bold text-navy">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink">{s.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- AI活用の便益 -->
  <section class="bg-mist">
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">- Why AI -</p>
        <h2 class="section-title">AIを使うから、何が良いのか</h2>
        <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-gray">
          「AIを使っています」では意味がありません。大切なのは、それによって<strong class="text-navy">あなたのサイトに何が起きるか</strong>です。
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-3xl gap-6 md:grid-cols-2">
        {
          aioBenefits.map((b) => (
            <div class="card p-7">
              <h3 class="text-xl font-bold text-navy">{b.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink">{b.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- プラン別の提供内容 -->
  <section>
    <div class="container-pd py-16 md:py-20">
      <div class="text-center">
        <p class="section-label">- Plans -</p>
        <h2 class="section-title">プランごとの提供内容</h2>
      </div>
      <div class="mt-12 space-y-6">
        {
          plans.map((plan) => (
            <div class="card flex flex-col gap-6 p-7 md:flex-row md:items-start">
              <div class="md:w-64 md:flex-shrink-0">
                <h3 class="font-display text-2xl text-navy">{plan.name}</h3>
                <p class="mt-1 text-sm text-gray">{plan.target}</p>
                <p class="mt-3">
                  <span class="font-display text-2xl text-navy">{plan.price}</span>
                  <span class="text-sm text-gray">{plan.priceNote}</span>
                </p>
                <p class="mt-3 rounded-lg bg-mist px-3 py-2 text-xs leading-relaxed text-ink">
                  {plan.forWho}
                </p>
              </div>
              <div class="flex-1 space-y-4">
                {plan.groups.map((g) => (
                  <div>
                    <p class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray">{g.category}</p>
                    <ul class="grid gap-2 sm:grid-cols-2">
                      {g.items.filter(item => item.label !== 'AIO対応なし').map((f) => (
                        <li class="flex items-start gap-2 text-sm text-ink">
                          <span class="mt-0.5 text-pink" aria-hidden="true">✓</span>
                          <span>{f.label}{f.note && <span class="text-xs text-gray">（{f.note}）</span>}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href="/price" class="btn-outline">料金プランを比較する</a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
